<script>
// Move modals to body to escape .main-content stacking context
// (.main-content is position:fixed + overflow:auto which traps Bootstrap modals)
document.addEventListener('DOMContentLoaded', function() {
  ['subscribedModal', 'notSubscribedModal'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el && el.parentElement !== document.body) {
      document.body.appendChild(el);
    }
  });

  // Modal search for subscribed customers
  document.getElementById('subscribedSearch')?.addEventListener('input', function() {
    const term = this.value.toLowerCase();
    document.querySelectorAll('#subscribedTable .subscribed-row').forEach(function(row) {
      row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
  });

  // Modal search for not-subscribed customers
  document.getElementById('notSubscribedSearch')?.addEventListener('input', function() {
    const term = this.value.toLowerCase();
    document.querySelectorAll('#notSubscribedTable .not-subscribed-row').forEach(function(row) {
      row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
  });
});
</script>