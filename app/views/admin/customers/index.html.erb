<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Customer Management</h2>
    <p class="text-muted mb-0">Manage and track all your customers</p>
  </div>
  <div>
    <%= link_to new_admin_customer_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Customer
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4 g-3">
  <div class="col">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Customers</h6>
            <h4 class="mb-0"><%= @total_customers || 0 %></h4>
          </div>
          <div class="text-primary">
            <i class="bi bi-people fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Active Customers</h6>
            <h4 class="mb-0"><%= @active_customers || 0 %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-person-check fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">New This Month</h6>
            <h4 class="mb-0"><%= @new_this_month || 0 %></h4>
          </div>
          <div class="text-info">
            <i class="bi bi-person-plus fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card border-0 shadow-sm h-100 stat-card-clickable"
         data-bs-toggle="modal" data-bs-target="#subscribedModal"
         role="button" style="cursor:pointer;">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Subscribed</h6>
            <h4 class="mb-0 text-success"><%= @subscribed_count || 0 %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-patch-check fs-2"></i>
          </div>
        </div>
        <small class="text-muted">Click to view list</small>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card border-0 shadow-sm h-100 stat-card-clickable"
         data-bs-toggle="modal" data-bs-target="#notSubscribedModal"
         role="button" style="cursor:pointer;">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Not Subscribed</h6>
            <h4 class="mb-0 text-warning"><%= @not_subscribed_count || 0 %></h4>
          </div>
          <div class="text-warning">
            <i class="bi bi-person-x fs-2"></i>
          </div>
        </div>
        <small class="text-muted">Click to view list</small>
      </div>
    </div>
  </div>
</div>

<!-- Subscribed Customers Modal -->
<div class="modal fade" id="subscribedModal" tabindex="-1" aria-labelledby="subscribedModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title" id="subscribedModalLabel">
          <i class="bi bi-patch-check me-2"></i>Subscribed Customers
          <span class="badge bg-white text-success ms-2"><%= @subscribed_count || 0 %></span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div class="p-3 border-bottom">
          <input type="text" class="form-control form-control-sm" id="subscribedSearch" placeholder="Search by name, ID or phone...">
        </div>
        <% if @subscribed_customers_list.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="subscribedTable">
              <thead class="table-light sticky-top">
                <tr>
                  <th class="border-0">#</th>
                  <th class="border-0">Customer ID</th>
                  <th class="border-0">Name</th>
                  <th class="border-0">Phone</th>
                  <th class="border-0">Action</th>
                </tr>
              </thead>
              <tbody>
                <% @subscribed_customers_list.each_with_index do |customer, idx| %>
                  <tr class="subscribed-row">
                    <td class="align-middle text-muted small"><%= idx + 1 %></td>
                    <td class="align-middle"><span class="badge bg-success-subtle text-success">#<%= customer.id %></span></td>
                    <td class="align-middle fw-semibold">
                      <%= [customer.first_name, customer.middle_name.presence, customer.last_name].compact.join(' ') %>
                    </td>
                    <td class="align-middle">
                      <i class="bi bi-telephone text-muted me-1"></i><%= customer.mobile %>
                    </td>
                    <td class="align-middle">
                      <%= link_to admin_customer_path(customer.id), class: "btn btn-sm btn-outline-success", target: "_blank" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-5 text-muted">
            <i class="bi bi-patch-check fs-1 mb-3 d-block"></i>
            No subscribed customers found.
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Not Subscribed Customers Modal -->
<div class="modal fade" id="notSubscribedModal" tabindex="-1" aria-labelledby="notSubscribedModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-warning text-dark">
        <h5 class="modal-title" id="notSubscribedModalLabel">
          <i class="bi bi-person-x me-2"></i>Not Subscribed Customers
          <span class="badge bg-dark text-white ms-2"><%= @not_subscribed_count || 0 %></span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div class="p-3 border-bottom">
          <input type="text" class="form-control form-control-sm" id="notSubscribedSearch" placeholder="Search by name, ID or phone...">
        </div>
        <% if @not_subscribed_customers_list.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="notSubscribedTable">
              <thead class="table-light sticky-top">
                <tr>
                  <th class="border-0">#</th>
                  <th class="border-0">Customer ID</th>
                  <th class="border-0">Name</th>
                  <th class="border-0">Phone</th>
                  <th class="border-0">Action</th>
                </tr>
              </thead>
              <tbody>
                <% @not_subscribed_customers_list.each_with_index do |customer, idx| %>
                  <tr class="not-subscribed-row">
                    <td class="align-middle text-muted small"><%= idx + 1 %></td>
                    <td class="align-middle"><span class="badge bg-warning-subtle text-warning">#<%= customer.id %></span></td>
                    <td class="align-middle fw-semibold">
                      <%= [customer.first_name, customer.middle_name.presence, customer.last_name].compact.join(' ') %>
                    </td>
                    <td class="align-middle">
                      <i class="bi bi-telephone text-muted me-1"></i><%= customer.mobile %>
                    </td>
                    <td class="align-middle">
                      <%= link_to admin_customer_path(customer.id), class: "btn btn-sm btn-outline-warning", target: "_blank" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-5 text-muted">
            <i class="bi bi-person-x fs-1 mb-3 d-block"></i>
            All customers are subscribed!
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Filter Controls -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <label for="customerFilter" class="form-label fw-semibold">
          <i class="bi bi-people me-1 text-primary"></i>
          Select Customer
        </label>
        <select id="customerFilter" class="form-select customer-select2">
          <option value="">All Customers</option>
          <% Customer.order(:first_name, :last_name).each do |customer| %>
            <option value="<%= customer.id %>"
                    <%= 'selected' if params[:customer_id] == customer.id.to_s %>
                    data-name="<%= customer.display_name %>"
                    data-email="<%= customer.email %>"
                    data-mobile="<%= customer.mobile %>">
              <%= customer.display_name %> - <%= customer.mobile %>
            </option>
          <% end %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="deliveryPersonFilter" class="form-label fw-semibold">
          <i class="bi bi-truck me-1 text-success"></i>
          Select Delivery Person
        </label>
        <select id="deliveryPersonFilter" class="form-select delivery-person-select2">
          <option value="">All Delivery Persons</option>
          <% if defined?(DeliveryPerson) %>
            <% DeliveryPerson.active.order(:first_name, :last_name).each do |dp| %>
              <option value="<%= dp.id %>"
                      <%= 'selected' if params[:delivery_person_id] == dp.id.to_s %>
                      data-name="<%= dp.display_name %>"
                      data-mobile="<%= dp.mobile %>"
                      data-vehicle="<%= dp.vehicle_number %>">
                <%= dp.display_name %> - <%= dp.mobile %> (<%= dp.vehicle_number %>)
              </option>
            <% end %>
          <% end %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="statusFilter" class="form-label fw-semibold">
          <i class="bi bi-funnel me-1 text-info"></i>
          Status Filter
        </label>
        <select id="statusFilter" class="form-select">
          <option value="">All Status</option>
          <option value="active" <%= 'selected' if params[:status] == 'active' %>>Active</option>
          <option value="inactive" <%= 'selected' if params[:status] == 'inactive' %>>Inactive</option>
        </select>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-12">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-primary btn-sm" id="applyFilters">
            <i class="bi bi-funnel me-1"></i>Apply Filters
          </button>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="clearFilters">
            <i class="bi bi-x-circle me-1"></i>Clear All
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Customers Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Customer List</h5>
      <div class="d-flex gap-2">
        <div class="position-relative">
          <input type="text" class="form-control" placeholder="Search in table..." id="searchInput">
          <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <% if @customers.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Customer</th>
              <th class="border-0 fw-semibold">Contact Info</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Joined</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @customers.each do |customer| %>
              <tr>
                <td class="align-middle">
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-person text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-0"><%= customer.display_name %></h6>
                      <small class="text-muted">ID: #<%= customer.id %></small>
                    </div>
                  </div>
                </td>
                <td class="align-middle">
                  <div>
                    <% if customer.email.present? %>
                      <div class="small">
                        <i class="bi bi-envelope text-muted me-1"></i>
                        <%= customer.email %>
                      </div>
                    <% end %>
                    <% if customer.mobile.present? %>
                      <div class="small">
                        <i class="bi bi-telephone text-muted me-1"></i>
                        <%= customer.mobile %>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td class="align-middle">
                  <% if customer.respond_to?(:status) && customer.status %>
                    <span class="badge bg-success-subtle text-success">
                      <i class="bi bi-check-circle me-1"></i>
                      Active
                    </span>
                  <% else %>
                    <span class="badge bg-danger-subtle text-danger">
                      <i class="bi bi-x-circle me-1"></i>
                      Inactive
                    </span>
                  <% end %>
                </td>
                <td class="align-middle">
                  <%= customer.created_at.strftime("%b %d, %Y") if customer.created_at %>
                </td>
                <td class="align-middle">
                  <div class="d-flex gap-1">
                    <%= link_to admin_customer_path(customer),
                        class: "btn btn-sm btn-outline-info",
                        title: "View Details" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_customer_path(customer),
                        class: "btn btn-sm btn-outline-primary",
                        title: "Edit Customer" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <button class="btn btn-sm btn-outline-danger"
                            title="Delete Customer"
                            onclick="confirmDelete('<%= customer.display_name %>', '<%= admin_customer_path(customer) %>')">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if respond_to?(:paginate) && @customers.respond_to?(:total_pages) %>
        <div class="card-footer bg-transparent border-0">
          <%= paginate @customers %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <div class="mb-3">
          <i class="bi bi-people fs-1 text-muted"></i>
        </div>
        <h5 class="text-muted mb-3">No Customers Found</h5>
        <p class="text-muted mb-4">Start building your customer base by adding your first customer.</p>
        <%= link_to "Add Customer", new_admin_customer_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize Select2 dropdowns
  initializeSelect2Dropdowns();

  // Show flash messages with SweetAlert2
  <% if notice %>
    <% if notice.include?('deleted') %>
      Swal.fire({
        title: 'Customer Deleted Successfully!',
        html: '<%= notice.html_safe %>',
        icon: 'success',
        confirmButtonText: '<i class="bi bi-check-circle me-2"></i>Got it!',
        confirmButtonColor: '#198754',
        customClass: {
          confirmButton: 'btn btn-success px-4'
        },
        buttonsStyling: false,
        timer: 8000,
        timerProgressBar: true
      });
    <% else %>
      Swal.fire({
        title: 'Success!',
        text: '<%= notice %>',
        icon: 'success',
        confirmButtonText: 'Got it!',
        confirmButtonColor: '#198754'
      });
    <% end %>
  <% end %>

  <% if alert %>
    Swal.fire({
      title: 'Error!',
      html: '<%= alert.html_safe %>',
      icon: 'error',
      confirmButtonText: '<i class="bi bi-x-circle me-2"></i>Understood',
      confirmButtonColor: '#dc3545',
      customClass: {
        confirmButton: 'btn btn-danger px-4'
      },
      buttonsStyling: false
    });
  <% end %>

  // Search functionality in table
  const searchInput = document.getElementById('searchInput');
  const tableRows = document.querySelectorAll('tbody tr');

  searchInput?.addEventListener('input', function() {
    const searchTerm = this.value.toLowerCase();

    tableRows.forEach(row => {
      const customerName = row.cells[0]?.textContent.toLowerCase() || '';
      const contactInfo = row.cells[1]?.textContent.toLowerCase() || '';

      if (customerName.includes(searchTerm) ||
          contactInfo.includes(searchTerm)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });

  // Filter functionality
  setupFilterFunctionality();
});

// Initialize Select2 dropdowns
function initializeSelect2Dropdowns() {
  // Customer Select2
  $('.customer-select2').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select customer...',
    allowClear: true,
    width: '100%',
    templateResult: formatCustomerOption,
    templateSelection: formatCustomerSelection,
    escapeMarkup: function(markup) { return markup; }
  });

  // Delivery Person Select2
  $('.delivery-person-select2').select2({
    theme: 'bootstrap-5',
    placeholder: 'Search and select delivery person...',
    allowClear: true,
    width: '100%',
    templateResult: formatDeliveryPersonOption,
    templateSelection: formatDeliveryPersonSelection,
    escapeMarkup: function(markup) { return markup; }
  });
}

// Format customer option display
function formatCustomerOption(option) {
  if (!option.id) {
    return option.text;
  }

  const $option = $(option.element);
  const name = $option.data('name') || '';
  const email = $option.data('email') || '';
  const mobile = $option.data('mobile') || '';

  return $(`
    <div class="select2-option-content">
      <div class="fw-semibold text-primary">${name}</div>
      <div class="small text-muted">
        <i class="bi bi-envelope me-1"></i>${email} |
        <i class="bi bi-telephone me-1"></i>${mobile}
      </div>
    </div>
  `);
}

// Format customer selection display
function formatCustomerSelection(option) {
  if (!option.id) {
    return option.text;
  }

  const $option = $(option.element);
  const name = $option.data('name') || '';
  const mobile = $option.data('mobile') || '';

  return `${name} - ${mobile}`;
}

// Format delivery person option display
function formatDeliveryPersonOption(option) {
  if (!option.id) {
    return option.text;
  }

  const $option = $(option.element);
  const name = $option.data('name') || '';
  const mobile = $option.data('mobile') || '';
  const vehicle = $option.data('vehicle') || '';

  return $(`
    <div class="select2-option-content">
      <div class="fw-semibold text-success">${name}</div>
      <div class="small text-muted">
        <i class="bi bi-telephone me-1"></i>${mobile} |
        <i class="bi bi-truck me-1"></i>${vehicle}
      </div>
    </div>
  `);
}

// Format delivery person selection display
function formatDeliveryPersonSelection(option) {
  if (!option.id) {
    return option.text;
  }

  const $option = $(option.element);
  const name = $option.data('name') || '';
  const vehicle = $option.data('vehicle') || '';

  return `${name} - ${vehicle}`;
}

// Setup filter functionality
function setupFilterFunctionality() {
  const applyFiltersBtn = document.getElementById('applyFilters');
  const clearFiltersBtn = document.getElementById('clearFilters');

  // Apply filters
  applyFiltersBtn?.addEventListener('click', function() {
    const customerFilter = $('#customerFilter').val();
    const deliveryPersonFilter = $('#deliveryPersonFilter').val();
    const statusFilter = document.getElementById('statusFilter').value;

    // Build URL parameters
    const params = new URLSearchParams(window.location.search);

    if (customerFilter) {
      params.set('customer_id', customerFilter);
    } else {
      params.delete('customer_id');
    }

    if (deliveryPersonFilter) {
      params.set('delivery_person_id', deliveryPersonFilter);
    } else {
      params.delete('delivery_person_id');
    }

    if (statusFilter) {
      params.set('status', statusFilter);
    } else {
      params.delete('status');
    }

    // Navigate with filters
    window.location.href = `${window.location.pathname}?${params.toString()}`;
  });

  // Clear all filters
  clearFiltersBtn?.addEventListener('click', function() {
    $('.customer-select2').val(null).trigger('change');
    $('.delivery-person-select2').val(null).trigger('change');
    document.getElementById('statusFilter').value = '';

    // Navigate without parameters
    window.location.href = window.location.pathname;
  });
}

// Beautiful confirmation dialog for customer deletion
function confirmDelete(customerName, deleteUrl) {
  Swal.fire({
    title: '⚠️ Delete Customer?',
    html: `
      <div class="text-start">
        <p class="mb-2"><strong>Customer:</strong> ${customerName}</p>
        <div class="alert alert-warning small">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>This will permanently delete:</strong>
          <ul class="mb-0 mt-2">
            <li>Customer profile and personal information</li>
            <li>All associated orders and bookings</li>
            <li>Subscriptions and delivery records</li>
            <li>User account and login credentials</li>
            <li>All notifications and addresses</li>
          </ul>
        </div>
        <div class="alert alert-danger small mb-0">
          <i class="bi bi-shield-exclamation me-2"></i>
          <strong>Warning:</strong> This action cannot be undone once confirmed!
        </div>
      </div>
    `,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#6c757d',
    confirmButtonText: '<i class="bi bi-trash me-2"></i>Yes, Delete Permanently',
    cancelButtonText: '<i class="bi bi-x-circle me-2"></i>Cancel',
    focusCancel: true,
    customClass: {
      confirmButton: 'btn btn-danger px-4 me-3',
      cancelButton: 'btn btn-secondary px-4'
    },
    buttonsStyling: false
  }).then((result) => {
    if (result.isConfirmed) {
      // Show loading state
      Swal.fire({
        title: 'Deleting Customer...',
        html: `<div class="d-flex align-items-center justify-content-center">
                 <div class="spinner-border text-danger me-3" role="status">
                   <span class="visually-hidden">Loading...</span>
                 </div>
                 <span>Please wait while we delete <strong>${customerName}</strong> and all associated records...</span>
               </div>`,
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false
      });

      // Create and submit form for DELETE request
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = deleteUrl;

      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = csrfToken;

      const methodInput = document.createElement('input');
      methodInput.type = 'hidden';
      methodInput.name = '_method';
      methodInput.value = 'delete';

      form.appendChild(csrfInput);
      form.appendChild(methodInput);
      document.body.appendChild(form);
      form.submit();
    }
  });
}
</script>

<style>

/* Fix dropdown menu visibility */
.dropdown {
  position: relative;
}

