<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">My Profile</h2>
    <p class="text-muted mb-0">
      <span class="badge bg-primary me-2">
        <%= @user.user_type&.titleize || 'Admin' %>
      </span>
      User ID: #<%= @user.id %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_profile_path, class: "btn btn-warning" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Profile
    <% end %>
  </div>
</div>

<div class="row">
  <!-- Main Profile Information -->
  <div class="col-lg-8">
    <!-- Basic Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Basic Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">First Name</label>
            <p class="mb-0"><%= @user.first_name %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Last Name</label>
            <p class="mb-0"><%= @user.last_name %></p>
          </div>
          <% if @user.middle_name.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Middle Name</label>
              <p class="mb-0"><%= @user.middle_name %></p>
            </div>
          <% end %>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Email</label>
            <p class="mb-0">
              <i class="bi bi-envelope me-1"></i>
              <%= @user.email %>
            </p>
          </div>
          <% if @user.mobile.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Mobile</label>
              <p class="mb-0">
                <i class="bi bi-telephone me-1"></i>
                <%= @user.mobile %>
              </p>
            </div>
          <% end %>
          <% if @user.birth_date.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Birth Date</label>
              <p class="mb-0">
                <i class="bi bi-calendar me-1"></i>
                <%= @user.birth_date.strftime('%B %d, %Y') %>
              </p>
            </div>
          <% end %>
          <% if @user.gender.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Gender</label>
              <p class="mb-0"><%= @user.gender.titleize %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Professional Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Professional Information</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <% if @user.department.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Department</label>
              <p class="mb-0"><%= @user.department %></p>
            </div>
          <% end %>
          <% if @user.designation.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Designation</label>
              <p class="mb-0"><%= @user.designation %></p>
            </div>
          <% end %>
          <% if @user.joining_date.present? %>
            <div class="col-md-6 mb-3">
              <label class="form-label text-muted">Joining Date</label>
              <p class="mb-0">
                <i class="bi bi-calendar-check me-1"></i>
                <%= @user.joining_date.strftime('%B %d, %Y') %>
              </p>
            </div>
          <% end %>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Role</label>
            <p class="mb-0">
              <span class="badge bg-success">
                <%= @user.role&.titleize %>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Information -->
    <% if @user.address.present? || @user.city.present? || @user.emergency_contact_name.present? %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent border-0">
          <h5 class="mb-0">Contact Information</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <% if @user.address.present? %>
              <div class="col-12 mb-3">
                <label class="form-label text-muted">Address</label>
                <p class="mb-0">
                  <i class="bi bi-geo-alt me-1"></i>
                  <%= @user.address %>
                </p>
              </div>
            <% end %>
            <% if @user.city.present? %>
              <div class="col-md-4 mb-3">
                <label class="form-label text-muted">City</label>
                <p class="mb-0"><%= @user.city %></p>
              </div>
            <% end %>
            <% if @user.state.present? %>
              <div class="col-md-4 mb-3">
                <label class="form-label text-muted">State</label>
                <p class="mb-0"><%= @user.state %></p>
              </div>
            <% end %>
            <% if @user.pincode.present? %>
              <div class="col-md-4 mb-3">
                <label class="form-label text-muted">Pincode</label>
                <p class="mb-0"><%= @user.pincode %></p>
              </div>
            <% end %>
            <% if @user.emergency_contact_name.present? %>
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted">Emergency Contact</label>
                <p class="mb-0">
                  <i class="bi bi-person-exclamation me-1"></i>
                  <%= @user.emergency_contact_name %>
                </p>
              </div>
            <% end %>
            <% if @user.emergency_contact_mobile.present? %>
              <div class="col-md-6 mb-3">
                <label class="form-label text-muted">Emergency Contact Mobile</label>
                <p class="mb-0">
                  <i class="bi bi-telephone-plus me-1"></i>
                  <%= @user.emergency_contact_mobile %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sidebar Information -->
  <div class="col-lg-4">
    <!-- Profile Summary -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Profile Summary</h5>
      </div>
      <div class="card-body text-center">
        <div class="mb-3">
          <% if @user.profile_picture.present? %>
            <img src="<%= @user.profile_picture %>" alt="Profile Picture" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover;">
          <% else %>
            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-person-fill" style="font-size: 2rem;"></i>
            </div>
          <% end %>
        </div>
        <h6 class="mb-1"><%= @user.first_name %> <%= @user.last_name %></h6>
        <p class="text-muted mb-2"><%= @user.email %></p>
        <span class="badge bg-<%= @user.status? ? 'success' : 'danger' %>">
          <%= @user.status? ? 'Active' : 'Inactive' %>
        </span>
      </div>
    </div>

    <!-- Account Statistics -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Account Statistics</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-6 text-center border-end">
            <h4 class="text-primary mb-1"><%= @user.sign_in_count || 0 %></h4>
            <small class="text-muted">Total Logins</small>
          </div>
          <div class="col-6 text-center">
            <h4 class="text-success mb-1">
              <%= @user.last_sign_in_at ? time_ago_in_words(@user.last_sign_in_at) : 'Never' %>
            </h4>
            <small class="text-muted">Last Login</small>
          </div>
        </div>
        <hr>
        <div class="text-center">
          <small class="text-muted">
            Member since <%= @user.created_at.strftime('%B %Y') %>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>