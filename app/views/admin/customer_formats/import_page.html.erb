<% content_for :title, "Import from Master Subscription" %>

<div class="container-fluid">
  <!-- Page Header -->
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <div>
      <h1 class="h3 mb-0 text-gray-800">
        <i class="bi bi-download text-success"></i>
        Import from Master Subscription
      </h1>
      <p class="text-muted">Create monthly subscriptions from existing customer formats</p>
    </div>
    <div>
      <%= link_to admin_customer_formats_path, class: "btn btn-secondary" do %>
        <i class="bi bi-arrow-left"></i> Back to Customer Formats
      <% end %>
    </div>
  </div>

  <!-- Import Form Card -->
  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Import Configuration</h5>
        </div>
        <div class="card-body">
          <%= form_with url: import_from_master_admin_customer_formats_path, method: :post, local: false, html: { id: "importForm", class: "needs-validation" }, novalidate: true do |form| %>

            <!-- Month and Year Selection -->
            <div class="row mb-4">
              <div class="col-md-6">
                <div class="form-group">
                  <%= form.label :month, "Select Month", class: "form-label fw-bold" %>
                  <%= form.select :month,
                      options_for_select([
                        ['January', 1], ['February', 2], ['March', 3], ['April', 4],
                        ['May', 5], ['June', 6], ['July', 7], ['August', 8],
                        ['September', 9], ['October', 10], ['November', 11], ['December', 12]
                      ], Date.current.month),
                      { prompt: "Choose Month" },
                      { class: "form-select form-select-lg", required: true } %>
                  <div class="form-text">Select the month for which to create subscriptions</div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-group">
                  <%= form.label :year, "Select Year", class: "form-label fw-bold" %>
                  <%= form.select :year,
                      options_for_select((Date.current.year..(Date.current.year + 2)).map { |y| [y, y] }, Date.current.year),
                      { prompt: "Choose Year" },
                      { class: "form-select form-select-lg", required: true } %>
                  <div class="form-text">Select the year for the subscription period</div>
                </div>
              </div>
            </div>

            <!-- Batch Processing Options -->
            <div class="card border-primary mb-4">
              <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-layers me-2"></i>Processing Options</h6>
              </div>
              <div class="card-body">
                <div class="form-check mb-3">
                  <input class="form-check-input" type="radio" name="processing_mode" id="processingModeAll" value="all" checked>
                  <label class="form-check-label" for="processingModeAll">
                    <strong>Process All Customers at Once</strong>
                    <div class="text-muted small">Process all active customer formats in one operation (faster but may timeout for large datasets)</div>
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="processing_mode" id="processingModeBatch" value="batch">
                  <label class="form-check-label" for="processingModeBatch">
                    <strong>Process in Batches</strong>
                    <div class="text-muted small">Process customers in smaller batches (recommended for better control and large datasets)</div>
                  </label>
                </div>

                <!-- Batch Options (Hidden initially) -->
                <div id="batchOptions" class="mt-3 d-none">
                  <div class="row">
                    <div class="col-md-6">
                      <div class="form-group">
                        <%= form.label :batch_size, "Customers per Batch", class: "form-label" %>
                        <%= form.select :batch_size,
                            options_for_select([
                              ['5 customers', 5],
                              ['10 customers (recommended)', 10],
                              ['15 customers', 15],
                              ['20 customers', 20],
                              ['25 customers', 25]
                            ], 10),
                            {},
                            { class: "form-select" } %>
                        <div class="form-text">Number of customer formats to process per batch</div>
                      </div>
                    </div>
                    <div class="col-md-6">
                      <div class="form-group">
                        <%= form.hidden_field :batch_number, value: 1 %>
                        <label class="form-label">Current Batch</label>
                        <div class="input-group">
                          <input type="number" class="form-control" id="batchNumberDisplay" value="1" min="1" readonly>
                          <div class="input-group-text">of <span id="totalBatches">?</span></div>
                        </div>
                        <div class="form-text">Current batch being processed</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Import Process Information -->
            <div class="alert alert-info">
              <h6 class="alert-heading"><i class="bi bi-info-circle me-2"></i>Import Process Information</h6>
              <div class="row">
                <div class="col-md-6">
                  <strong>What will be created:</strong>
                  <ul class="mb-0 mt-2">
                    <li>Monthly subscriptions for selected period</li>
                    <li>Daily tasks based on delivery patterns</li>
                    <li>Customer-specific delivery schedules</li>
                  </ul>
                </div>
                <div class="col-md-6">
                  <strong>Important Notes:</strong>
                  <ul class="mb-0 mt-2">
                    <li>Only active customer formats will be processed</li>
                    <li>Process runs in background (~10 minutes)</li>
                    <li>Duplicates are automatically prevented</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="text-center">
              <button type="submit" class="btn btn-success btn-lg px-5" id="importBtn">
                <i class="bi bi-gear me-2"></i>
                <span id="importBtnText">Start Import Process</span>
                <span class="spinner-border spinner-border-sm ms-2 d-none" id="importSpinner" role="status"></span>
              </button>
              <div id="batchControls" class="d-none mt-3">
                <button type="button" class="btn btn-primary me-2" id="nextBatchBtn" disabled>
                  <i class="bi bi-arrow-right me-2"></i>
                  Process Next Batch
                </button>
                <button type="button" class="btn btn-outline-secondary" id="resetBatchBtn">
                  <i class="bi bi-arrow-clockwise me-2"></i>
                  Reset to Batch 1
                </button>
              </div>
            </div>

          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Sidebar -->
    <div class="col-lg-4">
      <!-- Current Stats Card -->
      <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
          <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Current Statistics</h6>
        </div>
        <div class="card-body">
          <div class="row text-center">
            <div class="col-6 mb-3">
              <i class="bi bi-file-text text-primary display-6"></i>
              <h4 class="text-primary mt-2"><%= @stats[:active] %></h4>
              <small class="text-muted">Active Formats</small>
            </div>
            <div class="col-6 mb-3">
              <i class="bi bi-people text-success display-6"></i>
              <h4 class="text-success mt-2"><%= Customer.joins(:customer_formats).where(customer_formats: { status: 'active' }).distinct.count rescue 0 %></h4>
              <small class="text-muted">Customers</small>
            </div>
            <div class="col-6">
              <i class="bi bi-box text-warning display-6"></i>
              <h4 class="text-warning mt-2"><%= Product.joins(:customer_formats).where(customer_formats: { status: 'active' }).distinct.count rescue 0 %></h4>
              <small class="text-muted">Products</small>
            </div>
            <div class="col-6">
              <i class="bi bi-diagram-3 text-info display-6"></i>
              <h4 class="text-info mt-2"><%= @stats[:pattern_counts].keys.count rescue 0 %></h4>
              <small class="text-muted">Patterns</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Formats Preview -->
      <div class="card shadow">
        <div class="card-header bg-secondary text-white">
          <h6 class="mb-0"><i class="bi bi-list me-2"></i>Recent Active Formats</h6>
        </div>
        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
          <% if @active_formats.any? %>
            <% @active_formats.each do |format| %>
              <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                <div class="flex-shrink-0">
                  <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-person"></i>
                  </div>
                </div>
                <div class="flex-grow-1 ms-3">
                  <h6 class="mb-0"><%= "#{format.customer.first_name} #{format.customer.last_name}" %></h6>
                  <small class="text-muted"><%= format.product.name %> - <%= format.quantity %> <%= format.pattern.humanize %></small>
                </div>
                <div class="flex-shrink-0">
                  <span class="badge bg-success">Active</span>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-inbox display-4"></i>
              <p class="mt-2">No active formats found</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Results Section (Hidden initially) -->
  <div id="importResults" class="d-none">
    <div class="card shadow mt-4">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-check-circle me-2"></i>Import Results</h5>
      </div>
      <div class="card-body" id="importResultsContent">
        <!-- Results will be loaded here -->
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const importForm = document.getElementById('importForm');
  const importBtn = document.getElementById('importBtn');
  const importBtnText = document.getElementById('importBtnText');
  const importSpinner = document.getElementById('importSpinner');
  const importResults = document.getElementById('importResults');
  const importResultsContent = document.getElementById('importResultsContent');

  // Batch processing elements
  const processingModeAll = document.getElementById('processingModeAll');
  const processingModeBatch = document.getElementById('processingModeBatch');
  const batchOptions = document.getElementById('batchOptions');
  const batchControls = document.getElementById('batchControls');
  const nextBatchBtn = document.getElementById('nextBatchBtn');
  const resetBatchBtn = document.getElementById('resetBatchBtn');
  const batchNumberDisplay = document.getElementById('batchNumberDisplay');
  const totalBatchesSpan = document.getElementById('totalBatches');

  let currentBatchInfo = null;

  // Handle processing mode changes
  if (processingModeAll && processingModeBatch) {
    [processingModeAll, processingModeBatch].forEach(radio => {
      radio.addEventListener('change', function() {
        if (processingModeBatch.checked) {
          batchOptions.classList.remove('d-none');
          updateTotalBatches();
        } else {
          batchOptions.classList.add('d-none');
          batchControls.classList.add('d-none');
        }
      });
    });
  }

  // Handle batch size changes
  const batchSizeSelect = document.querySelector('[name="batch_size"]');
  if (batchSizeSelect) {
    batchSizeSelect.addEventListener('change', updateTotalBatches);
  }

  // Update total batches calculation
  function updateTotalBatches() {
    if (processingModeBatch.checked) {
      const batchSize = parseInt(batchSizeSelect.value);
      const activeFormats = <%= @stats[:active] %>;
      const totalBatches = Math.ceil(activeFormats / batchSize);
      totalBatchesSpan.textContent = totalBatches;
    }
  }

  if (importForm) {
    importForm.addEventListener('submit', function(e) {
      e.preventDefault();
      processImport();
    });
  }

  // Handle next batch button
  if (nextBatchBtn) {
    nextBatchBtn.addEventListener('click', function() {
      const currentBatch = parseInt(document.querySelector('[name="batch_number"]').value);
      document.querySelector('[name="batch_number"]').value = currentBatch + 1;
      batchNumberDisplay.value = currentBatch + 1;
      processImport();
    });
  }

  // Handle reset batch button
  if (resetBatchBtn) {
    resetBatchBtn.addEventListener('click', function() {
      document.querySelector('[name="batch_number"]').value = 1;
      batchNumberDisplay.value = 1;
      currentBatchInfo = null;
      batchControls.classList.add('d-none');
      nextBatchBtn.disabled = false;
      importResults.classList.add('d-none');
    });
  }

  function processImport() {
    console.log('🚀 Starting import process...');

    // Show loading state
    importBtn.disabled = true;
    importBtnText.textContent = 'Processing...';
    importSpinner.classList.remove('d-none');
    nextBatchBtn.disabled = true;

    // Prepare form data
    const formData = new FormData(importForm);
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

    // Add batch processing parameters if batch mode is selected
    if (processingModeBatch.checked) {
      // Batch size is already in the form
      // Batch number is already in the form
    } else {
      // Remove batch parameters for "all at once" mode
      formData.delete('batch_size');
      formData.delete('batch_number');
    }

    // Submit request
    fetch(importForm.action, {
      method: 'POST',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': csrfToken
      }
    })
    .then(response => {
      console.log('📡 Response received:', response.status);
      if (!response.ok) {
        throw new Error(`Server error: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      console.log('✅ Import response:', data);

      // Show results
      importResults.classList.remove('d-none');

      if (data.success) {
        currentBatchInfo = data.batch_info;

        let resultContent = `
          <div class="alert alert-success">
            <h5 class="alert-heading"><i class="bi bi-check-circle me-2"></i>Import Successful!</h5>
            <p class="mb-0">${data.message}</p>
          </div>
        `;

        // Handle batch processing results
        if (currentBatchInfo) {
          resultContent += `
            <div class="card mt-3">
              <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Batch Progress</h6>
              </div>
              <div class="card-body">
                <div class="row text-center">
                  <div class="col-md-3">
                    <h5 class="text-primary">${currentBatchInfo.current_batch}</h5>
                    <small class="text-muted">Current Batch</small>
                  </div>
                  <div class="col-md-3">
                    <h5 class="text-info">${currentBatchInfo.total_batches}</h5>
                    <small class="text-muted">Total Batches</small>
                  </div>
                  <div class="col-md-3">
                    <h5 class="text-success">${currentBatchInfo.processed_in_batch}</h5>
                    <small class="text-muted">Processed in Batch</small>
                  </div>
                  <div class="col-md-3">
                    <h5 class="text-warning">${currentBatchInfo.batch_size}</h5>
                    <small class="text-muted">Batch Size</small>
                  </div>
                </div>
                <div class="progress mt-3" style="height: 20px;">
                  <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                       role="progressbar"
                       style="width: ${(currentBatchInfo.current_batch / currentBatchInfo.total_batches) * 100}%">
                    ${Math.round((currentBatchInfo.current_batch / currentBatchInfo.total_batches) * 100)}%
                  </div>
                </div>
              </div>
            </div>
          `;

          // Show batch controls and update next batch button
          batchControls.classList.remove('d-none');
          if (currentBatchInfo.next_batch_available) {
            nextBatchBtn.disabled = false;
            nextBatchBtn.innerHTML = '<i class="bi bi-arrow-right me-2"></i>Process Next Batch (' + (currentBatchInfo.current_batch + 1) + ' of ' + currentBatchInfo.total_batches + ')';
          } else {
            nextBatchBtn.disabled = true;
            nextBatchBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>All Batches Complete';
            resultContent += `
              <div class="alert alert-info mt-3">
                <h6 class="alert-heading"><i class="bi bi-star me-2"></i>All Batches Completed!</h6>
                <p class="mb-0">Successfully processed all ${currentBatchInfo.total_batches} batches.</p>
              </div>
            `;
          }
        } else {
          // Non-batch processing - show back button and auto-redirect
          resultContent += `
            <div class="text-center mt-3">
              <a href="${window.location.pathname.replace('/import_page', '')}" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i>Back to Customer Formats
              </a>
            </div>
          `;

          // Auto-redirect after 5 seconds for non-batch processing
          setTimeout(() => {
            window.location.href = window.location.pathname.replace('/import_page', '');
          }, 5000);
        }

        importResultsContent.innerHTML = resultContent;
        showAlert('success', data.message);
      } else {
        throw new Error(data.message || 'Import failed');
      }
    })
    .catch(error => {
      console.error('❌ Import error:', error);

      importResults.classList.remove('d-none');
      importResultsContent.innerHTML = `
        <div class="alert alert-danger">
          <h5 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Import Failed</h5>
          <p class="mb-0">${error.message}</p>
          <div class="mt-3">
            <button class="btn btn-primary" onclick="location.reload()">
              <i class="bi bi-arrow-clockwise me-2"></i>Try Again
            </button>
          </div>
        </div>
      `;

      showAlert('danger', error.message);
    })
    .finally(() => {
      // Reset button state
      importBtn.disabled = false;
      importBtnText.textContent = 'Start Import Process';
      importSpinner.classList.add('d-none');
    });
  }

  function showAlert(type, message) {
    const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
    const iconClass = type === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle';
    const strongText = type === 'success' ? 'Success!' : 'Error!';

    // Remove any existing alerts
    document.querySelectorAll('.alert.position-fixed').forEach(alert => alert.remove());

    const alertDiv = document.createElement('div');
    alertDiv.className = `alert ${alertClass} alert-dismissible fade show position-fixed`;
    alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
    alertDiv.innerHTML = `
      <i class="${iconClass} me-2"></i>
      <strong>${strongText}</strong> ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;

    document.body.appendChild(alertDiv);

    // Auto-remove alert after 8 seconds
    setTimeout(() => {
      if (alertDiv.parentNode) {
        alertDiv.remove();
      }
    }, 8000);
  }

  // Initial call to set up batch information
  updateTotalBatches();
});
</script>