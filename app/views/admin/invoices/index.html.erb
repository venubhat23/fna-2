// Partial Payment Modal Functions
function openPartialPaymentModal(invoiceId, invoiceNumber, totalAmount, customerName, paidAmount = 0) {
  // Calculate remaining amount
  const remainingAmount = totalAmount - paidAmount;

  // Set modal data
  document.getElementById('partialPaymentInvoiceId').value = invoiceId;
  document.getElementById('partialPaymentInvoiceNumber').textContent = invoiceNumber;
  document.getElementById('partialPaymentCustomerName').textContent = customerName;
  document.getElementById('partialPaymentTotalAmount').textContent = totalAmount.toFixed(2);
  document.getElementById('partialPaymentRemainingAmount').textContent = remainingAmount.toFixed(2);

  // Reset form
  document.getElementById('partialPaymentForm').reset();
  document.getElementById('partialPaymentInvoiceId').value = invoiceId; // Reset clears hidden fields too

  // Set max amount for input (should not exceed remaining amount)
  const amountInput = document.getElementById('partialPaymentAmount');
  amountInput.max = remainingAmount;

  // Show modal
  const modal = document.getElementById('partialPaymentModal');
  if (modal) {
    modal.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  // Focus on amount input
  setTimeout(() => {
    amountInput.focus();
  }, 100);
}

function closePartialPaymentModal() {
  const modal = document.getElementById('partialPaymentModal');
  if (modal) {
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
  }
}

// Handle partial payment form submission
document.addEventListener('DOMContentLoaded', function() {
  const partialPaymentForm = document.getElementById('partialPaymentForm');
  if (partialPaymentForm) {
    partialPaymentForm.addEventListener('submit', function(e) {
      e.preventDefault();
      processPartialPayment();
    });
  }

  // Update remaining amount when payment amount changes
  const amountInput = document.getElementById('partialPaymentAmount');
  if (amountInput) {
    amountInput.addEventListener('input', function() {
      // Get the original remaining amount that was set when modal opened
      const maxAmount = parseFloat(this.max) || 0;
      const paymentAmount = parseFloat(this.value) || 0;
      const newRemainingAmount = maxAmount - paymentAmount;

      document.getElementById('partialPaymentRemainingAmount').textContent = newRemainingAmount.toFixed(2);

      // Update button text based on remaining amount
      const processBtn = document.getElementById('processPartialPaymentBtn');
      if (newRemainingAmount <= 0) {
        processBtn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Mark as Fully Paid';
        processBtn.className = 'btn btn-success';
      } else {
        processBtn.innerHTML = '<i class="bi bi-cash me-1"></i>Process Partial Payment';
        processBtn.className = 'btn btn-warning';
      }
    });
  }
});

function processPartialPayment() {
  const form = document.getElementById('partialPaymentForm');
  const processBtn = document.getElementById('processPartialPaymentBtn');

  if (!form || !processBtn) return;

  // Get form data
  const formData = new FormData(form);
  const invoiceId = formData.get('invoice_id');
  const amount = parseFloat(formData.get('amount'));
  const notes = formData.get('notes');
  const totalAmount = parseFloat(document.getElementById('partialPaymentTotalAmount').textContent);

  // Validation
  if (!invoiceId || !amount || amount <= 0) {
    alert('Please enter a valid payment amount.');
    return;
  }

  if (amount > totalAmount) {
    alert('Payment amount cannot exceed the total invoice amount.');
    return;
  }

  // Show loading state
  const originalBtnContent = processBtn.innerHTML;
  processBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Processing...';
  processBtn.disabled = true;

  // Prepare request data
  const requestData = {
    invoice_id: invoiceId,
    amount: amount,
    notes: notes
  };

  // Send request
  fetch('/admin/invoices/partial_payment', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    },
    body: JSON.stringify(requestData)
  })
  .then(response => response.json())
  .then(result => {
    if (result.success) {
      // Show success message
      const remainingAmount = totalAmount - amount;
      const message = remainingAmount <= 0
        ? 'Invoice marked as fully paid!'
        : `Partial payment of ₹${amount.toFixed(2)} processed successfully. Remaining: ₹${remainingAmount.toFixed(2)}`;

      alert(message);
      closePartialPaymentModal();
      location.reload(); // Refresh to show updated status
    } else {
      alert('Error processing payment: ' + (result.error || 'Unknown error'));
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Error processing payment. Please try again.');
  })
  .finally(() => {
    // Reset button
    processBtn.innerHTML = originalBtnContent;
    processBtn.disabled = false;
  });
}

// Enhanced search functionality
document.addEventListener('DOMContentLoaded', function() {
