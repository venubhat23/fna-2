<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Invoice Management</h2>
    <p class="text-muted mb-0">Manage customer invoices and billing</p>
  </div>
  <div class="d-flex gap-2">
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#bulkInvoiceModal">
      <i class="bi bi-plus-lg me-1"></i>
      Generate Invoices
    </button>
  </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-xl-3 col-lg-6 col-md-6 col-sm-12 mb-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
              <i class="bi bi-receipt text-primary fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <div class="text-muted small">Total Invoices</div>
            <div class="fs-4 fw-bold text-dark"><%= number_with_delimiter(@stats[:total_invoices]) %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-lg-6 col-md-6 col-sm-12 mb-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0">
            <div class="bg-success bg-opacity-10 rounded-circle p-3">
              <i class="bi bi-currency-rupee text-success fs-4"></i>
            </div>
          </div>
          <div class="flex-grow-1 ms-3">
            <div class="text-muted small">Total Amount</div>
            <div class="fs-4 fw-bold text-dark">₹<%= number_with_delimiter(@stats[:total_amount].to_i) %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-lg-6 col-md-6 col-sm-12 mb-3">
    <%= link_to admin_invoices_path(status: 'fully_paid'), class: "text-decoration-none" do %>
      <div class="card border-0 shadow-sm h-100 clickable-card">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
              <div class="bg-success bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-check-circle text-success fs-4"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <div class="text-muted small">Paid Amount</div>
              <div class="fs-4 fw-bold text-success">₹<%= number_with_delimiter(@stats[:paid_amount].to_i) %></div>
              <div class="small text-muted"><%= @stats[:paid_count] %> invoices</div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="col-xl-3 col-lg-6 col-md-6 col-sm-12 mb-3">
    <%= link_to admin_invoices_path(status: 'pending'), class: "text-decoration-none" do %>
      <div class="card border-0 shadow-sm h-100 clickable-card">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
              <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-clock text-warning fs-4"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <div class="text-muted small">Pending Amount</div>
              <div class="fs-4 fw-bold text-warning">₹<%= number_with_delimiter(@stats[:pending_amount].to_i) %></div>
              <div class="small text-muted"><%= @stats[:pending_count] %> invoices</div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Search and Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: admin_invoices_path, method: :get, local: true, class: "search-form" do |f| %>
      <!-- First Row: Main Search and Status -->
      <div class="row g-3 align-items-end mb-3">
        <div class="col-lg-6 col-md-8">
          <%= f.text_field :search, value: params[:search], placeholder: "Search invoices, customers...",
                          class: "form-control", id: "searchInput" %>
        </div>
        <div class="col-lg-3 col-md-4">
          <%= f.select :status, options_for_select([
                ['All Status', 'all'],
                ['Paid', 'fully_paid'],
                ['Pending', 'pending'],
                ['Unpaid', 'unpaid'],
                ['Partially Paid', 'partially_paid']
              ], params[:status] || 'all'), {}, { class: "form-select" } %>
        </div>
        <div class="col-lg-3 col-md-12">
          <div class="d-flex gap-2">
            <%= f.submit "Search", class: "btn btn-primary" %>
            <%= link_to "Reset", admin_invoices_path, class: "btn btn-outline-secondary" %>
          </div>
        </div>
      </div>

      <!-- Second Row: Additional Filters -->
      <div class="row g-3 align-items-end">
        <div class="col-lg-3 col-md-6">
          <div class="input-group">
            <span class="input-group-text bg-primary text-white">
              <i class="bi bi-receipt"></i>
            </span>
            <input type="text" class="form-control" value="Regular Invoices Only" readonly>
            <input type="hidden" name="type" value="regular">
          </div>
        </div>
        <div class="col-lg-3 col-md-6">
          <%= f.select :delivery_person_id,
                options_for_select([['All Delivery Persons', 'all']] +
                                 @delivery_persons.map { |dp| [dp.display_name, dp.id] },
                                 params[:delivery_person_id] || 'all'),
                {}, { class: "form-select" } %>
        </div>
        <div class="col-lg-3 col-md-6">
          <select name="customer_id" class="form-select" id="customerSelect">
            <option value="">All Customers</option>
            <% if params[:customer_id].present? %>
              <% selected_customer = Customer.find_by(id: params[:customer_id]) %>
              <% if selected_customer %>
                <option value="<%= selected_customer.id %>" selected><%= selected_customer.display_name %></option>
              <% end %>
            <% end %>
          </select>
        </div>
        <div class="col-lg-3 col-md-6">
          <%= f.date_field :date_from, value: params[:date_from],
                          class: "form-control", placeholder: "From Date" %>
        </div>
        <div class="col-lg-3 col-md-6">
          <%= f.date_field :date_to, value: params[:date_to],
                          class: "form-control", placeholder: "To Date" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Invoices Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0 py-3">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h6 class="mb-0 text-dark">Invoice List</h6>
        <small class="text-muted">
          <% if params[:search].present? || params[:status].present? || params[:date_from].present? || params[:date_to].present? %>
            Showing filtered results (Page <%= @paginated_invoices.current_page %> of <%= @paginated_invoices.total_pages %>)
          <% else %>
            Showing page <%= @paginated_invoices.current_page %> of <%= @paginated_invoices.total_pages %>
          <% end %>
        </small>
      </div>
      <div class="d-flex align-items-center gap-2">
        <!-- Bulk Actions -->
        <div id="bulkActions" style="display: none;" class="me-3">
          <button id="bulkMarkPaidBtn" class="btn btn-success btn-sm" onclick="markSelectedAsPaid()">
            <i class="bi bi-check-circle me-1"></i>
            Mark as Paid (<span id="selectedCount">0</span>)
          </button>
          <button class="btn btn-outline-secondary btn-sm" onclick="clearSelection()">
            <i class="bi bi-x me-1"></i>
            Clear
          </button>
        </div>
        <small class="text-muted">
          Total: <%= number_with_delimiter(@paginated_invoices.total_count) %> invoices
        </small>
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <% if @invoices.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold" style="width: 50px;">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="selectAll" onchange="toggleSelectAll()">
                  <label class="form-check-label" for="selectAll"></label>
                </div>
              </th>
              <th class="border-0 fw-semibold">Invoice #</th>
              <th class="border-0 fw-semibold">Customer</th>
              <th class="border-0 fw-semibold">Amount</th>
              <th class="border-0 fw-semibold">Payment Status</th>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @invoices.each do |invoice_data| %>
              <%
                # Handle both hash data (combined) and ActiveRecord objects (legacy)
                if invoice_data.is_a?(Hash)
                  invoice_id = invoice_data[:id]
                  invoice_number = invoice_data[:invoice_number]
                  customer_name = invoice_data[:customer_name]
                  customer_mobile = invoice_data[:customer_mobile]
                  total_amount = invoice_data[:total_amount]
                  paid_amount = invoice_data[:paid_amount]
                  payment_status = invoice_data[:payment_status]
                  invoice_date = invoice_data[:invoice_date]
                  created_at = invoice_data[:created_at]
                  invoice_type = invoice_data[:type]
                  booking_number = invoice_data[:booking_number]
                  model_object = invoice_data[:model_object]
                else
                  # Legacy ActiveRecord object
                  invoice_id = invoice_data.id
                  invoice_number = invoice_data.invoice_number
                  customer_name = invoice_data.customer&.display_name || 'Walk-in Customer'
                  customer_mobile = invoice_data.customer&.mobile
                  total_amount = invoice_data.total_amount
                  paid_amount = invoice_data.paid_amount || 0
                  payment_status = invoice_data.payment_status
                  invoice_date = invoice_data.invoice_date
                  created_at = invoice_data.created_at
                  invoice_type = 'regular'
                  booking_number = nil
                  model_object = invoice_data
                end
              %>
              <tr>
                <td>
                  <% unless payment_status == 'fully_paid' %>
                    <div class="form-check">
                      <input class="form-check-input invoice-checkbox" type="checkbox"
                             value="<%= invoice_id %>"
                             id="invoice_<%= invoice_id %>"
                             onchange="updateBulkActions()"
                             data-invoice-id="<%= invoice_id %>"
                             data-invoice-type="<%= invoice_type %>">
                      <label class="form-check-label" for="invoice_<%= invoice_id %>"></label>
                    </div>
                  <% end %>
                </td>
                <td class="fw-medium text-primary">
                  <%= link_to invoice_number,
                      invoice_type == 'booking' ? "#" : admin_invoice_path(model_object),
                      class: "text-decoration-none fw-medium" %>
                </td>
                <td>
                  <div class="d-flex flex-column">
                    <span class="fw-medium"><%= customer_name || 'N/A' %></span>
                    <% if customer_mobile.present? %>
                      <small class="text-muted"><%= customer_mobile %></small>
                    <% end %>
                    <% if booking_number.present? %>
                      <small class="text-muted">Booking: <%= booking_number %></small>
                    <% end %>
                  </div>
                </td>
                <td class="fw-medium">₹<%= number_with_delimiter((total_amount || 0).to_i) %></td>
                <td>
                  <% case payment_status.to_s %>
                  <% when 'fully_paid', 'paid' %>
                    <span class="badge bg-success bg-opacity-10 text-success border border-success">
                      <i class="bi bi-check-circle me-1"></i>
                      Paid
                    </span>
                  <% when 'partially_paid' %>
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">
                      <i class="bi bi-clock me-1"></i>
                      Partial
                    </span>
                  <% else %>
                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary">
                      <i class="bi bi-x-circle me-1"></i>
                      Unpaid
                    </span>
                  <% end %>
                </td>
                <td class="text-muted">
                  <div class="d-flex flex-column">
                    <span><%= invoice_date&.strftime("%d %b %Y") if invoice_date %></span>
                    <small class="text-muted"><%= time_ago_in_words(created_at) + ' ago' if created_at %></small>
                  </div>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <% if invoice_type == 'booking' %>
                      <!-- Booking Invoice Actions -->
                      <% if model_object&.share_token.present? %>
                        <%= link_to "/invoice/#{model_object.share_token}",
                                   class: "btn btn-sm btn-outline-primary", target: "_blank",
                                   title: "View Booking Invoice", data: { bs_toggle: "tooltip" } do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                        <%= link_to "/invoice/#{model_object.share_token}.pdf",
                                   class: "btn btn-sm btn-outline-info", target: "_blank",
                                   title: "Download PDF", data: { bs_toggle: "tooltip" } do %>
                          <i class="bi bi-download"></i>
                        <% end %>
                      <% else %>
                        <span class="text-muted small">No share token</span>
                      <% end %>
                    <% else %>
                      <!-- Regular Invoice Actions -->
                      <%= link_to admin_invoice_path(model_object), class: "btn btn-sm btn-outline-primary",
                                 title: "View Invoice", data: { bs_toggle: "tooltip" } do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                      <%= link_to edit_admin_invoice_path(model_object), class: "btn btn-sm btn-outline-warning",
                                 title: "Edit Invoice", data: { bs_toggle: "tooltip" } do %>
                        <i class="bi bi-pencil-square"></i>
                      <% end %>
                      <% unless payment_status == 'fully_paid' %>
                        <button type="button" class="btn btn-sm btn-outline-warning"
                               onclick="openPartialPaymentModal(<%= invoice_id %>, '<%= invoice_number %>', <%= total_amount %>, '<%= customer_name %>', <%= paid_amount || 0 %>)"
                               title="Partial Payment"
                               data-bs-toggle="tooltip">
                          <i class="bi bi-cash"></i>
                        </button>
                        <%= button_to mark_as_paid_admin_invoice_path(model_object),
                                      method: :patch,
                                      class: "btn btn-sm btn-outline-success",
                                      title: "Mark as Paid",
                                      form: { style: "display: inline;" },
                                      data: {
                                        bs_toggle: "tooltip",
                                        confirm: "Mark this invoice as paid?"
                                      } do %>
                          <i class="bi bi-check-circle"></i>
                        <% end %>
                      <% end %>
                      <% if respond_to?(:download_pdf_admin_invoice_path) %>
                        <%= link_to download_pdf_admin_invoice_path(model_object),
                                   class: "btn btn-sm btn-outline-info", target: "_blank",
                                   title: "Download PDF", data: { bs_toggle: "tooltip" } do %>
                          <i class="bi bi-download"></i>
                        <% end %>
                      <% end %>
                    <% end %>
                    <% if invoice_type == 'regular' %>
                      <%= button_to admin_invoice_path(model_object),
                                    method: :delete,
                                  class: "btn btn-sm btn-outline-danger",
                                  title: "Delete Invoice",
                                  form: { style: "display: inline;" },
                                  data: {
                                    bs_toggle: "tooltip",
                                    confirm: "Are you sure you want to delete this invoice? This action cannot be undone."
                                  } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination Info and Controls -->
      <div class="card-footer bg-light border-0">
        <div class="d-flex justify-content-between align-items-center">
          <div class="text-muted small">
            Showing <%= @paginated_invoices.offset_value + 1 %>-<%= [@paginated_invoices.offset_value + @paginated_invoices.limit_value, @paginated_invoices.total_count].min %> of <%= number_with_delimiter(@paginated_invoices.total_count) %> invoices
          </div>
          <div>
            <%= paginate @paginated_invoices, outer_window: 2, inner_window: 2 %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-5">
        <div class="mb-3">
          <i class="bi bi-receipt-cutoff display-1 text-muted"></i>
        </div>
        <h5 class="text-muted">No Invoices Found</h5>
        <p class="text-muted mb-3">
          <% if params[:search].present? || params[:status].present? %>
            No invoices match your search criteria.
          <% else %>
            Generate invoices for completed deliveries to get started.
          <% end %>
        </p>
        <% if params[:search].present? || params[:status].present? %>
          <%= link_to "Clear Filters", admin_invoices_path, class: "btn btn-outline-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Partial Payment Modal -->
<div class="modal-overlay" id="partialPaymentModal" style="display: none;">
  <div class="simple-modal">
    <div class="modal-header bg-warning text-dark">
      <h5 class="modal-title">
        <i class="bi bi-cash"></i> Partial Payment
      </h5>
      <button type="button" class="btn-close" onclick="closePartialPaymentModal()" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <form id="partialPaymentForm">
        <input type="hidden" id="partialPaymentInvoiceId" name="invoice_id">

        <div class="mb-3">
          <label class="form-label fw-semibold">Invoice Details</label>
          <div class="card bg-light border-0">
            <div class="card-body">
              <div class="row">
                <div class="col-sm-6">
                  <small class="text-muted">Invoice Number</small>
                  <div class="fw-medium" id="partialPaymentInvoiceNumber"></div>
                </div>
                <div class="col-sm-6">
                  <small class="text-muted">Customer</small>
                  <div class="fw-medium" id="partialPaymentCustomerName"></div>
                </div>
              </div>
              <div class="row mt-2">
                <div class="col-sm-6">
                  <small class="text-muted">Total Amount</small>
                  <div class="fw-bold text-primary fs-5">₹<span id="partialPaymentTotalAmount"></span></div>
                </div>
                <div class="col-sm-6">
                  <small class="text-muted">Remaining Amount</small>
                  <div class="fw-bold text-warning fs-5">₹<span id="partialPaymentRemainingAmount"></span></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label for="partialPaymentAmount" class="form-label">
            Payment Amount <span class="text-danger">*</span>
          </label>
          <div class="input-group">
            <span class="input-group-text">₹</span>
            <input type="number"
                   class="form-control form-control-lg"
                   id="partialPaymentAmount"
                   name="amount"
                   step="0.01"
                   min="0.01"
                   required
                   placeholder="Enter payment amount">
          </div>
          <div class="form-text">
            Enter the amount being paid (must be less than remaining amount for partial payment)
          </div>
        </div>

        <div class="mb-4">
          <label for="partialPaymentNotes" class="form-label">Payment Notes</label>
          <textarea class="form-control"
                    id="partialPaymentNotes"
                    name="notes"
                    rows="3"
                    placeholder="Optional notes about this payment..."></textarea>
        </div>

        <div class="d-flex justify-content-end gap-2">
          <button type="button" class="btn btn-secondary" onclick="closePartialPaymentModal()">
            Cancel
          </button>
          <button type="submit" class="btn btn-warning" id="processPartialPaymentBtn">
            <i class="bi bi-cash me-1"></i>
            Process Payment
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Generate Invoice Modal -->
<div class="modal-overlay" id="bulkInvoiceModal" style="display: none;">
  <div class="simple-modal">
    <div class="modal-header bg-primary text-white">
      <h5 class="modal-title" id="bulkInvoiceModalLabel">
        <i class="bi bi-receipt"></i> Generate Bulk Invoices
        <span id="header_selected_count" class="badge bg-light text-primary ms-2" style="display: none;">0 Selected</span>
      </h5>
      <button type="button" class="btn-close btn-close-white" onclick="closeBulkInvoiceModal()" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body pt-4">
      <div id="bulkInvoiceLoading" class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Loading invoice form...</p>
      </div>
      <div id="bulkInvoiceContent" style="display: none;">
        <form id="generateInvoiceForm">
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="invoice_month" class="form-label">Month <span class="text-danger">*</span></label>
                <select class="form-select" id="invoice_month" name="month" required>
                  <option value="">Select Month</option>
                  <option value="1">January</option>
                  <option value="2">February</option>
                  <option value="3">March</option>
                  <option value="4">April</option>
                  <option value="5">May</option>
                  <option value="6">June</option>
                  <option value="7">July</option>
                  <option value="8">August</option>
                  <option value="9">September</option>
                  <option value="10">October</option>
                  <option value="11">November</option>
                  <option value="12">December</option>
                </select>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label for="invoice_year" class="form-label">Year <span class="text-danger">*</span></label>
                <select class="form-select" id="invoice_year" name="year" required>
                  <option value="">Select Year</option>
                  <% (2024..2030).each do |year| %>
                    <option value="<%= year %>" <%= 'selected' if year == Date.current.year %>><%= year %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label">Customer Selection <span class="text-danger">*</span></label>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="customer_selection" id="all_customers" value="all" checked>
              <label class="form-check-label" for="all_customers">
                All Customers
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="customer_selection" id="specific_customers" value="specific">
              <label class="form-check-label" for="specific_customers">
                Specific Customers
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="customer_selection" id="delivery_person_customers" value="delivery_person">
              <label class="form-check-label" for="delivery_person_customers">
                Customers by Delivery Person
              </label>
            </div>
          </div>

          <!-- Delivery Person Selection -->
          <div id="delivery_person_section" class="mb-4" style="display: none;">
            <label class="form-label">Select Delivery Person</label>
            <select class="form-select" id="delivery_person_select" name="delivery_person_id">
              <option value="">Choose Delivery Person...</option>
              <!-- Options will be populated by JavaScript -->
            </select>
            <div class="form-text">
              <i class="bi bi-info-circle me-1"></i>
              Select a delivery person to generate invoices for their customers only.
            </div>
          </div>

          <div id="customer_dropdown_section" class="mb-4" style="display: none;">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <label class="form-label mb-0">Select Customers</label>
              <span id="total_customer_count" class="badge bg-primary fs-6" style="display: none;">
                <i class="bi bi-people me-1"></i>
                <span id="total_count_text">0 available</span>
              </span>
            </div>
            <div class="border rounded p-3" style="max-height: 300px; overflow-y: auto; background-color: #f8f9fa;">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                  <button type="button" class="btn btn-sm btn-outline-primary me-2" onclick="selectAllCustomers()">
                    <i class="bi bi-check-all me-1"></i>Select All
                  </button>
                  <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllCustomers()">
                    <i class="bi bi-x-circle me-1"></i>Deselect All
                  </button>
                  <span id="selection_summary" class="badge bg-info ms-3 fs-6" style="display: none;">
                    <i class="bi bi-people-fill me-1"></i>
                    <span id="selected_count_text">0 customers selected</span>
                  </span>
                </div>
                <div>
                  <input type="text" class="form-control form-control-sm" placeholder="Search customers..."
                         id="customerSearch" onkeyup="filterCustomers()" style="width: 200px;">
                </div>
              </div>
              <div id="customers_checkbox_list">
                <!-- Customer checkboxes will be loaded dynamically -->
                <div class="text-muted text-center py-3">
                  <i class="bi bi-person-lines-fill fs-3 d-block mb-2"></i>
                  Loading customers...
                </div>
              </div>
            </div>
            <div class="form-text mt-2">
              <i class="bi bi-info-circle me-1"></i>
              Select customers using checkboxes. Use search to quickly find specific customers.
              <span id="selected_count" class="badge bg-primary ms-2">0 selected</span>
            </div>
            <!-- Hidden inputs for form submission -->
            <div id="selected_customer_inputs"></div>
          </div>

          <!-- Invoice Generation Summary -->
          <div id="invoiceGenerationSummary" class="card border-info mb-4" style="display: none;">
            <div class="card-header bg-info text-white">
              <h6 class="mb-0">
                <i class="bi bi-info-circle me-2"></i>
                Invoice Generation Summary for <span id="summaryMonthYear"></span>
              </h6>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-4">
                  <div class="text-center p-3 border-end">
                    <div class="fs-2 fw-bold text-primary" id="totalPotentialCustomers">0</div>
                    <div class="small text-muted">Total Customers</div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="text-center p-3 border-end">
                    <div class="fs-2 fw-bold text-success" id="existingInvoicesCount">0</div>
                    <div class="small text-muted">Already Have Invoices</div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="text-center p-3">
                    <div class="fs-2 fw-bold text-warning" id="availableCustomersCount">0</div>
                    <div class="small text-muted">Will Generate New</div>
                  </div>
                </div>
              </div>

              <!-- Existing Customers Section -->
              <div id="existingCustomersSection" style="display: none;" class="mt-4">
                <h6 class="text-success">
                  <i class="bi bi-check-circle me-2"></i>
                  Customers with Existing Invoices
                </h6>
                <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                  <table class="table table-sm">
                    <thead>
                      <tr>
                        <th>Customer</th>
                        <th>Invoice #</th>
                        <th>Amount</th>
                      </tr>
                    </thead>
                    <tbody id="existingCustomersList">
                      <!-- Will be populated by JavaScript -->
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- Available Customers Section -->
              <div id="availableCustomersSection" style="display: none;" class="mt-4">
                <h6 class="text-warning">
                  <i class="bi bi-person-plus me-2"></i>
                  Customers Ready for New Invoices (Sample)
                </h6>
                <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                  <table class="table table-sm">
                    <thead>
                      <tr>
                        <th>Customer</th>
                        <th>Mobile</th>
                      </tr>
                    </thead>
                    <tbody id="availableCustomersList">
                      <!-- Will be populated by JavaScript -->
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="text-end">
            <button type="button" class="btn btn-outline-info me-2" onclick="checkInvoiceSummary()">
              <i class="bi bi-search me-1"></i>
              Preview Invoice Summary
            </button>
            <button type="button" class="btn btn-secondary me-2" onclick="closeBulkInvoiceModal()">
              Cancel
            </button>
            <button type="submit" class="btn btn-primary" id="generateInvoiceBtn" disabled>
              <i class="bi bi-receipt me-1"></i>
              Generate Invoices
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal CSS -->
<style>
