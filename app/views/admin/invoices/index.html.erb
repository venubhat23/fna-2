  // Show batch info if available
  if (result.batch_info) {
    message += `
      <div class="alert alert-light mb-2">
        <strong>Batch Processing Summary:</strong><br>
        ${result.batch_info.successful_batches}/${result.batch_info.total_batches} batches succeeded<br>
        Batch size: ${result.batch_info.batch_size} customers
      </div>
    `;
  }

  // Show detailed errors if available
  if (result.detailed_errors && result.detailed_errors.length > 0) {
    message += `
      <details class="mt-2">
        <summary class="text-danger fw-semibold">Show Error Details (${result.detailed_errors.length})</summary>
