<div class="item-card">
  <button type="button" class="remove-item-btn mob-remove-item"><i class="bi bi-trash"></i></button>

  <div class="field-label">Product *</div>
  <%= f.select :product_id,
      options_for_select(
        @products.map { |p| [p.name, p.id, { 'data-unit-type' => p.unit_type || 'units', 'data-default-price' => p.default_selling_price }] },
        f.object.product_id
      ),
      { prompt: 'Select product' },
      { class: 'mob-select mob-product-select', required: true } %>

  <div class="item-row">
    <div>
      <div class="field-label">Qty *</div>
      <%= f.number_field :quantity, class: 'mob-input mob-qty', placeholder: '0', step: 0.01, min: 0.01, required: true %>
    </div>
    <div>
      <div class="field-label">Purchase ₹ *</div>
      <%= f.number_field :purchase_price, class: 'mob-input mob-purchase-price', placeholder: '0.00', step: 0.01, min: 0.01, required: true %>
    </div>
    <div>
      <div class="field-label">Selling ₹ *</div>
      <%= f.number_field :selling_price, class: 'mob-input mob-selling-price', placeholder: '0.00', step: 0.01, min: 0.01, required: true %>
    </div>
  </div>

  <div class="line-total">Line total: ₹0.00</div>

  <%= f.hidden_field :_destroy, class: 'destroy-field' %>
</div>
