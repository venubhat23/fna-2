<style>
.pl-search-bar {
  background: white;
  padding: 10px 14px;
  border-bottom: 1px solid #e9ecef;
  position: sticky;
  top: 100px;
  z-index: 89;
}
.pl-search-input {
  border-radius: 20px;
  border: 2px solid #e9ecef;
  padding: 8px 16px 8px 38px;
  font-size: 0.9rem;
  width: 100%;
  outline: none;
  transition: border-color 0.2s;
}
.pl-search-input:focus { border-color: #2e7d32; }
.pl-search-input { padding-right: 34px; }
.pl-search-wrap { position: relative; }
.pl-search-wrap .bi-search { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 0.9rem; }
.pl-clear-btn {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  background: none; border: none; padding: 0; line-height: 0;
  color: #aaa; font-size: 1.05rem; cursor: pointer;
  display: none; align-items: center;
}
.pl-clear-btn:hover { color: #6c757d; }

.cat-pills { display: flex; gap: 6px; overflow-x: auto; padding: 8px 0 2px; scrollbar-width: none; }
.cat-pills::-webkit-scrollbar { display: none; }
.cat-pill {
  flex-shrink: 0;
  border-radius: 20px;
  border: 2px solid #dee2e6;
  background: white;
  color: #6c757d;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 12px;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
  transition: all 0.15s;
}
.cat-pill.active, .cat-pill:hover {
  background: #2e7d32;
  border-color: #2e7d32;
  color: white;
}

.pl-summary {
  background: linear-gradient(135deg, #2e7d32, #1b5e20);
  color: white;
  padding: 10px 16px;
  font-size: 0.82rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cat-section { margin: 10px 12px; }
.cat-header {
  background: linear-gradient(135deg, #2e7d32, #1b5e20);
  color: white;
  padding: 8px 14px;
  border-radius: 10px 10px 0 0;
  font-size: 0.85rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6px;
}
.pl-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 0 0 10px 10px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  font-size: 0.78rem;
}
.pl-table th {
  background: #f8f9fa;
  color: #6c757d;
  font-weight: 700;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  padding: 8px 10px;
  text-align: left;
  border-bottom: 1px solid #e9ecef;
}
.pl-table td {
  padding: 9px 10px;
  border-bottom: 1px solid #f5f5f5;
  vertical-align: middle;
}
.pl-table tr:last-child td { border-bottom: none; }
.pl-table tr:hover td { background: #fafafa; }

.prod-name { font-weight: 600; color: #1a1a1a; line-height: 1.3; }
.prod-sku { font-size: 0.65rem; color: #aaa; margin-top: 1px; }

.price-sell { font-weight: 700; color: #1a7f37; }
.price-cost { color: #6c757d; }

.stock-badge {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 12px;
  white-space: nowrap;
}
.stock-in    { background: #d4edda; color: #155724; }
.stock-low   { background: #fff3cd; color: #856404; }
.stock-out   { background: #f8d7da; color: #721c24; }

.no-products { text-align: center; padding: 20px; color: #aaa; font-size: 0.85rem; }

.empty-state { text-align: center; padding: 60px 24px; color: #aaa; }
.empty-state i { font-size: 3.5rem; display: block; margin-bottom: 12px; }
</style>

<%# Search & Category Filter %>
<div class="pl-search-bar">
  <%= form_with url: admin_mobile_ui_price_list_path, method: :get, local: true, data: { no_loader: '' } do |f| %>
    <div class="pl-search-wrap mb-2">
      <i class="bi bi-search"></i>
      <%= f.text_field :search, value: params[:search], class: 'pl-search-input',
          placeholder: 'Search product name or SKU…', autocomplete: 'off',
          id: 'plSearch' %>
      <button type="button" id="plClearSearch" class="pl-clear-btn"
              style="<%= 'display:flex;' if params[:search].present? %>"
              onclick="clearPlSearch()" aria-label="Clear search">
        <i class="bi bi-x-circle-fill"></i>
      </button>
    </div>
    <%= f.hidden_field :category_id, value: params[:category_id], id: 'catHidden' %>
    <div class="cat-pills">
      <a href="#" class="cat-pill <%= params[:category_id].blank? ? 'active' : '' %>"
         onclick="setCat(''); return false;">All</a>
      <% @categories.each do |cat| %>
        <a href="#" class="cat-pill <%= params[:category_id].to_s == cat.id.to_s ? 'active' : '' %>"
           onclick="setCat('<%= cat.id %>'); return false;"><%= cat.name %></a>
      <% end %>
    </div>
  <% end %>
</div>

<%# Summary bar %>
<% total_products = @products_by_category.values.flatten.size %>
<% in_stock_count = @products_by_category.values.flatten.count { |p| p.cached_stock.to_i > 0 } %>
<div class="pl-summary">
  <span><i class="bi bi-tags me-1"></i><strong><%= total_products %></strong> products</span>
  <span>
    <span style="color:#86efac;"><i class="bi bi-check-circle-fill me-1"></i><%= in_stock_count %> in stock</span>
    &nbsp;
    <span style="color:#fca5a5;"><i class="bi bi-x-circle-fill me-1"></i><%= total_products - in_stock_count %> out</span>
  </span>
</div>

<% if @products_by_category.any? %>
  <% @products_by_category.each do |(cat_id, cat_name), products| %>
    <div class="cat-section">
      <div class="cat-header">
        <i class="bi bi-folder2-open"></i>
        <%= cat_name.presence || 'Uncategorized' %>
        <span style="margin-left:auto; font-size:0.72rem; opacity:0.8;"><%= products.size %> items</span>
      </div>
      <table class="pl-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Sell ₹</th>
            <th>Stock</th>
          </tr>
        </thead>
        <tbody>
          <% products.each do |product| %>
            <%
              stock_qty   = product.cached_stock.to_i
              low_thresh  = 5

              sell_price  = product.discount_price.present? && product.discount_price > 0 ? product.discount_price : product.price

              if stock_qty <= 0
                stock_cls  = 'stock-out'
                stock_icon = 'bi-x-circle-fill'
                stock_lbl  = 'Out'
              elsif stock_qty <= low_thresh
                stock_cls  = 'stock-low'
                stock_icon = 'bi-exclamation-circle-fill'
                stock_lbl  = "#{stock_qty} Low"
              else
                stock_cls  = 'stock-in'
                stock_icon = 'bi-check-circle-fill'
                stock_lbl  = stock_qty.to_s
              end
            %>
            <tr>
              <td>
                <div class="prod-name"><%= product.name %></div>
                <div class="prod-sku"><%= product.sku %></div>
              </td>
              <td>
                <span class="price-sell">₹<%= number_with_delimiter(sell_price.to_f.round(2)) %></span>
                <% if product.discount_price.present? && product.discount_price > 0 && product.price != product.discount_price %>
                  <br><span style="font-size:0.65rem;color:#aaa;text-decoration:line-through;">₹<%= number_with_delimiter(product.price.to_f.round(2)) %></span>
                <% end %>
              </td>
              <td>
                <span class="stock-badge <%= stock_cls %>">
                  <i class="bi <%= stock_icon %>"></i><%= stock_lbl %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <div class="empty-state">
    <i class="bi bi-tags"></i>
    <h5 class="text-muted">No Products Found</h5>
    <p class="text-muted" style="font-size:0.9rem;">
      <%= params[:search].present? || params[:category_id].present? ? 'Try clearing your filters.' : 'No products available.' %>
    </p>
  </div>
<% end %>

<script>
function setCat(val) {
  showLoader('Loading…', 'Filtering by category');
  document.getElementById('catHidden').value = val;
  document.getElementById('plSearch').closest('form').submit();
}

function clearPlSearch() {
  const input = document.getElementById('plSearch');
  input.value = '';
  document.getElementById('plClearSearch').style.display = 'none';
  showLoader('Loading…', 'Clearing search');
  input.closest('form').submit();
}

let plSearchTimer;
document.getElementById('plSearch').addEventListener('input', function() {
  document.getElementById('plClearSearch').style.display = this.value ? 'flex' : 'none';
  clearTimeout(plSearchTimer);
  plSearchTimer = setTimeout(() => this.closest('form').submit(), 500);
});
</script>
