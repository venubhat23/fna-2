<style>
/* Search & Filter Bar */
.search-bar {
  background: white;
  padding: 10px 14px;
  border-bottom: 1px solid #e9ecef;
  position: sticky;
  top: 100px;
  z-index: 90;
}
.search-input {
  border-radius: 20px;
  border: 2px solid #e9ecef;
  padding: 8px 16px 8px 38px;
  font-size: 0.9rem;
  width: 100%;
  outline: none;
  transition: border-color 0.2s;
}
.search-input:focus { border-color: #2e7d32; }
.search-wrap { position: relative; }
.search-wrap .bi-search { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 0.9rem; }
.filter-pills { display: flex; gap: 6px; overflow-x: auto; padding: 8px 0 2px; scrollbar-width: none; }
.filter-pills::-webkit-scrollbar { display: none; }
.filter-pill {
  flex-shrink: 0;
  border-radius: 20px;
  border: 2px solid #dee2e6;
  background: white;
  color: #6c757d;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 12px;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
  transition: all 0.15s;
}
.filter-pill.active, .filter-pill:hover {
  background: #2e7d32;
  border-color: #2e7d32;
  color: white;
}

/* Summary bar */
.summary-bar {
  background: linear-gradient(135deg, #2e7d32, #1b5e20);
  color: white;
  padding: 10px 16px;
  font-size: 0.82rem;
}

/* Booking Cards */
.booking-card {
  background: white;
  border-radius: 14px;
  margin: 8px 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  overflow: hidden;
  transition: transform 0.15s;
  border: 1px solid #f0f0f0;
}
.booking-card:active { transform: scale(0.98); }
.booking-card-header {
  padding: 12px 14px 8px;
  border-bottom: 1px solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.booking-number { font-weight: 700; font-size: 0.92rem; color: #1a1a1a; }
.booking-date { font-size: 0.73rem; color: #888; margin-top: 1px; }
.booking-card-body { padding: 10px 14px; }
.customer-name { font-weight: 600; font-size: 0.95rem; color: #222; }
.customer-phone { font-size: 0.8rem; color: #666; margin-top: 2px; }
.booking-card-footer {
  background: #fafafa;
  border-top: 1px solid #f0f0f0;
  padding: 10px 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}
.amount-badge {
  font-size: 1rem;
  font-weight: 700;
  color: #1a7f37;
}
.action-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; justify-content: flex-end; }

/* Status pill */
.status-pill {
  font-size: 0.68rem;
  font-weight: 600;
  padding: 3px 9px;
  border-radius: 20px;
  letter-spacing: 0.2px;
  display: inline-block;
}
.s-draft        { background: #f0f0f0; color: #555; }
.s-pending      { background: #fff3cd; color: #856404; }
.s-confirmed    { background: #cfe2ff; color: #0a58ca; }
.s-processing   { background: #d1ecf1; color: #0c5460; }
.s-packed       { background: #d4edda; color: #155724; }
.s-shipped      { background: #cce5ff; color: #004085; }
.s-out_delivery { background: #ffeeba; color: #856404; }
.s-delivered    { background: #d4edda; color: #155724; }
.s-completed    { background: #d4edda; color: #155724; }
.s-cancelled    { background: #f8d7da; color: #721c24; }
.s-returned     { background: #f8d7da; color: #721c24; }

/* Payment badge */
.pay-paid    { background: #d4edda; color: #155724; }
.pay-unpaid  { background: #f8d7da; color: #721c24; }
.pay-partial { background: #fff3cd; color: #856404; }

/* Action icon buttons */
.icon-btn {
  width: 34px; height: 34px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: transform 0.1s;
}
.icon-btn:active { transform: scale(0.9); }
.icon-view  { background: #e3f2fd; color: #1976d2; }
.icon-edit  { background: #e8f5e9; color: #2e7d32; }
.icon-view-invoice { background: #f3e5f5; color: #7b1fa2; }
.icon-edit-invoice { background: #fff3e0; color: #e65100; }
.icon-wa    { background: #e8f8ee; color: #25d366; }
.icon-wa:hover { background: #25d366; color: white; }

/* Invoice share */
.wa-send-btn {
  background: #25d366;
  color: white;
  border: none;
  border-radius: 22px;
  font-size: 0.82rem;
  font-weight: 600;
  padding: 6px 14px;
  display: flex; align-items: center; gap: 5px;
  text-decoration: none;
  white-space: nowrap;
}
.wa-send-btn:hover, .wa-send-btn:active { background: #1ebe5d; color: white; }

/* Empty state */
.empty-state { text-align: center; padding: 60px 24px; color: #aaa; }
.empty-state i { font-size: 3.5rem; display: block; margin-bottom: 12px; }

/* Pagination */
.pager { display: flex; justify-content: center; gap: 8px; padding: 16px; }
.page-btn {
  padding: 8px 18px; border-radius: 20px; border: 2px solid #dee2e6;
  background: white; color: #2e7d32; font-weight: 600; font-size: 0.85rem;
  text-decoration: none;
}
.page-btn.active { background: #2e7d32; border-color: #2e7d32; color: white; }
</style>

<%# Search & Filters %>
<div class="search-bar">
  <%= form_with url: admin_mobile_ui_bookings_path, method: :get, local: true, data: { no_loader: '' } do |f| %>
    <div class="search-wrap mb-2">
      <i class="bi bi-search"></i>
      <%= f.text_field :search, value: params[:search], class: 'search-input',
          placeholder: 'Search booking #, name, phone…', autocomplete: 'off',
          id: 'mobileSearch' %>
    </div>
    <%# hidden status field updated by pills below %>
    <%= f.hidden_field :status, value: params[:status], id: 'statusHidden' %>
    <div class="filter-pills">
      <% statuses = [
           ['All', ''],
           ['Draft', 'draft'],
           ['Pending', 'ordered_and_delivery_pending'],
           ['Confirmed', 'confirmed'],
           ['Processing', 'processing'],
           ['Packed', 'packed'],
           ['Shipped', 'shipped'],
           ['Out for Delivery', 'out_for_delivery'],
           ['Delivered', 'delivered'],
           ['Completed', 'completed'],
           ['Cancelled', 'cancelled'],
           ['Returned', 'returned']
         ] %>
      <% statuses.each do |label, val| %>
        <a href="#"
           class="filter-pill <%= params[:status].to_s == val ? 'active' : '' %>"
           onclick="setStatus('<%= val %>'); return false;">
          <%= label %>
        </a>
      <% end %>
    </div>
  <% end %>
</div>

<%# Summary bar %>
<div class="summary-bar d-flex justify-content-between align-items-center">
  <span><i class="bi bi-receipt me-1"></i><strong><%= @total %></strong> bookings</span>
  <span style="font-size:0.75rem; opacity:0.8;"><%= Date.current.strftime('%d %b %Y') %></span>
</div>

<%# Bookings list %>
<% if @bookings.any? %>
  <% @bookings.each do |booking| %>
    <%
      phone_raw   = (booking.customer&.mobile || booking.customer_phone).to_s
      phone_clean = phone_raw.gsub(/\D/, '').sub(/^0+/, '').sub(/^91/, '')
      wa_phone    = phone_clean.present? ? "91#{phone_clean}" : nil
      cname       = booking.customer&.display_name || booking.customer_name.presence || 'Walk-in'
      bdate       = (booking.respond_to?(:booking_date) && booking.booking_date.present? ? booking.booking_date : booking.created_at)&.strftime('%d %b %Y')
      amount      = number_with_delimiter(booking.total_amount.to_f.round(2))

      status_css = case booking.status&.to_s
                   when 'draft'                         then 's-draft'
                   when 'ordered_and_delivery_pending'  then 's-pending'
                   when 'confirmed'                     then 's-confirmed'
                   when 'processing'                    then 's-processing'
                   when 'packed'                        then 's-packed'
                   when 'shipped'                        then 's-shipped'
                   when 'out_for_delivery'              then 's-out_delivery'
                   when 'delivered'                     then 's-delivered'
                   when 'completed'                     then 's-completed'
                   when 'cancelled'                     then 's-cancelled'
                   when 'returned'                      then 's-returned'
                   else 's-draft'
                   end

      pay_css = case booking.payment_status&.to_s
                when 'paid'           then 'pay-paid'
                when 'unpaid'         then 'pay-unpaid'
                when 'partially_paid' then 'pay-partial'
                else 'pay-unpaid'
                end

      inv = booking.associated_invoice
      inv&.generate_share_token! if inv && inv.share_token.blank?
      invoice_pdf_url = inv&.share_token.present? ? public_invoice_by_token_url(inv.share_token, format: :pdf) : nil

      # WhatsApp thank-you message — includes invoice PDF link if an invoice exists
      pdf_line = invoice_pdf_url ? "\n📄 Download Invoice PDF: #{invoice_pdf_url}" : ""
      wa_thank_msg = "Dear #{cname},\n\nThank you for your booking with Atma Nirbhar Farm! 🌾\n\nBooking #: #{booking.booking_number}\nDate: #{bdate}\nAmount: ₹#{amount}#{pdf_line}\n\nWe appreciate your trust in us!\n\n🙏 Atma Nirbhar Farm Team"
    %>
    <div class="booking-card">
      <div class="booking-card-header">
        <div>
          <div class="booking-number">#<%= booking.booking_number %></div>
          <div class="booking-date"><i class="bi bi-calendar3 me-1"></i><%= bdate %></div>
        </div>
        <div class="d-flex flex-column align-items-end gap-1">
          <span class="status-pill <%= status_css %>"><%= booking.status&.humanize || 'Unknown' %></span>
          <span class="status-pill <%= pay_css %>"><%= booking.payment_status&.humanize || 'Unpaid' %></span>
        </div>
      </div>

      <div class="booking-card-body">
        <div class="customer-name"><i class="bi bi-person-fill me-1 text-muted" style="font-size:0.8rem;"></i><%= cname %></div>
        <% if phone_raw.present? %>
          <div class="customer-phone"><i class="bi bi-telephone-fill me-1"></i><%= phone_raw %></div>
        <% end %>
        <div class="mt-1 d-flex align-items-center gap-2 flex-wrap">
          <small class="text-muted">
            <i class="bi bi-bag me-1"></i><%= pluralize(booking.booking_items.size, 'item') %>
          </small>
          <% if booking.has_invoice? %>
            <span class="status-pill" style="background:#f3e5f5;color:#7b1fa2;">
              <i class="bi bi-receipt me-1"></i><%= booking.display_invoice_number %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="booking-card-footer">
        <div class="amount-badge">₹<%= amount %></div>
        <div class="action-row">
          <%# View %>
          <%= link_to admin_mobile_ui_show_booking_path(booking), class: 'icon-btn icon-view', title: 'View' do %>
            <i class="bi bi-eye-fill"></i>
          <% end %>

          <%# Edit %>
          <%= link_to admin_mobile_ui_edit_booking_path(booking), class: 'icon-btn icon-edit', title: 'Edit' do %>
            <i class="bi bi-pencil-fill"></i>
          <% end %>

          <%# Show / Edit Invoice — only when a regular Invoice exists for this booking %>
          <% if booking.associated_invoice.present? %>
            <%= link_to admin_mobile_ui_show_invoice_path(booking.associated_invoice), class: 'icon-btn icon-view-invoice', title: 'Show Invoice' do %>
              <i class="bi bi-receipt"></i>
            <% end %>
            <%= link_to admin_mobile_ui_edit_invoice_path(booking.associated_invoice), class: 'icon-btn icon-edit-invoice', title: 'Edit Invoice' do %>
              <i class="bi bi-pencil-square"></i>
            <% end %>
          <% end %>

          <%# WhatsApp Thanks button — for paid and unpaid bookings %>
          <% if wa_phone.present? %>
            <a href="https://wa.me/<%= wa_phone %>?text=<%= ERB::Util.url_encode(wa_thank_msg) %>"
               class="wa-send-btn" target="_blank" title="Send Thank You + Invoice Link on WhatsApp">
              <i class="bi bi-whatsapp"></i> Thanks
            </a>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Pagination %>
  <% if @bookings.respond_to?(:total_pages) && @bookings.total_pages > 1 %>
    <div class="pager">
      <% if @bookings.prev_page %>
        <%= link_to '← Prev', admin_mobile_ui_bookings_path(page: @bookings.prev_page, search: params[:search], status: params[:status]), class: 'page-btn' %>
      <% end %>
      <span class="page-btn active"><%= @bookings.current_page %> / <%= @bookings.total_pages %></span>
      <% if @bookings.next_page %>
        <%= link_to 'Next →', admin_mobile_ui_bookings_path(page: @bookings.next_page, search: params[:search], status: params[:status]), class: 'page-btn' %>
      <% end %>
    </div>
  <% end %>

<% else %>
  <div class="empty-state">
    <i class="bi bi-cart-x"></i>
    <h5 class="text-muted">No Bookings Found</h5>
    <p class="text-muted" style="font-size:0.9rem;">
      <%= params[:search].present? || params[:status].present? ? 'Try clearing your filters.' : 'Tap + to create the first booking.' %>
    </p>
  </div>
<% end %>

<script>
function setStatus(val) {
  showLoader('Loading…', 'Filtering bookings');
  document.getElementById('statusHidden').value = val;
  document.getElementById('mobileSearch').closest('form').submit();
}

// Debounced search
let searchTimer;
document.getElementById('mobileSearch').addEventListener('input', function() {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => this.closest('form').submit(), 500);
});
</script>
