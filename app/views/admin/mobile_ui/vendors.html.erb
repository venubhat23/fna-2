<style>
/* Search & Filter Bar */
.search-bar { background: white; padding: 10px 14px; border-bottom: 1px solid #e9ecef; position: sticky; top: 100px; z-index: 90; }
.search-input {
  border-radius: 20px; border: 2px solid #e9ecef; padding: 8px 16px 8px 38px;
  font-size: 0.9rem; width: 100%; outline: none; transition: border-color 0.2s;
}
.search-input:focus { border-color: #2e7d32; }
.search-wrap { position: relative; }
.search-wrap .bi-search { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 0.9rem; }
.filter-pills { display: flex; gap: 6px; overflow-x: auto; padding: 8px 0 2px; scrollbar-width: none; }
.filter-pills::-webkit-scrollbar { display: none; }
.filter-pill {
  flex-shrink: 0; border-radius: 20px; border: 2px solid #dee2e6; background: white;
  color: #6c757d; font-size: 0.75rem; font-weight: 600; padding: 4px 12px;
  cursor: pointer; white-space: nowrap; text-decoration: none; transition: all 0.15s;
}
.filter-pill.active, .filter-pill:hover { background: #2e7d32; border-color: #2e7d32; color: white; }

/* Summary bar */
.summary-bar { background: linear-gradient(135deg, #2e7d32, #1b5e20); color: white; padding: 10px 16px; font-size: 0.82rem; }

/* Status pill */
.status-pill { font-size: 0.68rem; font-weight: 600; padding: 3px 9px; border-radius: 20px; letter-spacing: 0.2px; display: inline-block; }
.s-completed { background: #d4edda; color: #155724; }
.s-cancelled { background: #f8d7da; color: #721c24; }

/* Empty state */
.empty-state { text-align: center; padding: 60px 24px; color: #aaa; }
.empty-state i { font-size: 3.5rem; display: block; margin-bottom: 12px; }

/* Pagination */
.pager { display: flex; justify-content: center; gap: 8px; padding: 16px; }
.page-btn {
  padding: 8px 18px; border-radius: 20px; border: 2px solid #dee2e6;
  background: white; color: #2e7d32; font-weight: 600; font-size: 0.85rem; text-decoration: none;
}
.page-btn.active { background: #2e7d32; border-color: #2e7d32; color: white; }

.vendor-card {
  background: white;
  border-radius: 14px;
  margin: 8px 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  overflow: hidden;
  border: 1px solid #f0f0f0;
}
.vendor-card-header {
  padding: 12px 14px 8px;
  border-bottom: 1px solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.vendor-name { font-weight: 700; font-size: 0.95rem; color: #1a1a1a; }
.vendor-contact { font-size: 0.78rem; color: #888; margin-top: 2px; }
.vendor-card-body { padding: 10px 14px; display: flex; gap: 10px; }
.vendor-stat { flex: 1; }
.vendor-stat .label { font-size: 0.68rem; color: #999; text-transform: uppercase; letter-spacing: 0.4px; }
.vendor-stat .value { font-size: 0.9rem; font-weight: 700; color: #222; }
.vendor-card-footer {
  background: #fafafa;
  border-top: 1px solid #f0f0f0;
  padding: 10px 14px;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
.vendor-btn {
  border: none;
  border-radius: 10px;
  padding: 7px 12px;
  font-size: 0.78rem;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.vendor-btn-purchase { background: #2e7d32; color: white; }
.vendor-btn-toggle { background: #f0f0f0; color: #555; }
</style>

<%# Search & Filters %>
<div class="search-bar">
  <%= form_with url: admin_mobile_ui_vendors_path, method: :get, local: true, data: { no_loader: '' } do |f| %>
    <div class="search-wrap mb-2">
      <i class="bi bi-search"></i>
      <%= f.text_field :search, value: params[:search], class: 'search-input',
          placeholder: 'Search vendor name…', autocomplete: 'off', id: 'vendorSearch' %>
    </div>
    <%= f.hidden_field :status, value: params[:status], id: 'vendorStatusHidden' %>
    <div class="filter-pills">
      <% [['All', ''], ['Active', 'true'], ['Inactive', 'false']].each do |label, val| %>
        <a href="#" class="filter-pill <%= params[:status].to_s == val ? 'active' : '' %>"
           onclick="setVendorStatus('<%= val %>'); return false;"><%= label %></a>
      <% end %>
    </div>
  <% end %>
</div>

<div class="summary-bar d-flex justify-content-between align-items-center flex-wrap gap-1">
  <span><i class="bi bi-people me-1"></i><strong><%= @active_vendors %></strong>/<%= @total_vendors %> active</span>
  <span style="font-size:0.75rem; opacity:0.9;">Outstanding: ₹<%= number_with_delimiter(@total_outstanding.to_i) %></span>
</div>

<% if @vendors.any? %>
  <% @vendors.each do |vendor| %>
    <div class="vendor-card">
      <div class="vendor-card-header">
        <div>
          <div class="vendor-name"><%= vendor.name %></div>
          <% if vendor.phone.present? %>
            <div class="vendor-contact"><i class="bi bi-telephone-fill me-1"></i><%= vendor.phone %></div>
          <% end %>
        </div>
        <div class="d-flex flex-column align-items-end gap-1">
          <span class="status-pill <%= vendor.status? ? 's-completed' : 's-cancelled' %>"><%= vendor.status_text %></span>
          <span class="status-pill" style="background:#f3e5f5;color:#7b1fa2;"><%= vendor.payment_type %></span>
        </div>
      </div>
      <div class="vendor-card-body">
        <div class="vendor-stat">
          <div class="label">Total Purchases</div>
          <div class="value">₹<%= number_with_delimiter(vendor.total_purchases.to_i) %></div>
        </div>
        <div class="vendor-stat">
          <div class="label">Outstanding</div>
          <div class="value" style="color:<%= vendor.outstanding_balance > 0 ? '#c0392b' : '#1a7f37' %>;">
            ₹<%= number_with_delimiter(vendor.outstanding_balance.to_i) %>
          </div>
        </div>
      </div>
      <div class="vendor-card-footer">
        <%= button_to admin_mobile_ui_toggle_vendor_status_path(vendor, search: params[:search], status: params[:status]),
            method: :patch, class: 'vendor-btn vendor-btn-toggle', form: { style: 'display:inline;' } do %>
          <i class="bi bi-power"></i><%= vendor.status? ? 'Deactivate' : 'Activate' %>
        <% end %>
        <%= link_to admin_mobile_ui_new_vendor_purchase_path(vendor_id: vendor.id), class: 'vendor-btn vendor-btn-purchase' do %>
          <i class="bi bi-cart-plus-fill"></i>New Purchase
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Pagination %>
  <% if @vendors.respond_to?(:total_pages) && @vendors.total_pages > 1 %>
    <div class="pager">
      <% if @vendors.prev_page %>
        <%= link_to '← Prev', admin_mobile_ui_vendors_path(page: @vendors.prev_page, search: params[:search], status: params[:status]), class: 'page-btn' %>
      <% end %>
      <span class="page-btn active"><%= @vendors.current_page %> / <%= @vendors.total_pages %></span>
      <% if @vendors.next_page %>
        <%= link_to 'Next →', admin_mobile_ui_vendors_path(page: @vendors.next_page, search: params[:search], status: params[:status]), class: 'page-btn' %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="empty-state">
    <i class="bi bi-people"></i>
    <h5 class="text-muted">No Vendors Found</h5>
    <p class="text-muted" style="font-size:0.9rem;">
      <%= params[:search].present? || params[:status].present? ? 'Try clearing your filters.' : 'Tap + to add your first vendor.' %>
    </p>
  </div>
<% end %>

<script>
function setVendorStatus(val) {
  showLoader('Loading…', 'Filtering vendors');
  document.getElementById('vendorStatusHidden').value = val;
  document.getElementById('vendorSearch').closest('form').submit();
}

let vendorSearchTimer;
document.getElementById('vendorSearch').addEventListener('input', function() {
  clearTimeout(vendorSearchTimer);
  vendorSearchTimer = setTimeout(() => this.closest('form').submit(), 500);
});
</script>
