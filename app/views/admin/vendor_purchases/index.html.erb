<% content_for :title, "Vendor Purchases" %>

<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-0"><i class="bi bi-cart-fill me-2"></i>Vendor Purchases</h2>
      <p class="text-muted mb-0">Manage your vendor purchase orders and inventory</p>
    </div>
    <div class="btn-group">
      <%= link_to "New Purchase", new_admin_vendor_purchase_path, class: "btn btn-primary" %>
      <%= link_to "Batch Inventory", batch_inventory_admin_vendor_purchases_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <!-- Filters -->
  <div class="card mb-4">
    <div class="card-body">
      <%= form_with url: admin_vendor_purchases_path, method: :get, local: true, class: "row g-3" do |f| %>
        <div class="col-md-3">
          <%= f.text_field :search, value: params[:search], placeholder: "Search by vendor name...", class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= f.select :vendor_id, options_from_collection_for_select(@vendors, :id, :name, params[:vendor_id]),
              { prompt: "All Vendors" }, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.select :status, options_for_select([
            ['All Status', ''],
            ['Pending', 'pending'],
            ['Completed', 'completed'],
            ['Cancelled', 'cancelled']
          ], params[:status]), {}, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Filter", class: "btn btn-outline-primary" %>
        </div>
        <div class="col-md-2 text-end">
          <%= link_to "Clear", admin_vendor_purchases_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card border-primary">
        <div class="card-body text-center">
          <div class="h4 mb-1 text-primary"><%= @stats[:total_count] %></div>
          <div class="text-muted">Total Purchases</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-warning">
        <div class="card-body text-center">
          <div class="h4 mb-1 text-warning"><%= @stats[:pending_count] %></div>
          <div class="text-muted">Pending Orders</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-success">
        <div class="card-body text-center">
          <div class="h4 mb-1 text-success">₹<%= number_with_delimiter(@stats[:total_value].to_i) %></div>
          <div class="text-muted">Total Value</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-info">
        <div class="card-body text-center">
          <div class="h4 mb-1 text-info">₹<%= number_with_delimiter(@stats[:outstanding_value].to_i) %></div>
          <div class="text-muted">Outstanding</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bulk Actions -->
  <div class="card mb-3" id="bulk-actions" style="display: none;">
    <div class="card-body py-2">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span id="selected-count">0</span> purchases selected
        </div>
        <div>
          <button type="button" class="btn btn-success btn-sm" onclick="bulkMarkAsPaid()">
            <i class="bi bi-check-circle me-1"></i>
            Mark as Paid
          </button>
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearSelection()">
            <i class="bi bi-x me-1"></i>
            Clear Selection
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Vendor Purchases Table -->
  <div class="card">
    <div class="card-body">
      <% if @vendor_purchases.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle vp-table">
            <thead>
              <tr>
                <th width="40">
                  <input type="checkbox" id="select-all" class="form-check-input" title="Select All">
                </th>
                <th>Vendor</th>
                <th>Purchase Date</th>
                <th>Items</th>
                <th>Amount</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @vendor_purchases.each do |purchase| %>
                <tr>
                  <td>
                    <% if purchase.payment_status != 'paid' %>
                      <input type="checkbox" class="form-check-input purchase-checkbox" value="<%= purchase.id %>" data-purchase-id="<%= purchase.id %>">
                    <% end %>
                  </td>
                  <td>
                    <div class="fw-bold"><%= purchase.vendor.name %></div>
                    <div class="small text-muted"><%= purchase.vendor.phone.presence || purchase.purchase_number %></div>
                  </td>
                  <td>
                    <div><%= purchase.purchase_date.strftime('%b %d, %Y') %></div>
                    <div class="small text-muted"><%= time_ago_in_words(purchase.purchase_date) %> ago</div>
                  </td>
                  <td>
                    <div class="fw-bold"><%= purchase.vendor_purchase_items.size %> items</div>
                    <div class="small text-muted">
                      <%= purchase.vendor_purchase_items.sum(&:quantity) %> units
                    </div>
                  </td>
                  <td>
                    <div class="vp-amount-breakdown">
                      <div class="fw-bold">₹<%= number_with_delimiter(purchase.total_amount.to_i) %></div>
                      <div class="small">
                        <span class="text-success">Paid ₹<%= number_with_delimiter(purchase.paid_amount.to_i) %></span>
                        <% if purchase.outstanding_amount > 0 %>
                          <span class="text-danger">&middot; Due ₹<%= number_with_delimiter(purchase.outstanding_amount.to_i) %></span>
                        <% end %>
                      </div>
                      <div class="progress vp-amount-progress" title="<%= number_with_precision((purchase.paid_amount / purchase.total_amount * 100), precision: 0) rescue 0 %>% paid">
                        <div class="progress-bar bg-success" style="width: <%= purchase.total_amount.to_f > 0 ? [(purchase.paid_amount.to_f / purchase.total_amount.to_f * 100), 100].min : 0 %>%"></div>
                      </div>
                    </div>
                  </td>
                  <td class="text-center">
                    <div class="d-flex flex-column gap-1 align-items-center">
                      <span class="badge <%= purchase.status_badge_class %> px-2 py-1">
                        <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                        <%= purchase.status.titleize %>
                      </span>
                      <span class="badge <%= purchase.payment_status_badge_class %> px-2 py-1">
                        <i class="bi bi-wallet2 me-1" style="font-size: 0.7rem;"></i>
                        <%= purchase.payment_status.titleize %>
                      </span>
                    </div>
                  </td>
                  <td>
                    <div class="d-flex justify-content-end align-items-center gap-1">
                      <%= link_to admin_vendor_purchase_path(purchase), class: "btn btn-primary btn-sm", title: "View Details" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>

                      <% if purchase.can_be_edited? %>
                        <%= link_to edit_admin_vendor_purchase_path(purchase), class: "btn btn-warning btn-sm", title: "Edit" do %>
                          <i class="bi bi-pencil"></i>
                        <% end %>
                      <% end %>

                      <div class="dropdown">
                        <button class="btn btn-light btn-sm border" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="More actions">
                          <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                          <% if purchase.invoice_generated? %>
                            <li>
                              <%= link_to show_invoice_admin_vendor_purchase_path(purchase), class: "dropdown-item", target: "_blank" do %>
                                <i class="bi bi-receipt-cutoff me-2 text-success"></i>Show Invoice
                              <% end %>
                            </li>
                          <% else %>
                            <li>
                              <a class="dropdown-item" href="#" onclick="generateVendorInvoice(<%= purchase.id %>); return false;">
                                <i class="bi bi-receipt me-2 text-info"></i>Generate Invoice
                              </a>
                            </li>
                          <% end %>
                          <li>
                            <a class="dropdown-item" href="#" onclick="shareVendorInvoiceOnWhatsApp(<%= purchase.id %>); return false;">
                              <i class="bi bi-whatsapp me-2 text-success"></i>Share on WhatsApp
                            </a>
                          </li>
                          <% if purchase.payment_status != 'paid' %>
                            <li>
                              <%= link_to mark_as_paid_admin_vendor_purchase_path(purchase),
                                  data: {
                                    turbo_method: :patch,
                                    turbo_confirm: "Mark this purchase as fully paid?"
                                  },
                                  class: "dropdown-item" do %>
                                <i class="bi bi-check2-circle me-2 text-primary"></i>Mark as Paid
                              <% end %>
                            </li>
                          <% end %>
                          <% if purchase.status == 'pending' %>
                            <li>
                              <%= link_to complete_purchase_admin_vendor_purchase_path(purchase),
                                  data: {
                                    turbo_method: :patch,
                                    turbo_confirm: "Mark this purchase as completed?"
                                  },
                                  class: "dropdown-item" do %>
                                <i class="bi bi-check-circle me-2 text-success"></i>Complete Purchase
                              <% end %>
                            </li>
                          <% end %>
                          <% if purchase.can_be_cancelled? %>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                              <%= link_to admin_vendor_purchase_path(purchase),
                                  data: {
                                    turbo_method: :delete,
                                    turbo_confirm: "Are you sure you want to delete this purchase?"
                                  },
                                  class: "dropdown-item text-danger" do %>
                                <i class="bi bi-trash me-2"></i>Delete
                              <% end %>
                            </li>
                          <% end %>
                        </ul>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-3">
          <div class="text-muted">
            <% if @vendor_purchases.respond_to?(:total_count) %>
              Showing <%= @vendor_purchases.offset_value + 1 %> to <%= [@vendor_purchases.offset_value + @vendor_purchases.limit_value, @vendor_purchases.total_count].min %> of <%= @vendor_purchases.total_count %> purchases
            <% else %>
              Showing <%= @vendor_purchases.count %> purchases
            <% end %>
          </div>
          <%= paginate @vendor_purchases if defined?(Kaminari) && @vendor_purchases.respond_to?(:current_page) %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-cart-x display-1 text-muted"></i>
          <h4 class="mt-3">No Vendor Purchases Found</h4>
          <p class="text-muted">
            <% if params[:search].present? || params[:vendor_id].present? || params[:status].present? %>
              Try adjusting your search filters.
            <% else %>
              Start by creating your first vendor purchase order.
            <% end %>
          </p>
          <%= link_to "New Purchase", new_admin_vendor_purchase_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
.vp-table thead th {
  background: linear-gradient(135deg, #1e3a5f 0%, #274a72 100%);
  color: #fff;
  font-weight: 600;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border: none;
  vertical-align: middle;
  padding-top: 0.85rem;
  padding-bottom: 0.85rem;
}

.vp-table tbody tr {
  border-bottom: 1px solid #edf0f3;
}

.vp-table tbody tr:hover {
  background-color: #f6f9fc;
}

.vp-table tbody td {
  padding-top: 0.9rem;
  padding-bottom: 0.9rem;
}

.vp-amount-breakdown .vp-amount-progress {
  height: 4px;
  margin-top: 0.35rem;
  width: 100%;
  background-color: #e9ecef;
}

.vp-table .btn-sm i {
  font-size: 0.85rem;
}

.vp-table .dropdown-item i {
  width: 1.1rem;
}
</style>

<script>
function generateVendorInvoice(purchaseId) {
  // Show loading state
  const button = event.target.closest('button');
  const originalContent = button.innerHTML;
  button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
  button.disabled = true;

  fetch(`/admin/vendor_purchases/${purchaseId}/generate_invoice`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      // Show success message
      showNotification('Invoice generated successfully!', 'success');

      // Open the public invoice in a new tab
      if (data.invoice_url) {
        window.open(data.invoice_url, '_blank');
      }

      // Reload the page to update the button
      setTimeout(() => {
        window.location.reload();
      }, 1000);
    } else {
      showNotification('Error generating invoice: ' + (data.error || 'Unknown error'), 'error');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    showNotification('Error generating invoice. Please try again.', 'error');
  })
  .finally(() => {
    // Restore button state
    button.innerHTML = originalContent;
    button.disabled = false;
  });
}

function shareVendorInvoiceOnWhatsApp(purchaseId) {
  // First generate/get the invoice URL
  const button = event.target.closest('button');
  const originalContent = button.innerHTML;
  button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
  button.disabled = true;

  fetch(`/admin/vendor_purchases/${purchaseId}/generate_invoice`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success && data.invoice_url) {
      // Create WhatsApp message
      const message = `Hi! Here is your invoice for purchase #${data.purchase_number}:\n${data.invoice_url}`;
      const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(message)}`;

      // Open WhatsApp
      window.open(whatsappUrl, '_blank');

      showNotification('WhatsApp opened with invoice link!', 'success');
    } else {
      showNotification('Error getting invoice link: ' + (data.error || 'Unknown error'), 'error');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    showNotification('Error sharing invoice. Please try again.', 'error');
  })
  .finally(() => {
    // Restore button state
    button.innerHTML = originalContent;
    button.disabled = false;
  });
}

function showNotification(message, type = 'info') {
  // Create notification element
  const notification = document.createElement('div');
  notification.className = `alert alert-${type === 'error' ? 'danger' : type === 'success' ? 'success' : 'info'} alert-dismissible fade show position-fixed`;
  notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
  notification.innerHTML = `
    ${message}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  `;

  // Add to page
  document.body.appendChild(notification);

  // Auto-remove after 5 seconds
  setTimeout(() => {
    if (notification.parentNode) {
      notification.parentNode.removeChild(notification);
    }
  }, 5000);
}

// Bulk selection functionality
document.addEventListener('DOMContentLoaded', function() {
  const selectAllCheckbox = document.getElementById('select-all');
  const purchaseCheckboxes = document.querySelectorAll('.purchase-checkbox');
  const bulkActionsCard = document.getElementById('bulk-actions');
  const selectedCountSpan = document.getElementById('selected-count');

  // Select/Deselect all functionality
  if (selectAllCheckbox) {
    selectAllCheckbox.addEventListener('change', function() {
      purchaseCheckboxes.forEach(checkbox => {
        checkbox.checked = this.checked;
      });
      updateBulkActionsVisibility();
    });
  }

  // Individual checkbox change
  purchaseCheckboxes.forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      updateSelectAllState();
      updateBulkActionsVisibility();
    });
  });

  function updateSelectAllState() {
    const checkedBoxes = document.querySelectorAll('.purchase-checkbox:checked');
    const totalBoxes = purchaseCheckboxes.length;

    if (selectAllCheckbox) {
      if (checkedBoxes.length === 0) {
        selectAllCheckbox.indeterminate = false;
        selectAllCheckbox.checked = false;
      } else if (checkedBoxes.length === totalBoxes) {
        selectAllCheckbox.indeterminate = false;
        selectAllCheckbox.checked = true;
      } else {
        selectAllCheckbox.indeterminate = true;
        selectAllCheckbox.checked = false;
      }
    }
  }

  function updateBulkActionsVisibility() {
    const checkedBoxes = document.querySelectorAll('.purchase-checkbox:checked');

    if (checkedBoxes.length > 0) {
      bulkActionsCard.style.display = 'block';
      selectedCountSpan.textContent = checkedBoxes.length;
    } else {
      bulkActionsCard.style.display = 'none';
    }
  }
});

function bulkMarkAsPaid() {
  const selectedPurchases = Array.from(document.querySelectorAll('.purchase-checkbox:checked')).map(cb => cb.value);

  if (selectedPurchases.length === 0) {
    showNotification('Please select purchases to mark as paid', 'error');
    return;
  }

  if (!confirm(`Are you sure you want to mark ${selectedPurchases.length} purchase(s) as paid?`)) {
    return;
  }

  // Disable button and show loading
  const button = event.target;
  const originalContent = button.innerHTML;
  button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Processing...';
  button.disabled = true;

  fetch('/admin/vendor_purchases/bulk_mark_as_paid', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    },
    body: JSON.stringify({
      purchase_ids: selectedPurchases
    })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      showNotification(data.message || `Successfully marked ${data.updated_count} purchases as paid`, 'success');
      // Reload the page to show updated statuses
      setTimeout(() => {
        window.location.reload();
      }, 1500);
    } else {
      showNotification('Error: ' + (data.error || 'Unknown error occurred'), 'error');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    showNotification('Error marking purchases as paid. Please try again.', 'error');
  })
  .finally(() => {
    // Restore button state
    button.innerHTML = originalContent;
    button.disabled = false;
  });
}

function clearSelection() {
  document.querySelectorAll('.purchase-checkbox:checked').forEach(checkbox => {
    checkbox.checked = false;
  });
  document.getElementById('select-all').checked = false;
  document.getElementById('select-all').indeterminate = false;
  document.getElementById('bulk-actions').style.display = 'none';
}
</script>
