<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Customer Order</h2>
    <p class="text-muted mb-0">Assign and manage row numbers for each customer</p>
  </div>
  <div class="d-flex gap-2">
    <button type="button" class="btn btn-success" id="saveAllBtn">
      <i class="bi bi-check-all me-1"></i>Save All Row Numbers
    </button>
  </div>
</div>

<!-- Search / Filter Bar -->
<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2">
    <div class="row g-2 align-items-center">
      <div class="col-md-5">
        <div class="input-group input-group-sm">
          <span class="input-group-text border-end-0 bg-white">
            <i class="bi bi-search text-muted"></i>
          </span>
          <input type="text" id="coSearch" class="form-control border-start-0"
                 placeholder="Search by name, ID or contact...">
        </div>
      </div>
      <div class="col-md-3">
        <select id="rowFilter" class="form-select form-select-sm">
          <option value="">All Customers</option>
          <option value="assigned">Row Number Assigned</option>
          <option value="unassigned">Row Number Not Assigned</option>
        </select>
      </div>
    </div>
  </div>
</div>

<!-- Customers Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0" id="coTable">
        <thead class="table-light">
          <tr>
            <th class="border-0 fw-semibold" style="width:60px">#</th>
            <th class="border-0 fw-semibold">Customer Name</th>
            <th class="border-0 fw-semibold">Customer ID</th>
            <th class="border-0 fw-semibold">Contact Number</th>
            <th class="border-0 fw-semibold" style="width:160px">Row Number</th>
            <th class="border-0 fw-semibold" style="width:120px">Actions</th>
          </tr>
        </thead>
        <tbody id="coTableBody">
          <% row_counter = 0 %>
          <% @delivery_groups.each do |delivery_person, customers| %>
            <% next if customers.empty? %>
            <tr class="table-light">
              <td colspan="6" class="fw-semibold py-2">
                <% if delivery_person %>
                  <i class="bi bi-truck text-primary me-1"></i><%= delivery_person.full_name %>
                  <span class="text-muted fw-normal">(<%= customers.size %> customer<%= 's' if customers.size != 1 %>)</span>
                <% else %>
                  <i class="bi bi-exclamation-circle text-muted me-1"></i>Unassigned
                  <span class="text-muted fw-normal">(<%= customers.size %> customer<%= 's' if customers.size != 1 %>)</span>
                <% end %>
              </td>
            </tr>
            <% customers.each do |customer| %>
              <% row_counter += 1 %>
              <tr data-customer-id="<%= customer.id %>"
                  data-row-number="<%= customer.row_number.to_s %>"
                  data-name="<%= customer.display_name.downcase %>"
                  data-mobile="<%= customer.mobile.to_s.downcase %>">
                <td class="align-middle text-muted"><%= row_counter %></td>
                <td class="align-middle">
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center me-2" style="width:34px;height:34px;min-width:34px;">
                      <i class="bi bi-person text-primary small"></i>
                    </div>
                    <div>
                      <div class="fw-semibold"><%= customer.display_name %></div>
                    </div>
                  </div>
                </td>
                <td class="align-middle">
                  <span class="badge bg-primary-subtle text-primary">#<%= customer.id %></span>
                </td>
                <td class="align-middle">
                  <% if customer.mobile.present? %>
                    <i class="bi bi-telephone text-muted me-1"></i><%= customer.mobile %>
                  <% else %>
                    <span class="text-muted small">—</span>
                  <% end %>
                </td>
                <td class="align-middle">
                  <input type="number" min="1"
                         class="form-control form-control-sm row-number-input"
                         value="<%= customer.row_number %>"
                         placeholder="Enter number"
                         data-original="<%= customer.row_number.to_s %>"
                         style="width:120px">
                </td>
                <td class="align-middle">
                  <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-primary save-btn" title="Save row number">
                      <i class="bi bi-check-lg"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger clear-btn" title="Clear row number">
                      <i class="bi bi-x-lg"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @customers.empty? %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-people fs-1 d-block mb-3"></i>
        <p>No customers found.</p>
      </div>
    <% end %>
  </div>
</div>

<script>
const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

// Search + filter
document.getElementById('coSearch').addEventListener('input', filterTable);
document.getElementById('rowFilter').addEventListener('change', filterTable);

function filterTable() {
  const term = document.getElementById('coSearch').value.toLowerCase();
  const filter = document.getElementById('rowFilter').value;
  document.querySelectorAll('#coTableBody tr').forEach(function(row) {
    const name = row.dataset.name || '';
    const mobile = row.dataset.mobile || '';
    const id = row.dataset.customerId || '';
    const rowNum = row.dataset.rowNumber;

    const matchSearch = !term || name.includes(term) || mobile.includes(term) || id.includes(term);
    const matchFilter = !filter ||
      (filter === 'assigned' && rowNum && rowNum !== '') ||
      (filter === 'unassigned' && (!rowNum || rowNum === ''));

    row.style.display = matchSearch && matchFilter ? '' : 'none';
  });
}

// Single save
document.querySelectorAll('.save-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const row = btn.closest('tr');
    const customerId = row.dataset.customerId;
    const input = row.querySelector('.row-number-input');
    const rowNumber = input.value.trim();

    saveRowNumber(customerId, rowNumber, function(success) {
      if (success) {
        input.dataset.original = rowNumber;
        row.dataset.rowNumber = rowNumber;
        showToast('Row number saved!', 'success');
      }
    });
  });
});

// Clear row number
document.querySelectorAll('.clear-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const row = btn.closest('tr');
    const customerId = row.dataset.customerId;
    const customerName = row.querySelector('.fw-semibold')?.textContent?.trim();
    const input = row.querySelector('.row-number-input');

    Swal.fire({
      title: 'Clear Row Number?',
      text: `Remove row number for ${customerName}?`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#dc3545',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Yes, Clear',
      cancelButtonText: 'Cancel',
      buttonsStyling: false,
      customClass: { confirmButton: 'btn btn-danger me-2', cancelButton: 'btn btn-secondary' }
    }).then(function(result) {
      if (result.isConfirmed) {
        fetch(`/admin/customer_orders/${customerId}/clear_row_number`, {
          method: 'DELETE',
          headers: { 'X-CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' }
        }).then(r => r.json()).then(function(data) {
          if (data.success) {
            input.value = '';
            input.dataset.original = '';
            row.dataset.rowNumber = '';
            showToast('Row number cleared!', 'success');
          } else {
            showToast(data.message || 'Error clearing row number.', 'error');
          }
        });
      }
    });
  });
});

// Bulk save
document.getElementById('saveAllBtn').addEventListener('click', function() {
  const rows = document.querySelectorAll('#coTableBody tr');
  const updates = [];
  rows.forEach(function(row) {
    const input = row.querySelector('.row-number-input');
    if (!input) return;
    const val = input.value.trim();
    if (val !== input.dataset.original) {
      updates.push({ id: row.dataset.customerId, row_number: val });
    }
  });

  if (updates.length === 0) {
    showToast('No changes to save.', 'info');
    return;
  }

  fetch('/admin/customer_orders/bulk_update', {
    method: 'POST',
    headers: { 'X-CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ customers: updates })
  }).then(r => r.json()).then(function(data) {
    if (data.success) {
      rows.forEach(function(row) {
        const input = row.querySelector('.row-number-input');
        if (!input) return;
        input.dataset.original = input.value.trim();
        row.dataset.rowNumber = input.value.trim();
      });
      showToast(`${updates.length} row number(s) updated!`, 'success');
    } else {
      showToast(data.message || 'Bulk update failed.', 'error');
    }
  });
});

function saveRowNumber(customerId, rowNumber, callback) {
  fetch(`/admin/customer_orders/${customerId}`, {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ row_number: rowNumber })
  }).then(r => r.json()).then(function(data) {
    callback(data.success);
    if (!data.success) showToast(data.message || 'Save failed.', 'error');
  });
}

function showToast(message, type) {
  const iconMap = { success: 'success', error: 'error', info: 'info' };
  Swal.fire({
    toast: true, position: 'top-end', showConfirmButton: false,
    timer: 2500, timerProgressBar: true,
    icon: iconMap[type] || 'info', title: message
  });
}
</script>

<style>
.row-number-input::-webkit-inner-spin-button,
.row-number-input::-webkit-outer-spin-button { opacity: 1; }
.row-number-input:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.15rem rgba(13,110,253,.15); }
</style>
