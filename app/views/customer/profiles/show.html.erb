<% content_for :title, "My Profile - Atma Nirbhar Farm" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">My Profile</h2>
    <p class="text-muted mb-0">Manage your personal information and preferences</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_customer_profile_path, class: "btn btn-primary" do %>
      <i class="bi bi-pencil-square me-2"></i>Edit Profile
    <% end %>
  </div>
</div>

<!-- Profile Summary Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-auto">
        <div class="avatar-lg bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center">
          <i class="bi bi-person fs-1 text-primary"></i>
        </div>
      </div>
      <div class="col">
        <h4 class="mb-1"><%= @customer.display_name %></h4>
        <div class="text-muted">
          <div class="d-flex flex-wrap gap-3">
            <span><i class="bi bi-envelope me-2"></i><%= @customer.email %></span>
            <span><i class="bi bi-telephone me-2"></i><%= @customer.mobile.present? ? @customer.mobile : 'Not provided' %></span>
          </div>
        </div>
      </div>
      <div class="col-auto">
        <%= link_to customer_orders_path, class: "btn btn-outline-primary me-2" do %>
          <i class="bi bi-bag me-1"></i>My Orders
        <% end %>
        <%= link_to customer_addresses_path, class: "btn btn-outline-secondary" do %>
          <i class="bi bi-geo-alt me-1"></i>Addresses
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Information Cards -->
<div class="row mb-4">
  <div class="col-lg-6 mb-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-person me-2 text-primary"></i>
          Personal Information
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">First Name</label>
            <div class="fw-medium"><%= @customer.first_name.present? ? @customer.first_name : 'Not provided' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Middle Name</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.middle_name.present? %>">
              <%= @customer.middle_name.present? ? @customer.middle_name : 'Not provided' %>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Last Name</label>
            <div class="fw-medium"><%= @customer.last_name.present? ? @customer.last_name : 'Not provided' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Birth Date</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.birth_date.present? %>">
              <%= @customer.birth_date.present? ? @customer.birth_date.strftime("%B %d, %Y") : 'Not provided' %>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Gender</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.gender.present? %>">
              <%= @customer.gender.present? ? @customer.gender.humanize : 'Not provided' %>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Marital Status</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.marital_status.present? %>">
              <%= @customer.marital_status.present? ? @customer.marital_status.humanize : 'Not provided' %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-6 mb-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-telephone me-2 text-success"></i>
          Contact Information
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-semibold text-muted">Email Address</label>
            <div class="fw-medium"><%= @customer.email %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">Mobile Number</label>
            <div class="fw-medium"><%= @customer.mobile.present? ? @customer.mobile : 'Not provided' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold text-muted">WhatsApp Number</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.whatsapp_number.present? %>">
              <%= @customer.whatsapp_number.present? ? @customer.whatsapp_number : 'Not provided' %>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold text-muted">Address</label>
            <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.address.present? %>">
              <%= @customer.address.present? ? @customer.address : 'Not provided' %>
            </div>
          </div>
          <% if @customer.customer_addresses.any? %>
            <% default_address = @customer.customer_addresses.find(&:is_default?) || @customer.customer_addresses.first %>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">City</label>
              <div class="fw-medium <%= 'text-muted fst-italic' unless default_address.city.present? %>">
                <%= default_address.city.present? ? default_address.city : 'Not provided' %>
              </div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">State</label>
              <div class="fw-medium <%= 'text-muted fst-italic' unless default_address.state.present? %>">
                <%= default_address.state.present? ? default_address.state : 'Not provided' %>
              </div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">PIN Code</label>
              <div class="fw-medium <%= 'text-muted fst-italic' unless default_address.pincode.present? %>">
                <%= default_address.pincode.present? ? default_address.pincode : 'Not provided' %>
              </div>
            </div>
          <% else %>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">City</label>
              <div class="fw-medium text-muted fst-italic">Not provided</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">State</label>
              <div class="fw-medium text-muted fst-italic">Not provided</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold text-muted">PIN Code</label>
              <div class="fw-medium text-muted fst-italic">Not provided</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Additional Information Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <h5 class="mb-0">
      <i class="bi bi-info-circle me-2 text-info"></i>
      Additional Information
    </h5>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">Company Name</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.company_name.present? %>">
          <%= @customer.company_name.present? ? @customer.company_name : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">Occupation</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.occupation.present? %>">
          <%= @customer.occupation.present? ? @customer.occupation : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">Annual Income</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.annual_income.present? %>">
          <%= @customer.annual_income.present? ? "₹#{@customer.annual_income}" : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">PAN Number</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.pan_no.present? %>">
          <%= @customer.pan_no.present? ? @customer.pan_no : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">GST Number</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.gst_no.present? %>">
          <%= @customer.gst_no.present? ? @customer.gst_no : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold text-muted">Country</label>
        <div class="fw-medium">India</div>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold text-muted">Emergency Contact</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.emergency_contact_name.present? %>">
          <%= @customer.emergency_contact_name.present? ? @customer.emergency_contact_name : 'Not provided' %>
        </div>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold text-muted">Emergency Mobile</label>
        <div class="fw-medium <%= 'text-muted fst-italic' unless @customer.emergency_contact_number.present? %>">
          <%= @customer.emergency_contact_number.present? ? @customer.emergency_contact_number : 'Not provided' %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Avatar styling matching myorders */
.avatar-lg {
  width: 4rem;
  height: 4rem;
}

/* Enhanced card styling similar to myorders */
.card {
  transition: all 0.2s ease-in-out;
}

.card:hover {
  transform: translateY(-2px);
}

/* Form styling consistency */
.form-label {
  font-size: 0.875rem;
  margin-bottom: 0.25rem;
}

.fw-medium {
  font-weight: 500 !important;
}

/* Button styling to match myorders */
.btn-outline-primary:hover {
  background-color: #0d6efd;
  border-color: #0d6efd;
  color: white;
}

.btn-outline-secondary:hover {
  background-color: #6c757d;
  border-color: #6c757d;
  color: white;
}

/* Enhanced spacing and typography */
.card-header h5 {
  font-weight: 600;
}

.text-muted.fst-italic {
  font-style: italic;
  opacity: 0.7;
}
</style>