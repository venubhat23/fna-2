<% content_for :title, "My Orders - Atma Nirbhar Farm" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">My Orders</h2>
    <p class="text-muted mb-0">Track and manage all your purchases</p>
  </div>
  <div class="d-flex gap-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Orders</h6>
            <h5 class="mb-0"><%= @bookings_for_stats.count %></h5>
          </div>
          <div class="text-primary">
            <i class="bi bi-bag fs-3"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Pending</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.ordered_and_delivery_pending.count %></h4>
          </div>
          <div class="text-warning">
            <i class="bi bi-clock fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Processing</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.where(status: [:confirmed, :processing, :packed]).count %></h4>
          </div>
          <div class="text-info">
            <i class="bi bi-arrow-clockwise fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Shipped</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.where(status: [:shipped, :out_for_delivery]).count %></h4>
          </div>
          <div class="text-primary">
            <i class="bi bi-truck fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Completed</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.where(status: :completed).count %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-check-circle fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Issues</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.where(status: [:cancelled, :returned]).count %></h4>
          </div>
          <div class="text-danger">
            <i class="bi bi-x-circle fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total</h6>
            <h4 class="mb-0"><%= @bookings_for_stats.count %></h4>
          </div>
          <div class="text-secondary">
            <i class="bi bi-list-ul fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Controls -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: customer_orders_path, method: :get, local: true, class: "row g-3" do |f| %>
      <div class="col-md-4">
        <label for="search" class="form-label fw-semibold">
          <i class="bi bi-search me-1 text-primary"></i>
          Search Orders
        </label>
        <%= f.text_field :search,
            placeholder: "Search by order number, date, or status...",
            value: params[:search],
            class: "form-control",
            id: "search" %>
      </div>
      <div class="col-md-3">
        <label for="status" class="form-label fw-semibold">
          <i class="bi bi-funnel me-1 text-success"></i>
          Order Status
        </label>
        <%= f.select :status,
            options_for_select([
              ['All Statuses', ''],
              ['Pending', 'ordered_and_delivery_pending'],
              ['Confirmed', 'confirmed'],
              ['Processing', 'processing'],
              ['Packed', 'packed'],
              ['Shipped', 'shipped'],
              ['Out for Delivery', 'out_for_delivery'],
              ['Delivered', 'delivered'],
              ['Completed', 'completed'],
              ['Cancelled', 'cancelled'],
              ['Returned', 'returned']
            ], params[:status]),
            { include_blank: false },
            { class: "form-select", id: "status" } %>
      </div>
      <div class="col-md-3">
        <label for="date_from" class="form-label fw-semibold">
          <i class="bi bi-calendar me-1 text-info"></i>
          From Date
        </label>
        <%= f.date_field :date_from,
            placeholder: "From Date",
            value: params[:date_from],
            class: "form-control",
            id: "date_from" %>
      </div>
      <div class="col-md-2">
        <label class="form-label" style="opacity: 0;">Actions</label>
        <div class="d-grid gap-2">
          <%= f.submit "Filter", class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "Clear", customer_orders_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Orders Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Order History</h5>
      <div class="d-flex gap-2">
        <div class="position-relative">
          <input type="text" class="form-control" placeholder="Search in table..." id="searchInput">
          <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <% if @bookings.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 fw-semibold">Order</th>
              <th class="border-0 fw-semibold">Date</th>
              <th class="border-0 fw-semibold">Status</th>
              <th class="border-0 fw-semibold">Items</th>
              <th class="border-0 fw-semibold">Total</th>
              <th class="border-0 fw-semibold">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @bookings.each do |booking| %>
              <tr>
                <td class="align-middle">
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-bag text-primary"></i>
                    </div>
                    <div>
                      <h6 class="mb-0">#<%= booking.booking_number %></h6>
                      <small class="text-muted">
                        <% if booking.invoice_number.present? %>
                          Invoice: <%= booking.invoice_number %>
                        <% else %>
                          No invoice generated
                        <% end %>
                      </small>
                    </div>
                  </div>
                </td>
                <td class="align-middle">
                  <div>
                    <div class="fw-semibold"><%= booking.booking_date.strftime("%d %b %Y") %></div>
                    <small class="text-muted"><%= booking.booking_date.strftime("%I:%M %p") %></small>
                  </div>
                </td>
                <td class="align-middle">
                  <% case booking.status.to_s %>
                  <% when 'confirmed', 'processing', 'packed' %>
                    <span class="badge bg-info-subtle text-info">
                      <i class="bi bi-arrow-clockwise me-1"></i>
                      <%= booking.status.humanize %>
                    </span>
                  <% when 'shipped', 'out_for_delivery' %>
                    <span class="badge bg-warning-subtle text-warning">
                      <i class="bi bi-truck me-1"></i>
                      <%= booking.status.humanize %>
                    </span>
                  <% when 'completed', 'delivered' %>
                    <span class="badge bg-success-subtle text-success">
                      <i class="bi bi-check-circle me-1"></i>
                      <%= booking.status.humanize %>
                    </span>
                  <% when 'cancelled', 'returned' %>
                    <span class="badge bg-danger-subtle text-danger">
                      <i class="bi bi-x-circle me-1"></i>
                      <%= booking.status.humanize %>
                    </span>
                  <% else %>
                    <span class="badge bg-secondary-subtle text-secondary">
                      <i class="bi bi-clock me-1"></i>
                      <%= booking.status.humanize %>
                    </span>
                  <% end %>
                </td>
                <td class="align-middle">
                  <% booking_items = booking.booking_items.to_a %>
                  <div>
                    <div class="fw-semibold"><%= booking_items.size %> item<%= 's' if booking_items.size != 1 %></div>
                    <small class="text-muted"><%= booking_items.sum(&:quantity) %> units</small>
                  </div>
                </td>
                <td class="align-middle">
                  <div>
                    <div class="fw-semibold">₹<%= booking.total_amount.to_f %></div>
                    <small>
                      <span class="badge <%= booking.payment_status == 'paid' ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning' %>">
                        <%= booking.payment_status&.humanize || 'Unpaid' %>
                      </span>
                    </small>
                  </div>
                </td>
                <td class="align-middle">
                  <div class="d-flex gap-1">
                    <%= link_to customer_order_path(booking),
                        class: "btn btn-sm btn-outline-info",
                        title: "View Details" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <% if booking.invoice_generated? %>
                      <%= link_to invoice_customer_order_path(booking),
                          class: "btn btn-sm btn-outline-danger",
                          title: "Download Invoice",
                          target: "_blank" do %>
                        <i class="bi bi-file-earmark-pdf"></i>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if respond_to?(:paginate) && @bookings.respond_to?(:total_pages) && @bookings.total_pages > 1 %>
        <div class="card-footer bg-transparent border-0">
          <%= paginate @bookings %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <div class="mb-3">
          <i class="bi bi-bag fs-1 text-muted"></i>
        </div>
        <h5 class="text-muted mb-3">No Orders Found</h5>
        <p class="text-muted mb-4">You haven't placed any orders yet. Start shopping to see your orders here!</p>
        <%= link_to "Start Shopping", customer_shop_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Search functionality in table
  const searchInput = document.getElementById('searchInput');
  const tableRows = document.querySelectorAll('tbody tr');

  searchInput?.addEventListener('input', function() {
    const searchTerm = this.value.toLowerCase();

    tableRows.forEach(row => {
      const orderText = row.cells[0]?.textContent.toLowerCase() || '';
      const dateText = row.cells[1]?.textContent.toLowerCase() || '';
      const statusText = row.cells[2]?.textContent.toLowerCase() || '';

      if (orderText.includes(searchTerm) ||
          dateText.includes(searchTerm) ||
          statusText.includes(searchTerm)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });
});
</script>

<style>
/* Avatar styling */
.avatar-sm {
  width: 2.5rem;
  height: 2.5rem;
}

/* Enhanced table styling */
.table td {
  padding: 1rem 0.75rem;
}

.table th {
  padding: 1rem 0.75rem;
  font-size: 0.875rem;
  color: #6c757d;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.025em;
}

/* Badge enhancements */
.badge {
  font-size: 0.75rem;
  font-weight: 500;
  padding: 0.375rem 0.75rem;
}

/* Button styling */
.btn-sm {
  padding: 0.375rem 0.75rem;
  font-size: 0.875rem;
}

.btn-outline-info:hover {
  background-color: #0dcaf0;
  border-color: #0dcaf0;
  color: white;
}

.btn-outline-danger:hover {
  background-color: #dc3545;
  border-color: #dc3545;
  color: white;
}

/* Form styling */
.form-control:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.form-select:focus {
  border-color: #198754;
  box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
}
</style>