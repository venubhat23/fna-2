<div class="container-fluid px-4">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="mb-0">
            <i class="fas fa-headset me-2"></i>
            Submit Support Request
          </h4>
          <%= link_to "Back to Requests", customer_client_requests_path, class: "btn btn-outline-secondary" %>
        </div>

        <div class="card-body">
          <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Please provide as much detail as possible so our support team can assist you effectively.
          </div>

          <%= form_with(model: [:customer, @client_request], local: true, class: "needs-validation", novalidate: true) do |form| %>
            <% if @client_request.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @client_request.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-8 mb-3">
                <%= form.label :title, class: "form-label required" %>
                <%= form.text_field :title,
                    class: "form-control #{'is-invalid' if @client_request.errors[:title].present?}",
                    placeholder: "Brief description of your issue",
                    required: true %>
                <div class="invalid-feedback">
                  <%= @client_request.errors[:title].first %>
                </div>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :priority, class: "form-label required" %>
                <%= form.select :priority,
                    options_for_select([
                      ['Low - General inquiry', 'low'],
                      ['Medium - Need assistance', 'medium'],
                      ['High - Important issue', 'high'],
                      ['Urgent - Critical problem', 'urgent']
                    ], @client_request.priority),
                    { prompt: "Select Priority" },
                    { class: "form-select #{'is-invalid' if @client_request.errors[:priority].present?}", required: true } %>
                <div class="invalid-feedback">
                  <%= @client_request.errors[:priority].first %>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :department, class: "form-label" %>
              <%= form.select :department,
                  options_for_select([
                    ['Technical Support', 'technical'],
                    ['Customer Service', 'support'],
                    ['Sales Inquiry', 'sales'],
                    ['Billing & Payments', 'billing'],
                    ['Operations', 'operations'],
                    ['Management', 'management']
                  ], @client_request.department),
                  { prompt: "Select Department (Optional)" },
                  { class: "form-select" } %>
            </div>

            <div class="mb-4">
              <%= form.label :description, class: "form-label required" %>
              <%= form.text_area :description,
                  class: "form-control #{'is-invalid' if @client_request.errors[:description].present?}",
                  rows: 8,
                  placeholder: "Please describe your issue in detail. Include any relevant information such as error messages, steps to reproduce the problem, or specific requirements.",
                  required: true %>
              <div class="form-text">
                <small>Minimum 10 characters required. The more details you provide, the better we can help you.</small>
              </div>
              <div class="invalid-feedback">
                <%= @client_request.errors[:description].first %>
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to "Cancel", customer_client_requests_path, class: "btn btn-light" %>
              <%= form.submit "Submit Request", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Bootstrap form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();

// Character counter for description
document.addEventListener('DOMContentLoaded', function() {
  const textarea = document.getElementById('client_request_description');
  if (textarea) {
    const minLength = 10;

    textarea.addEventListener('input', function() {
      const currentLength = this.value.length;
      const formText = this.parentNode.querySelector('.form-text small');

      if (currentLength < minLength) {
        formText.textContent = `${currentLength}/${minLength} characters required (minimum ${minLength - currentLength} more needed)`;
        formText.className = 'text-warning';
      } else {
        formText.textContent = `${currentLength} characters entered. Looking good!`;
        formText.className = 'text-success';
      }
    });
  }
});
</script>