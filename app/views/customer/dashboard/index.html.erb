<% content_for :title, 'Dashboard - Atma Nirbhar Farm' %>
<% content_for :layout_class, 'customer-main-content' %>

<!-- Chart.js for interactive charts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>

<style>
  /* Modern Customer Dashboard - Matching Admin Design Language */
  * {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  }

  .dashboard-container {
    padding: 1.5rem;
    background: #f8fafc;
    min-height: calc(100vh - 80px);
    position: relative;
  }

  .dashboard-content {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Header Section */
  .dashboard-header {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .welcome-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .welcome-content h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.5rem 0;
  }

  .welcome-content p {
    color: #64748b;
    font-size: 1rem;
    margin: 0;
  }

  .dashboard-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  /* KPI Cards - Admin Style */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .kpi-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .kpi-card:hover {
    box-shadow: 0 10px 25px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .kpi-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .kpi-info {
    flex: 1;
  }

  .kpi-label {
    font-size: 0.875rem;
    color: #64748b;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .kpi-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .kpi-change {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .kpi-change.positive {
    color: #059669;
  }

  .kpi-change.neutral {
    color: #64748b;
  }

  .kpi-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: white;
  }

  .kpi-icon.orders { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
  .kpi-icon.cart { background: linear-gradient(135deg, #f59e0b, #d97706); }
  .kpi-icon.subscriptions { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
  .kpi-icon.rewards { background: linear-gradient(135deg, #10b981, #059669); }

  /* Chart Cards - Admin Style */
  .chart-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .chart-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .chart-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
  }

  .chart-subtitle {
    font-size: 0.875rem;
    color: #64748b;
  }

  /* Quick Actions - Admin Style */
  .quick-actions {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none;
    color: #1e293b;
    transition: all 0.2s ease;
    font-weight: 500;
  }

  .action-btn:hover {
    background: #f1f5f9;
    border-color: #cbd5e1;
    color: #1e293b;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .action-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    color: white;
  }

  .btn-primary-custom {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary-custom:hover {
    background: linear-gradient(135deg, #2563eb, #1e40af);
    color: white;
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* Recent Activity Card */
  .activity-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f1f5f9;
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    color: white;
  }

  .activity-content h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0;
  }

  .activity-content p {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
  }

  /* Empty Chart Placeholder */
  .empty-chart-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 200px;
    background: #f8fafc;
    border: 2px dashed #cbd5e1;
    border-radius: 8px;
    text-align: center;
    padding: 1rem;
  }

  .empty-chart-placeholder p {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .dashboard-container {
      padding: 1rem;
    }

    .dashboard-header {
      padding: 1.5rem;
    }

    .welcome-section {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .dashboard-actions {
      width: 100%;
      justify-content: flex-start;
    }

    .kpi-grid {
      grid-template-columns: 1fr;
    }

    .chart-grid {
      grid-template-columns: 1fr;
    }

    .actions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<% if current_customer %>
<div class="dashboard-container">
  <div class="dashboard-content">

    <!-- Dashboard Header -->
    <div class="dashboard-header">
      <div class="welcome-section">
        <div class="welcome-content">
          <h1>Welcome back, <%= current_customer.first_name %>!</h1>
          <p>Here's what's happening with your account today.</p>
        </div>
        <div class="dashboard-actions">
          <%= link_to customer_shop_path, class: "btn-primary-custom" do %>
            <i class="bi bi-shop me-2"></i>Shop Now
          <% end %>
        </div>
      </div>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-content">
          <div class="kpi-info">
            <div class="kpi-label">Recent Orders</div>
            <div class="kpi-value"><%= @recent_orders_count || 0 %></div>
            <div class="kpi-change neutral">
              <i class="bi bi-dash"></i>
              This month
            </div>
          </div>
          <div class="kpi-icon orders">
            <i class="bi bi-box-seam"></i>
          </div>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-content">
          <div class="kpi-info">
            <div class="kpi-label">Cart Items</div>
            <div class="kpi-value"><%= @cart_items_count || 0 %></div>
            <div class="kpi-change <%= @cart_items_count > 0 ? 'positive' : 'neutral' %>">
              <% if @cart_items_count > 0 %>
                <i class="bi bi-arrow-up"></i>
                Ready to checkout
              <% else %>
                <i class="bi bi-dash"></i>
                Cart empty
              <% end %>
            </div>
          </div>
          <div class="kpi-icon cart">
            <i class="bi bi-cart3"></i>
          </div>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-content">
          <div class="kpi-info">
            <div class="kpi-label">Active Subscriptions</div>
            <div class="kpi-value"><%= @active_subscriptions_count || 0 %></div>
            <div class="kpi-change <%= @active_subscriptions_count > 0 ? 'positive' : 'neutral' %>">
              <% if @active_subscriptions_count > 0 %>
                <i class="bi bi-arrow-up"></i>
                Active delivery
              <% else %>
                <i class="bi bi-dash"></i>
                No subscriptions
              <% end %>
            </div>
          </div>
          <div class="kpi-icon subscriptions">
            <i class="bi bi-arrow-repeat"></i>
          </div>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-content">
          <div class="kpi-info">
            <div class="kpi-label">Reward Points</div>
            <div class="kpi-value">250</div>
            <div class="kpi-change positive">
              <i class="bi bi-arrow-up"></i>
              +50 this month
            </div>
          </div>
          <div class="kpi-icon rewards">
            <i class="bi bi-star"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
      <h3 class="section-title">Quick Actions</h3>
      <div class="actions-grid">
        <%= link_to customer_shop_path, class: "action-btn" do %>
          <div class="action-icon" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
            <i class="bi bi-shop"></i>
          </div>
          <div>
            <div>Browse Shop</div>
            <small class="text-muted">Discover products</small>
          </div>
        <% end %>

        <%= link_to customer_orders_path, class: "action-btn" do %>
          <div class="action-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
            <i class="bi bi-box-seam"></i>
          </div>
          <div>
            <div>My Orders</div>
            <small class="text-muted">Track deliveries</small>
          </div>
        <% end %>

        <%= link_to customer_subscriptions_path, class: "action-btn" do %>
          <div class="action-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
            <i class="bi bi-arrow-repeat"></i>
          </div>
          <div>
            <div>Subscriptions</div>
            <small class="text-muted">Manage delivery</small>
          </div>
        <% end %>

        <%= link_to customer_profile_path, class: "action-btn" do %>
          <div class="action-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
            <i class="bi bi-person"></i>
          </div>
          <div>
            <div>My Profile</div>
            <small class="text-muted">Account settings</small>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Charts Grid -->
    <div class="chart-grid">
      <!-- Orders Chart -->
      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Order Activity</div>
            <div class="chart-subtitle">Last 7 days</div>
          </div>
        </div>
        <% if @order_activity_data[:has_data] %>
          <canvas id="ordersChart" width="400" height="200"></canvas>
        <% else %>
          <div class="empty-chart-placeholder">
            <i class="bi bi-bar-chart text-muted mb-3" style="font-size: 3rem;"></i>
            <p class="text-muted mb-2"><%= @order_activity_data[:message] %></p>
            <%= link_to customer_shop_path, class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-shop me-1"></i>Start Shopping
            <% end %>
          </div>
          <canvas id="ordersChart" width="400" height="200" style="display: none;"></canvas>
        <% end %>
      </div>

      <!-- Spending Chart -->
      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Monthly Spending</div>
            <div class="chart-subtitle">This year</div>
          </div>
        </div>
        <% if @monthly_spending_data[:has_data] %>
          <canvas id="spendingChart" width="400" height="200"></canvas>
        <% else %>
          <div class="empty-chart-placeholder">
            <i class="bi bi-wallet2 text-muted mb-3" style="font-size: 3rem;"></i>
            <p class="text-muted mb-2"><%= @monthly_spending_data[:message] %></p>
            <%= link_to customer_shop_path, class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-shop me-1"></i>Browse Products
            <% end %>
          </div>
          <canvas id="spendingChart" width="400" height="200" style="display: none;"></canvas>
        <% end %>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="activity-card">
      <h3 class="section-title">Recent Activity</h3>
      <div class="activity-item">
        <div class="activity-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
          <i class="bi bi-check-circle"></i>
        </div>
        <div class="activity-content">
          <h4>Order #1234 delivered successfully</h4>
          <p>2 hours ago • Fresh Organic Milk</p>
        </div>
      </div>

      <div class="activity-item">
        <div class="activity-icon" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
          <i class="bi bi-cart-plus"></i>
        </div>
        <div class="activity-content">
          <h4>Added items to cart</h4>
          <p>1 day ago • 3 items added</p>
        </div>
      </div>

      <div class="activity-item">
        <div class="activity-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
          <i class="bi bi-arrow-repeat"></i>
        </div>
        <div class="activity-content">
          <h4>Milk subscription renewed</h4>
          <p>3 days ago • Daily delivery active</p>
        </div>
      </div>
    </div>

  </div>
</div>

<% else %>
<!-- Not Logged In Section -->
<div class="dashboard-container">
  <div class="dashboard-content">
    <div class="text-center py-5">
      <h1 class="display-4 fw-bold mb-4">Welcome to Atma Nirbhar Farm</h1>
      <p class="lead mb-4">Fresh milk, organic groceries, and natural products delivered right to your doorstep.</p>
      <div class="d-flex justify-content-center gap-3">
        <%= link_to "Login", customer_login_path, class: "btn-primary-custom" %>
        <%= link_to "Register", customer_register_path, class: "btn btn-outline-primary" %>
      </div>
    </div>
  </div>
</div>
<% end %>

<script>
// Initialize Charts with Real Data
document.addEventListener('DOMContentLoaded', function() {
  // Orders Chart Data from Controller
  const orderActivityData = <%= @order_activity_data.to_json.html_safe %>;

  // Orders Chart
  const ordersCtx = document.getElementById('ordersChart');
  if (ordersCtx && ordersCtx.style.display !== 'none') {
    new Chart(ordersCtx, {
      type: 'line',
      data: {
        labels: orderActivityData.labels,
        datasets: [{
          label: 'Orders',
          data: orderActivityData.data,
          borderColor: 'rgb(59, 130, 246)',
          backgroundColor: 'rgba(59, 130, 246, 0.1)',
          tension: 0.4,
          fill: true,
          pointBackgroundColor: 'rgb(59, 130, 246)',
          pointBorderColor: 'white',
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index'
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: 'rgba(0, 0, 0, 0.8)',
            titleColor: 'white',
            bodyColor: 'white',
            borderColor: 'rgb(59, 130, 246)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                return `Orders: ${context.parsed.y}`;
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0, 0, 0, 0.05)',
              drawBorder: false
            },
            ticks: {
              stepSize: 1,
              color: '#64748b'
            }
          },
          x: {
            grid: {
              display: false
            },
            ticks: {
              color: '#64748b'
            }
          }
        }
      }
    });
  }

  // Spending Chart Data from Controller
  const monthlySpendingData = <%= @monthly_spending_data.to_json.html_safe %>;

  // Spending Chart
  const spendingCtx = document.getElementById('spendingChart');
  if (spendingCtx && spendingCtx.style.display !== 'none') {
    new Chart(spendingCtx, {
      type: 'bar',
      data: {
        labels: monthlySpendingData.labels,
        datasets: [{
          label: 'Spending',
          data: monthlySpendingData.data,
          backgroundColor: function(context) {
            const value = context.parsed.y;
            if (value === 0) {
              return 'rgba(203, 213, 225, 0.3)'; // Light gray for zero values
            }
            return 'rgba(16, 185, 129, 0.8)';
          },
          borderColor: function(context) {
            const value = context.parsed.y;
            if (value === 0) {
              return 'rgba(203, 213, 225, 0.5)';
            }
            return 'rgb(16, 185, 129)';
          },
          borderWidth: 1,
          borderRadius: 4,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index'
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: 'rgba(0, 0, 0, 0.8)',
            titleColor: 'white',
            bodyColor: 'white',
            borderColor: 'rgb(16, 185, 129)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                const value = context.parsed.y;
                if (value === 0) {
                  return 'No spending this month';
                }
                return `Spending: ₹${value.toFixed(2)}`;
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0, 0, 0, 0.05)',
              drawBorder: false
            },
            ticks: {
              color: '#64748b',
              callback: function(value) {
                if (value === 0) return '₹0';
                return '₹' + value.toLocaleString();
              }
            }
          },
          x: {
            grid: {
              display: false
            },
            ticks: {
              color: '#64748b'
            }
          }
        }
      }
    });
  }
});
