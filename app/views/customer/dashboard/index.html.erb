<% content_for :title, 'Dashboard' %>

<% if current_customer %>
<!-- Hero Banner Section - Show Active Banners First -->
<% if @banners&.any? %>
<div class="hero-banner-carousel mb-5">
  <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-indicators">
      <% @banners.each_with_index do |banner, index| %>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= index %>"
                class="<%= 'active' if index == 0 %>" aria-current="<%= 'true' if index == 0 %>"></button>
      <% end %>
    </div>

    <div class="carousel-inner">
      <% @banners.each_with_index do |banner, index| %>
        <div class="carousel-item <%= 'active' if index == 0 %>">
          <div class="hero-banner-slide"
               style="<%= banner.has_image? ? "background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url(#{banner.main_image_url})" : '' %>">
            <div class="container">
              <div class="row align-items-center min-vh-50">
                <div class="col-lg-7">
                  <div class="hero-content">
                    <h1 class="hero-title display-3 fw-bold mb-4 text-white">
                      <%= banner.title %>
                    </h1>
                    <p class="hero-description lead mb-4 text-white-75">
                      <%= banner.description || "Discover fresh, organic products delivered straight to your doorstep." %>
                    </p>
                    <div class="hero-actions">
                      <% if banner.redirect_link.present? %>
                        <%= link_to "Shop Now", banner.redirect_link,
                            class: "btn btn-hero-primary btn-lg me-3",
                            data: { aos: "fade-up", aos_delay: "200" } %>
                      <% else %>
                        <%= link_to "Shop Now", customer_products_path,
                            class: "btn btn-hero-primary btn-lg me-3",
                            data: { aos: "fade-up", aos_delay: "200" } %>
                      <% end %>
                      <%= link_to "Learn More", "#features",
                          class: "btn btn-hero-outline btn-lg",
                          data: { aos: "fade-up", aos_delay: "400" } %>
                    </div>
                  </div>
                </div>
                <% unless banner.has_image? %>
                <div class="col-lg-5 text-center">
                  <div class="hero-visual" data-aos="zoom-in" data-aos-delay="600">
                    <i class="bi bi-basket-fill hero-icon"></i>
                  </div>
                </div>
                <% end %>
              </div>
            </div>

            <!-- Decorative Elements -->
            <div class="hero-decoration">
              <div class="floating-shape shape-1"></div>
              <div class="floating-shape shape-2"></div>
              <div class="floating-shape shape-3"></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @banners.count > 1 %>
      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    <% end %>
  </div>
</div>
<% else %>
<!-- Default Hero Banner When No Active Banners -->
<div class="hero-banner-default mb-5">
  <div class="container">
    <div class="row align-items-center min-vh-50">
      <div class="col-lg-7">
        <div class="hero-content">
          <h1 class="hero-title display-3 fw-bold mb-4">
            Welcome back, <%= current_customer.first_name %>! 🌟
          </h1>
          <p class="hero-description lead mb-4">
            Discover fresh, organic products and natural groceries delivered straight to your doorstep.
            Your healthy lifestyle journey starts here.
          </p>
          <div class="hero-actions">
            <%= link_to "Explore Products", customer_products_path,
                class: "btn btn-hero-primary btn-lg me-3" %>
            <%= link_to "My Orders", customer_orders_path,
                class: "btn btn-hero-outline btn-lg" %>
          </div>
        </div>
      </div>
      <div class="col-lg-5 text-center">
        <div class="hero-visual">
          <i class="bi bi-heart-fill hero-icon text-success"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="hero-decoration">
    <div class="floating-shape shape-1"></div>
    <div class="floating-shape shape-2"></div>
    <div class="floating-shape shape-3"></div>
  </div>
</div>
<% end %>

<!-- Quick Action Cards -->
<div class="container mb-5">
  <div class="row g-4">
    <div class="col-lg-3 col-md-6">
      <div class="action-card action-cart" data-aos="fade-up" data-aos-delay="100">
        <div class="action-icon-wrapper">
          <div class="action-icon">
            <i class="bi bi-cart3"></i>
          </div>
          <div class="action-badge" id="cart-count-badge">0</div>
        </div>
        <div class="action-content">
          <h4 class="action-title">Shopping Cart</h4>
          <p class="action-description">View items ready for checkout</p>
          <%= link_to customer_cart_path, class: "action-link" do %>
            View Cart <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6">
      <div class="action-card action-orders" data-aos="fade-up" data-aos-delay="200">
        <div class="action-icon-wrapper">
          <div class="action-icon">
            <i class="bi bi-bag-check"></i>
          </div>
          <div class="action-badge"><%= @recent_orders.count %></div>
        </div>
        <div class="action-content">
          <h4 class="action-title">My Orders</h4>
          <p class="action-description">Track your recent purchases</p>
          <%= link_to customer_orders_path, class: "action-link" do %>
            View Orders <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6">
      <div class="action-card action-subscriptions" data-aos="fade-up" data-aos-delay="300">
        <div class="action-icon-wrapper">
          <div class="action-icon">
            <i class="bi bi-arrow-repeat"></i>
          </div>
          <div class="action-badge"><%= @active_subscriptions.count %></div>
        </div>
        <div class="action-content">
          <h4 class="action-title">Subscriptions</h4>
          <p class="action-description">Manage recurring deliveries</p>
          <%= link_to customer_subscriptions_path, class: "action-link" do %>
            View Subscriptions <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-3 col-md-6">
      <div class="action-card action-profile" data-aos="fade-up" data-aos-delay="400">
        <div class="action-icon-wrapper">
          <div class="action-icon">
            <i class="bi bi-person-circle"></i>
          </div>
        </div>
        <div class="action-content">
          <h4 class="action-title">My Profile</h4>
          <p class="action-description">Update account settings</p>
          <%= link_to customer_profile_path, class: "action-link" do %>
            Edit Profile <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>


<div class="container">
  <!-- Features Section -->
  <section id="features" class="mb-5">
    <h2 class="text-center mb-5">Why Choose Dhanvantri Naturals?</h2>
    <div class="row">
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-truck display-6 text-success"></i>
        </div>
        <h4>Free Delivery</h4>
        <p class="text-muted">Free delivery on orders above ₹500. Fast and reliable service to your doorstep.</p>
      </div>
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-shield-check display-6 text-success"></i>
        </div>
        <h4>Quality Assured</h4>
        <p class="text-muted">100% fresh and organic products. Quality guaranteed or money back.</p>
      </div>
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-arrow-repeat display-6 text-success"></i>
        </div>
        <h4>Subscription Plans</h4>
        <p class="text-muted">Daily, weekly, or monthly subscriptions for your regular needs.</p>
      </div>
    </div>
  </section>

  <!-- Product Categories Section -->
  <% if @categories.any? %>
    <section class="mb-5">
      <div class="container">
        <div class="section-header mb-5 text-center">
          <h2 class="section-title mb-3" data-aos="fade-up">Shop by Category</h2>
          <p class="section-subtitle mb-4" data-aos="fade-up" data-aos-delay="100">
            Explore our carefully curated collection of fresh, organic products
          </p>
          <%= link_to customer_categories_path,
              class: "btn btn-outline-primary btn-lg",
              data: { aos: "fade-up", aos_delay: "200" } do %>
            View All Categories <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>

        <div class="row g-4">
          <% @categories.each_with_index do |category, index| %>
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6"
                 data-aos="zoom-in"
                 data-aos-delay="<%= (index * 100) + 100 %>">
              <%= link_to customer_category_path(category), class: "text-decoration-none h-100" do %>
                <div class="modern-category-card">
                  <div class="category-image-wrapper">
                    <% if category.has_image? %>
                      <%= image_tag category.display_image_url,
                          class: "category-image",
                          alt: category.name,
                          loading: "lazy" %>
                    <% else %>
                      <div class="category-placeholder">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                      </div>
                    <% end %>
                    <div class="category-overlay">
                      <div class="category-overlay-content">
                        <i class="bi bi-arrow-right-circle"></i>
                      </div>
                    </div>
                  </div>
                  <div class="category-content">
                    <h5 class="category-name"><%= category.name %></h5>
                    <p class="category-count">
                      <%= pluralize(category.products_count || 0, 'Product') %>
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Featured Products Section -->
  <% if @featured_products.any? %>
    <section class="mb-5">
      <div class="container">
        <div class="section-header mb-5 text-center">
          <h2 class="section-title mb-3" data-aos="fade-up">Featured Products</h2>
          <p class="section-subtitle mb-4" data-aos="fade-up" data-aos-delay="100">
            Hand-picked premium products that our customers love most
          </p>
          <%= link_to customer_products_path,
              class: "btn btn-outline-primary btn-lg",
              data: { aos: "fade-up", aos_delay: "200" } do %>
            View All Products <i class="bi bi-arrow-right ms-2"></i>
          <% end %>
        </div>

        <div class="row g-4">
          <% @featured_products.each_with_index do |product, index| %>
            <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6"
                 data-aos="fade-up"
                 data-aos-delay="<%= (index * 100) + 100 %>">
              <div class="modern-product-card">
                <div class="product-image-wrapper">
                  <%= link_to customer_product_path(product), class: "product-image-link" do %>
                    <% if product.main_image_url %>
                      <%= image_tag product.main_image_url,
                          class: "product-image",
                          alt: product.name,
                          loading: "lazy" %>
                    <% else %>
                      <div class="product-placeholder">
                        <i class="bi bi-image"></i>
                      </div>
                    <% end %>
                  <% end %>

                  <!-- Product Badges -->
                  <div class="product-badges">
                    <% if product.respond_to?(:discounted?) && product.discounted? %>
                      <span class="badge badge-sale">
                        <%= product.discount_percentage.round %>% OFF
                      </span>
                    <% end %>

                    <% if product.respond_to?(:in_stock?) && !product.in_stock? %>
                      <span class="badge badge-out-of-stock">
                        Out of Stock
                      </span>
                    <% end %>

                    <% if product.respond_to?(:is_new?) && product.is_new? %>
                      <span class="badge badge-new">
                        New
                      </span>
                    <% end %>
                  </div>

                  <!-- Quick View Overlay -->
                  <div class="product-overlay">
                    <div class="product-overlay-content">
                      <%= link_to customer_product_path(product),
                          class: "btn btn-overlay-primary" do %>
                        <i class="bi bi-eye"></i>
                      <% end %>
                      <% if defined?(add_item_customer_cart_path) && product.respond_to?(:in_stock?) && product.in_stock? %>
                        <button type="button"
                                class="btn btn-overlay-secondary"
                                onclick="addToCartFromButton(<%= product.id %>, '<%= j product.name %>', <%= product.selling_price || product.price || 0 %>, '<%= product.main_image_url || '' %>')">
                          <i class="bi bi-cart-plus"></i>
                        </button>
                      <% end %>
                    </div>
                  </div>
                </div>

                <div class="product-content">
                  <div class="product-category">
                    <% if product.respond_to?(:category) && product.category %>
                      <%= product.category.name %>
                    <% else %>
                      Product
                    <% end %>
                  </div>

                  <h5 class="product-name">
                    <%= link_to product.name, customer_product_path(product),
                        class: "text-decoration-none product-name-link" %>
                  </h5>

                  <% if product.respond_to?(:has_reviews?) && product.has_reviews? %>
                    <div class="product-rating mb-2">
                      <div class="rating-stars">
                        <% (1..5).each do |star| %>
                          <i class="bi bi-star<%= '-fill' if star <= product.average_rating.floor %>"></i>
                        <% end %>
                      </div>
                      <span class="rating-count">(<%= product.total_reviews %>)</span>
                    </div>
                  <% end %>

                  <div class="product-pricing">
                    <span class="current-price">₹<%= product.selling_price || product.price || 0 %></span>
                    <% if product.respond_to?(:discounted?) && product.discounted? %>
                      <span class="original-price">₹<%= product.price %></span>
                    <% end %>
                  </div>

                  <div class="product-actions">
                    <% if product.respond_to?(:in_stock?) && product.in_stock? %>
                      <% if defined?(add_item_customer_cart_path) %>
                        <%= form_with url: add_item_customer_cart_path, method: :post, local: true,
                            class: "add-to-cart-form d-flex gap-2 align-items-center" do |f| %>
                          <%= f.hidden_field :product_id, value: product.id %>
                          <%= f.number_field :quantity, value: 1, min: 1,
                              max: [product.respond_to?(:available_quantity) ? product.available_quantity : 10, 10].min,
                              class: "form-control quantity-input" %>
                          <%= f.submit "Add to Cart", class: "btn btn-cart-primary flex-grow-1" %>
                        <% end %>
                      <% else %>
                        <button type="button"
                                class="btn btn-cart-primary w-100"
                                onclick="addToCartFromButton(<%= product.id %>, '<%= j product.name %>', <%= product.selling_price || product.price || 0 %>, '<%= product.main_image_url || '' %>')">
                          Add to Cart
                        </button>
                      <% end %>
                    <% else %>
                      <button class="btn btn-out-of-stock w-100" disabled>
                        <i class="bi bi-x-circle me-2"></i>Out of Stock
                      </button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Recent Bookings Section -->
  <% if @recent_orders.any? %>
    <section class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Your Recent Bookings</h2>
        <%= link_to "View All Bookings", customer_orders_path, class: "btn btn-outline-primary" %>
      </div>
      <div class="row">
        <% @recent_orders.each do |order| %>
          <div class="col-md-4 mb-3">
            <div class="bg-white rounded-lg shadow-sm p-3">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="fw-semibold mb-0">#<%= order.order_number %></h6>
                <span class="badge bg-<%= order.status == 'delivered' ? 'success' : order.status == 'cancelled' ? 'danger' : 'primary' %>">
                  <%= order.status.humanize %>
                </span>
              </div>
              <p class="text-muted small mb-2">
                <i class="bi bi-calendar3 me-1"></i>
                <%= order.order_date.strftime('%B %d, %Y') %>
              </p>
              <p class="fw-bold mb-2">₹<%= order.total_amount %></p>
              <%= link_to "View Booking", customer_order_path(order), class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Active Subscriptions Section -->
  <% if @active_subscriptions.any? %>
    <section class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Active Subscriptions</h2>
        <%= link_to "Manage Subscriptions", customer_subscriptions_path, class: "btn btn-outline-primary" %>
      </div>
      <div class="row">
        <% @active_subscriptions.each do |subscription| %>
          <div class="col-md-4 mb-3">
            <div class="bg-white rounded-lg shadow-sm p-3">
              <h6 class="fw-semibold mb-2"><%= subscription.product.name %></h6>
              <p class="text-muted small mb-2">
                <i class="bi bi-arrow-repeat me-1"></i>
                <%= subscription.quantity %> <%= subscription.unit %> - Daily
              </p>
              <p class="text-muted small mb-2">
                <i class="bi bi-calendar3 me-1"></i>
                Started: <%= subscription.start_date.strftime('%B %d, %Y') %>
              </p>
              <div class="d-flex gap-2">
                <%= link_to "View Details", customer_subscription_path(subscription), class: "btn btn-outline-primary btn-sm" %>
                <%= link_to "Pause", customer_subscription_pause_path(subscription), method: :patch, class: "btn btn-outline-warning btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Quick Order Section -->
  <section class="bg-light rounded-lg p-4 mb-5">
    <h3 class="text-center mb-4">Quick Order</h3>
    <p class="text-center text-muted mb-4">Quickly reorder your frequently purchased items</p>

    <!-- This would typically show frequently bought products by the customer -->
    <div class="text-center">
      <%= link_to "Browse All Products", customer_products_path, class: "btn btn-primary btn-lg" %>
    </div>
  </section>
</div>

<% else %>
<!-- Not Logged In Section -->
<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-8 text-center">
      <div class="hero-section py-5 mb-5">
        <h1 class="display-4 fw-bold mb-4">Welcome to Dhanvantri Naturals</h1>
        <p class="lead mb-4">Fresh milk, organic groceries, and natural products delivered right to your doorstep. Experience the convenience of healthy living with our premium quality products.</p>
        <%= link_to "Login", customer_login_path, class: "btn btn-light btn-lg me-3" %>
        <%= link_to "Register", customer_register_path, class: "btn btn-outline-light btn-lg" %>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <section id="features" class="mb-5">
    <h2 class="text-center mb-5">Why Choose Dhanvantri Naturals?</h2>
    <div class="row">
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-truck display-6 text-success"></i>
        </div>
        <h4>Free Delivery</h4>
        <p class="text-muted">Free delivery on orders above ₹500. Fast and reliable service to your doorstep.</p>
      </div>
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-shield-check display-6 text-success"></i>
        </div>
        <h4>Quality Assured</h4>
        <p class="text-muted">100% fresh and organic products. Quality guaranteed or money back.</p>
      </div>
      <div class="col-md-4 text-center mb-4">
        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
          <i class="bi bi-arrow-repeat display-6 text-success"></i>
        </div>
        <h4>Subscription Plans</h4>
        <p class="text-muted">Daily, weekly, or monthly subscriptions for your regular needs.</p>
      </div>
    </div>
  </section>
</div>
<% end %>