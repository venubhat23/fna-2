<% content_for :title, "Shop - Dhanvantri Naturals" %>
<% content_for :layout_class, "customer-main-content-no-sidebar" %>

<div class="professional-shop-page">
  <!-- Hero Header Section -->
  <div class="shop-hero-section">
    <div class="container-fluid px-4">
      <div class="hero-content">
        <!-- Back Navigation -->
        <div class="back-navigation mb-3">
          <%= link_to customer_dashboard_path, class: "back-btn" do %>
            <i class="fas fa-arrow-left me-2"></i>
            <span>Back to Dashboard</span>
          <% end %>
        </div>

        <!-- Hero Title and Search -->
        <div class="hero-header">
          <div class="hero-title-section">
            <h1 class="hero-title">
              <i class="fas fa-shopping-bag me-3"></i>
              Premium Shop
            </h1>
            <p class="hero-subtitle">Discover our exclusive collection of premium natural products</p>
          </div>

          <div class="hero-search">
            <%= form_with url: customer_shop_path, method: :get, local: true, class: "premium-search-form" do |f| %>
              <div class="search-input-wrapper">
                <i class="fas fa-search search-icon"></i>
                <%= f.text_field :search, value: params[:search],
                    placeholder: "Search for premium products...",
                    class: "premium-search-input" %>
                <%= f.submit "Search", class: "premium-search-btn" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container-fluid px-4 py-4">
    <div class="row g-4">
      <!-- Enhanced Filters Panel -->
      <div class="col-lg-3">
        <div class="premium-filters-panel">
          <div class="filters-header">
            <h5 class="filters-title">
              <i class="fas fa-sliders-h me-2"></i>
              Refine Your Search
            </h5>
          </div>

          <div class="filters-content">
            <%= form_with url: customer_shop_path, method: :get, local: true, class: "premium-filters-form" do |f| %>
              <%= f.hidden_field :search, value: params[:search] %>

              <!-- Category Filter -->
              <div class="filter-section">
                <h6 class="filter-section-title">Category</h6>
                <div class="category-filters-grid">
                  <div class="category-option">
                    <%= radio_button_tag :category_id, '', params[:category_id].blank?,
                        class: "category-radio", id: "category_all" %>
                    <label class="category-label" for="category_all">
                      <div class="category-icon">
                        <i class="fas fa-th-large"></i>
                      </div>
                      <span>All Categories</span>
                    </label>
                  </div>

                  <% @categories.each do |category| %>
                    <div class="category-option">
                      <%= radio_button_tag :category_id, category.id,
                          params[:category_id] == category.id.to_s,
                          class: "category-radio",
                          id: "category_#{category.id}" %>
                      <label class="category-label" for="category_<%= category.id %>">
                        <div class="category-icon">
                          <i class="fas fa-leaf"></i>
                        </div>
                        <span><%= category.name %></span>
                      </label>
                    </div>
                  <% end %>
                </div>
              </div>

              <!-- Price Range Filter -->
              <div class="filter-section">
                <h6 class="filter-section-title">Price Range</h6>
                <div class="price-range-inputs">
                  <%= f.number_field :min_price, value: params[:min_price],
                      placeholder: "Min Price", class: "price-input" %>
                  <span class="price-separator">to</span>
                  <%= f.number_field :max_price, value: params[:max_price],
                      placeholder: "Max Price", class: "price-input" %>
                </div>
              </div>

              <!-- Product Type Filter -->
              <div class="filter-section">
                <h6 class="filter-section-title">Product Type</h6>
                <%= f.select :product_type,
                    options_for_select([
                      ['All Types', 'all'],
                      ['Regular', 'regular'],
                      ['Subscription', 'subscription'],
                      ['Occasional', 'occasional']
                    ], params[:product_type] || 'all'),
                    {},
                    { class: "premium-select" } %>
              </div>

              <button type="submit" class="apply-filters-btn">
                <i class="fas fa-check me-2"></i>
                Apply Filters
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Products Section -->
      <div class="col-lg-9">
        <!-- Results Header -->
        <div class="results-header">
          <div class="results-info">
            <h4 class="results-title">
              <% if @search_query.present? %>
                Search Results for "<%= @search_query %>"
              <% elsif @selected_category %>
                <%= @selected_category.name %>
              <% else %>
                All Products
              <% end %>
            </h4>
            <p class="results-count">
              Showing <%= @products.count %> of <%= @products.total_count %> premium products
            </p>
          </div>

          <div class="sort-section">
            <%= form_with url: customer_shop_path, method: :get, local: true, class: "sort-form" do |f| %>
              <%= f.hidden_field :search, value: params[:search] %>
              <%= f.hidden_field :category_id, value: params[:category_id] %>
              <%= f.hidden_field :min_price, value: params[:min_price] %>
              <%= f.hidden_field :max_price, value: params[:max_price] %>
              <%= f.hidden_field :product_type, value: params[:product_type] %>

              <label class="sort-label">Sort by:</label>
              <%= f.select :sort,
                  options_for_select([
                    ['Featured', ''],
                    ['Price: Low to High', 'price_low'],
                    ['Price: High to Low', 'price_high'],
                    ['Name: A to Z', 'name'],
                    ['Newest First', 'newest']
                  ], params[:sort]),
                  {},
                  {
                    class: "sort-select",
                    onchange: "this.form.submit();"
                  } %>
            <% end %>
          </div>
        </div>

        <!-- Products Grid -->
        <% if @products.any? %>
          <div class="premium-products-grid">
            <div class="row g-4">
              <% @products.each do |product| %>
                <div class="col-xl-4 col-lg-4 col-md-6 col-sm-6" data-aos="zoom-in" data-aos-delay="<%= rand(100..300) %>">
                  <div class="premium-product-card">
                    <div class="product-image-section">
                      <% if product.image.present? %>
                        <%= image_tag product.image, class: "product-image", alt: product.name %>
                      <% elsif product.image_url.present? %>
                        <img src="<%= product.image_url %>" class="product-image" alt="<%= product.name %>">
                      <% else %>
                        <div class="product-image-placeholder">
                          <i class="fas fa-image"></i>
                        </div>
                      <% end %>

                      <!-- Product Badges -->
                      <div class="product-badges">
                        <% if product.discount_price.present? && product.discount_price > 0 %>
                          <span class="product-badge badge-sale">
                            <%= number_to_percentage(((product.price - product.discount_price) / product.price) * 100, precision: 0) %> OFF
                          </span>
                        <% end %>
                        <% if product.product_type == 'subscription' %>
                          <span class="product-badge badge-subscription">
                            Subscription
                          </span>
                        <% end %>
                      </div>

                      <!-- Quick Actions Overlay -->
                      <div class="product-overlay">
                        <div class="overlay-actions">
                          <%= link_to customer_shop_product_path(product), class: "overlay-btn view-btn" do %>
                            <i class="fas fa-eye"></i>
                          <% end %>
                          <% if product.stock.present? && product.stock > 0 %>
                            <button type="button"
                                    class="overlay-btn cart-btn"
                                    data-product-id="<%= product.id %>"
                                    onclick="addToCart(<%= product.id %>)">
                              <i class="fas fa-shopping-cart"></i>
                            </button>
                          <% end %>
                        </div>
                      </div>
                    </div>

                    <div class="product-content">
                      <div class="product-category-tag">
                        <%= product.category&.name || 'General' %>
                      </div>

                      <h6 class="product-title">
                        <%= link_to product.name, customer_shop_product_path(product),
                            class: "product-title-link" %>
                      </h6>

                      <div class="product-pricing">
                        <% if product.discount_price.present? && product.discount_price > 0 %>
                          <span class="current-price">₹<%= number_with_delimiter(product.discount_price.to_i) %></span>
                          <span class="original-price">₹<%= number_with_delimiter(product.price.to_i) %></span>
                        <% else %>
                          <span class="current-price">₹<%= number_with_delimiter(product.price.to_i) %></span>
                        <% end %>
                      </div>

                      <div class="product-actions">
                        <% if product.stock.present? && product.stock > 0 %>
                          <button type="button"
                                  class="add-to-cart-btn primary"
                                  data-product-id="<%= product.id %>"
                                  onclick="addToCart(<%= product.id %>)">
                            <i class="fas fa-shopping-cart me-2"></i>
                            Add to Cart
                          </button>
                        <% else %>
                          <button type="button" class="add-to-cart-btn disabled" disabled>
                            <i class="fas fa-times-circle me-2"></i>
                            Out of Stock
                          </button>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>

            <!-- Pagination -->
            <% if @products.respond_to?(:current_page) %>
              <div class="pagination-section">
                <%= paginate @products, theme: 'customer' %>
              </div>
            <% end %>
          </div>
        <% else %>
          <!-- Empty State -->
          <div class="empty-state-section">
            <div class="empty-state-content">
              <div class="empty-state-icon">
                <i class="fas fa-search"></i>
              </div>
              <h3 class="empty-state-title">No Products Found</h3>
              <p class="empty-state-message">
                <% if @search_query.present? %>
                  We couldn't find any products matching "<%= @search_query %>". Try different search terms or browse our categories.
                <% else %>
                  No products are currently available in this category. Check back soon for new arrivals!
                <% end %>
              </p>
              <div class="empty-state-actions">
                <%= link_to "View All Products", customer_shop_path, class: "empty-state-btn primary" %>
                <%= link_to "Browse Categories", "#", class: "empty-state-btn secondary" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
/* ===== PROFESSIONAL SHOP PAGE STYLES ===== */

/* Override the sidebar layout for this page */
.customer-main-content-no-sidebar {
  margin-left: 0 !important;
  margin-top: 70px !important;
  padding: 0 !important;
  width: 100vw !important;
}

/* Professional Shop Page Container */
.professional-shop-page {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  min-height: calc(100vh - 70px);
  font-family: 'Poppins', sans-serif;
  overflow-x: hidden;
}

/* Hero Section */
.shop-hero-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 3rem 0 4rem;
  position: relative;
  overflow: hidden;
}

.shop-hero-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 200"><path d="M0,120L50,130C100,140,200,160,300,150C400,140,500,100,600,90C700,80,800,100,900,110C950,115,1000,120,1050,125L1100,130L1100,200L1050,200C1000,200,900,200,800,200C700,200,600,200,500,200C400,200,300,200,200,200C100,200,50,200,25,200L0,200Z" fill="rgba(255,255,255,0.1)"/></svg>') no-repeat bottom;
  background-size: cover;
  animation: wave 3s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

/* Back Navigation */
.back-navigation {
  animation: slideInLeft 0.6s ease-out;
}

.back-btn {
  background: rgba(255, 255, 255, 0.15);
  color: white;
  padding: 12px 20px;
  border-radius: 25px;
  text-decoration: none;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.back-btn:hover {
  background: rgba(255, 255, 255, 0.25);
  color: white;
  transform: translateX(-5px);
  box-shadow: 0 8px 25px rgba(255, 255, 255, 0.2);
}

/* Hero Header */
.hero-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.hero-title-section {
  flex: 1;
}

.hero-title {
  font-size: 3.5rem;
  font-weight: 800;
  color: white;
  margin-bottom: 1rem;
  text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
}

.hero-title i {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: bounce 2s ease-in-out infinite;
}

.hero-subtitle {
  font-size: 1.2rem;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
  line-height: 1.6;
}

/* Premium Search Form */
.hero-search {
  flex: 1;
  max-width: 500px;
}

.premium-search-form {
  position: relative;
}

.search-input-wrapper {
  position: relative;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50px;
  padding: 5px;
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.search-input-wrapper:focus-within {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.4);
  transform: scale(1.02);
  box-shadow: 0 12px 40px rgba(255, 255, 255, 0.2);
}

.search-icon {
  position: absolute;
  left: 20px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 1.1rem;
  z-index: 2;
}

.premium-search-input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 15px 50px 15px 50px;
  color: white;
  font-size: 1rem;
  font-weight: 500;
  border-radius: 50px;
}

.premium-search-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.premium-search-input:focus {
  outline: none;
  box-shadow: none;
}

.premium-search-btn {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  border: none;
  color: white;
  padding: 12px 25px;
  border-radius: 50px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
}

.premium-search-btn:hover {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
  color: white;
}

/* Premium Filters Panel */
.premium-filters-panel {
  background: white;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  border: 1px solid #e2e8f0;
  overflow: hidden;
  position: sticky;
  top: 100px;
  animation: slideInLeft 0.8s ease-out 0.4s both;
}

.filters-header {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  padding: 1.5rem;
  border-bottom: 1px solid #e2e8f0;
}

.filters-title {
  margin: 0;
  font-weight: 700;
  color: #1e293b;
  font-size: 1.1rem;
  display: flex;
  align-items: center;
}

.filters-title i {
  color: #10b981;
  margin-right: 0.5rem;
}

.filters-content {
  padding: 1.5rem;
}

/* Filter Sections */
.filter-section {
  margin-bottom: 2rem;
  border-bottom: 1px solid #f1f5f9;
  padding-bottom: 1.5rem;
}

.filter-section:last-of-type {
  border-bottom: none;
  margin-bottom: 1rem;
}

.filter-section-title {
  font-weight: 600;
  color: #374151;
  margin-bottom: 1rem;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Category Filters Grid */
.category-filters-grid {
  display: grid;
  gap: 0.5rem;
}

.category-option {
  position: relative;
}

.category-radio {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.category-label {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-radius: 12px;
  border: 2px solid #e2e8f0;
  background: #f8fafc;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  font-weight: 500;
  color: #64748b;
  gap: 12px;
  margin: 0;
}

.category-label:hover {
  border-color: #10b981;
  background: rgba(16, 185, 129, 0.05);
  transform: translateX(4px);
}

.category-radio:checked + .category-label {
  border-color: #10b981;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(52, 211, 153, 0.1) 100%);
  color: #10b981;
  font-weight: 600;
  box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);
}

.category-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  font-size: 14px;
}

.category-radio:checked + .category-label .category-icon {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: white;
  transform: scale(1.1);
}

/* Price Range Inputs */
.price-range-inputs {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0.5rem;
  align-items: center;
}

.price-input {
  padding: 12px 16px;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  background: #f8fafc;
  color: #1e293b;
  font-weight: 500;
  transition: all 0.3s ease;
}

.price-input:focus {
  outline: none;
  border-color: #10b981;
  background: white;
  box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
}

.price-separator {
  color: #64748b;
  font-weight: 600;
  text-align: center;
}

/* Premium Select */
.premium-select {
  width: 100%;
  padding: 12px 16px;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  background: #f8fafc;
  color: #1e293b;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
}

.premium-select:focus {
  outline: none;
  border-color: #10b981;
  background: white;
  box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
}

/* Apply Filters Button */
.apply-filters-btn {
  width: 100%;
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  border: none;
  color: white;
  padding: 14px 20px;
  border-radius: 12px;
  font-weight: 600;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
}

.apply-filters-btn:hover {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
}

/* Results Header */
.results-header {
  background: white;
  border-radius: 16px;
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  animation: fadeInUp 0.8s ease-out 0.6s both;
}

.results-title {
  font-size: 1.8rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 0.5rem 0;
}

.results-count {
  color: #64748b;
  font-weight: 500;
  margin: 0;
}

/* Sort Section */
.sort-form {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.sort-label {
  color: #64748b;
  font-weight: 600;
  margin: 0;
  white-space: nowrap;
}

.sort-select {
  padding: 10px 16px;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  background: #f8fafc;
  color: #1e293b;
  font-weight: 500;
  min-width: 200px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.sort-select:focus {
  outline: none;
  border-color: #10b981;
  background: white;
  box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
}

/* Premium Products Grid */
.premium-products-grid {
  animation: fadeInUp 0.8s ease-out 0.8s both;
}

.premium-product-card {
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid #e2e8f0;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
}

.premium-product-card:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.15);
  border-color: #10b981;
}

/* Product Image Section */
.product-image-section {
  position: relative;
  height: 250px;
  overflow: hidden;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.premium-product-card:hover .product-image {
  transform: scale(1.1) rotate(2deg);
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
  color: #cbd5e1;
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
}

/* Product Badges */
.product-badges {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.product-badge {
  padding: 6px 12px;
  border-radius: 15px;
  font-size: 0.7rem;
  font-weight: 700;
