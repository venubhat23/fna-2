<% content_for :title, "Shop Products - Dhanvantri Naturals" %>

<style>
  /* Premium Shop Page Styles - Matching Dashboard Green Theme */
  body {
    background: linear-gradient(135deg, #f8fcf9 0%, #ffffff 100%);
  }

  .hover-lift {
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .hover-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(28, 124, 84, 0.15) !important;
  }

  .product-card {
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    height: 100%;
    border: 1px solid rgba(28, 124, 84, 0.1);
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(28, 124, 84, 0.12);
    border-color: rgba(28, 124, 84, 0.2);
  }

  .btn-group-sm .btn {
    font-size: 0.875rem;
  }

  .card-img-top {
    height: 200px;
    object-fit: cover;
  }

  .card-title {
    min-height: 48px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: #1C7C54;
    font-weight: 600;
  }

  .quantity-input {
    height: 45px;
    font-size: 1.1rem;
    border: 2px solid rgba(28, 124, 84, 0.1);
    transition: all 0.3s ease;
  }

  .quantity-input:focus {
    border-color: #1C7C54;
    box-shadow: 0 0 0 3px rgba(28, 124, 84, 0.1);
  }

  .quantity-btn {
    width: 45px;
    height: 45px;
    border: 2px solid #1C7C54;
    color: #1C7C54;
    background: rgba(28, 124, 84, 0.05);
    transition: all 0.3s ease;
  }

  .quantity-btn:hover {
    background: #1C7C54;
    color: white;
    transform: scale(1.05);
  }

  /* Premium Header with Green Theme */
  .shop-header {
    background: linear-gradient(135deg, #1C7C54 0%, #10b981 100%);
    border-radius: 16px;
    padding: 3rem 2rem;
    margin-bottom: 2rem;
    border: none;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(28, 124, 84, 0.15);
  }

  .shop-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, transparent 0%, rgba(255, 255, 255, 0.1) 50%, transparent 100%);
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  .shop-title {
    color: white;
    font-weight: 700;
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    letter-spacing: 0.5px;
    position: relative;
    z-index: 2;
  }

  .shop-subtitle {
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    font-size: 1.1rem;
    font-weight: 500;
    position: relative;
    z-index: 2;
  }

  /* Enhanced Cards */
  .card {
    border: 1px solid rgba(28, 124, 84, 0.1);
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: rgba(28, 124, 84, 0.2);
  }

  /* Premium Buttons */
  .btn-primary {
    background: linear-gradient(135deg, #1C7C54 0%, #10b981 100%);
    border: none;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(28, 124, 84, 0.2);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #0f5d3d 0%, #047857 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(28, 124, 84, 0.3);
  }

  .btn-outline-primary {
    color: #1C7C54;
    border-color: #1C7C54;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-outline-primary:hover {
    background: #1C7C54;
    border-color: #1C7C54;
    transform: translateY(-1px);
  }

  /* Filter Buttons */
  .btn-group .btn.active {
    background: linear-gradient(135deg, #1C7C54 0%, #10b981 100%);
    border-color: #1C7C54;
    color: white;
    box-shadow: 0 4px 12px rgba(28, 124, 84, 0.2);
  }

  /* Form Controls */
  .form-control, .form-select {
    border: 2px solid rgba(28, 124, 84, 0.1);
    transition: all 0.3s ease;
  }

  .form-control:focus, .form-select:focus {
    border-color: #1C7C54;
    box-shadow: 0 0 0 3px rgba(28, 124, 84, 0.1);
  }

  /* Price Display */
  .text-primary {
    color: #1C7C54 !important;
  }

  .text-success {
    color: #10b981 !important;
  }

  /* Stock Badges */
  .badge.bg-success {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
  }

  .badge.bg-warning {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
  }

  .badge.bg-danger {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important;
  }

</style>

<div class="container py-4">
  <!-- Shop Header -->
  <div class="shop-header">
    <h1 class="shop-title d-flex align-items-center">
      <i class="fas fa-shopping-basket me-3"></i>
      Shop Products
    </h1>
    <p class="shop-subtitle">Browse and order your favorite fresh & organic products</p>
  </div>

  <!-- Search and Filters -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="row g-2 align-items-center">
        <div class="col-md-5">
          <%= form_with url: customer_shop_path, method: :get, local: true, class: "d-flex" do |f| %>
            <%= f.text_field :search, value: params[:search],
                placeholder: "Search products by name, SKU, or category...",
                class: "form-control form-control-sm" %>
            <button type="submit" class="btn btn-primary btn-sm ms-2">
              <i class="bi bi-search"></i>
            </button>
          <% end %>
        </div>
        <div class="col-md-3">
          <select class="form-select form-select-sm" id="categoryFilter">
            <option value="">All Categories</option>
            <% @categories.each do |category| %>
              <option value="<%= category.id %>"><%= category.name %></option>
            <% end %>
          </select>
        </div>
        <div class="col-md-4">
          <div class="d-flex gap-2 align-items-center">
            <small class="text-muted">Filter:</small>
            <div class="btn-group btn-group-sm" role="group">
              <button type="button" class="btn btn-outline-primary btn-sm active" id="allProductsBtn" onclick="toggleFilter('all')">All</button>
              <button type="button" class="btn btn-outline-primary btn-sm" id="inStockBtn" onclick="toggleFilter('instock')">In Stock</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Products Grid -->
  <% if @products&.any? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body pt-3">
        <div class="row g-3" id="productGrid">
          <% @products.each do |product| %>
            <% current_stock = product.cached_total_batch_stock %>
            <% in_stock = current_stock > 0 %>

            <div class="col-md-4 col-lg-3 product-grid-item"
                 data-product-id="<%= product.id %>"
                 data-category="<%= product.category_id %>"
                 data-stock="<%= current_stock %>">
              <div class="card h-100 border-0 shadow-sm hover-lift">
                <!-- Product Image -->
                <div class="position-relative">
                  <% if product.image.present? %>
                    <%= image_tag product.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
                  <% elsif product.image_url.present? %>
                    <img src="<%= product.image_url %>" class="card-img-top" style="height: 200px; object-fit: cover;" alt="<%= product.name %>">
                  <% else %>
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                      <i class="bi bi-box-seam fs-1 text-muted"></i>
                    </div>
                  <% end %>

                  <!-- Enhanced Stock Badge -->
                  <% if current_stock == 0 %>
                    <span class="position-absolute top-0 end-0 badge bg-danger m-2">
                      <i class="bi bi-x-circle me-1"></i>Out of Stock
                    </span>
                  <% elsif current_stock < 10 %>
                    <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2">
                      <i class="bi bi-exclamation-triangle me-1"></i>Low Stock (<%= current_stock.to_i %> left)
                    </span>
                  <% else %>
                    <span class="position-absolute top-0 end-0 badge bg-success m-2">
                      <i class="bi bi-check-circle me-1"></i><%= current_stock.to_i %> in stock
                    </span>
                  <% end %>

                  <!-- Discount Badge -->
                  <% if product.respond_to?(:discount_price) && product.discount_price.present? && product.discount_price != product.price %>
                    <% discount_percent = ((product.price - product.discount_price) * 100 / product.price).round %>
                    <span class="position-absolute top-0 start-0 badge bg-success m-2"><%= discount_percent %>% OFF</span>
                  <% end %>
                </div>

                <!-- Product Details -->
                <div class="card-body d-flex flex-column">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <small class="text-muted"><%= product.category&.name || 'No Category' %></small>
                  </div>

                  <h6 class="card-title mb-2"><%= product.name %></h6>

                  <!-- Price -->
                  <div class="mb-3">
                    <%
                      # Calculate final price with GST
                      selling_price = product.respond_to?(:discount_price) && product.discount_price.present? && product.discount_price != product.price ? product.discount_price : product.price

                      if product.gst_enabled && product.gst_percentage.present? && product.gst_percentage > 0
                        gst_rate = product.gst_percentage
                        base_price = selling_price / (1 + (gst_rate / 100.0))
                        gst_amount = selling_price - base_price
                        final_price = selling_price
                      else
                        base_price = selling_price
                        gst_rate = 0
                        gst_amount = 0
                        final_price = selling_price
                      end
                    %>

                    <% if product.respond_to?(:discount_price) && product.discount_price.present? && product.discount_price != product.price %>
                      <div class="d-flex align-items-center gap-2">
                        <span class="h6 text-success mb-0">₹<%= number_with_delimiter(final_price.round(2)) %></span>
                        <small class="text-muted text-decoration-line-through">₹<%= number_with_delimiter(product.price) %></small>
                      </div>
                    <% else %>
                      <span class="h6 text-primary mb-0">₹<%= number_with_delimiter(final_price.round(2)) %></span>
                    <% end %>

                    <% if product.gst_enabled && gst_rate > 0 %>
                      <small class="text-muted d-block">
                        Base: ₹<%= number_with_delimiter(base_price.round(2)) %> + GST: ₹<%= number_with_delimiter(gst_amount.round(2)) %> (<%= gst_rate %>%) = ₹<%= number_with_delimiter(final_price.round(2)) %>
                      </small>
                    <% end %>
                  </div>

                  <!-- Quantity and Add to Cart -->
                  <div class="mt-auto">
                    <% if current_stock > 0 %>
                      <!-- Quantity Selector -->
                      <div class="mb-3">
                        <label class="form-label fw-bold small">
                          Quantity
                          <span class="badge bg-info-subtle text-info ms-1">
                            Max: <%= current_stock.to_i %>
                          </span>
                        </label>
                        <div class="input-group">
                          <button class="btn btn-outline-primary quantity-btn" type="button" onclick="decreaseQty(<%= product.id %>)">
                            <i class="bi bi-dash fw-bold"></i>
                          </button>
                          <input type="number"
                                 id="qty-<%= product.id %>"
                                 value="1"
                                 min="1"
                                 step="1"
                                 max="<%= current_stock %>"
                                 class="form-control text-center fw-bold quantity-input"
                                 onchange="validateQty(<%= product.id %>, <%= current_stock %>)">
                          <button class="btn btn-outline-primary quantity-btn" type="button" onclick="increaseQty(<%= product.id %>)">
                            <i class="bi bi-plus fw-bold"></i>
                          </button>
                        </div>

                        <!-- Simple Stock Warning - Only for Low Stock -->
                        <% if current_stock < 10 %>
                          <small class="text-warning d-block mt-1">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <strong>Low Stock!</strong> Only <%= current_stock.to_i %> left
                          </small>
                        <% end %>
                      </div>

                      <!-- Add to Cart Button -->
                      <button class="btn btn-primary w-100"
                              onclick="addToCart(<%= product.id %>, '<%= j(product.name) %>', <%= final_price %>, <%= current_stock %>, <%= base_price %>, <%= gst_rate %>)">
                        <i class="bi bi-cart-plus me-2"></i>Add to Cart
                      </button>
                    <% else %>
                      <!-- Out of Stock Button -->
                      <button class="btn btn-danger w-100" disabled>
                        <i class="bi bi-x-circle me-2"></i>Out of Stock
                      </button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <div class="mb-4">
          <i class="bi bi-box-seam fs-1 text-muted"></i>
        </div>
        <h5 class="card-title">No Products Found</h5>
        <p class="text-muted mb-4">Check back later for new products or try adjusting your search.</p>
        <%= link_to customer_dashboard_path, class: "btn btn-primary" do %>
          <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!-- Cart Notification -->
<div id="cartNotification" class="position-fixed" style="top: 90px; right: 24px; z-index: 1050; display: none;">
  <div class="alert alert-success alert-dismissible fade show" style="min-width: 300px;">
    <strong id="addedProductName"></strong> added to cart!
    <button type="button" class="btn-close" onclick="hideCartNotification()"></button>
  </div>
</div>

<script>
// Modern Shopping Cart Management - Based on Admin Booking Design
let cart = JSON.parse(localStorage.getItem('customerCart') || '[]');

document.addEventListener('DOMContentLoaded', function() {
  updateCartBadge();
  initializeFilters();
});

// Initialize filters
function initializeFilters() {
  // Category filter dropdown
  const categoryFilter = document.getElementById('categoryFilter');
  if (categoryFilter) {
    categoryFilter.addEventListener('change', function() {
      const categoryId = this.value;
      if (categoryId === '') {
        showAllProducts();
      } else {
        filterProductsByCategory(categoryId);
      }
    });
  }
}

// Quantity controls - matching admin booking design
function decreaseQty(productId) {
  const qtyInput = document.getElementById(`qty-${productId}`);
  const current = parseInt(qtyInput.value);
  const step = parseInt(qtyInput.step) || 1;
  const min = parseInt(qtyInput.min) || 1;

  if (current > min) {
    qtyInput.value = Math.max(min, current - step);
  }
}

function increaseQty(productId) {
  const qtyInput = document.getElementById(`qty-${productId}`);
  const max = parseInt(qtyInput.max);
  const current = parseInt(qtyInput.value);
  const step = parseInt(qtyInput.step) || 1;

  if (current < max) {
    qtyInput.value = Math.min(max, current + step);
  }
}

function validateQty(productId, maxStock) {
  const qtyInput = document.getElementById(`qty-${productId}`);
  let value = parseInt(qtyInput.value);
  const min = parseInt(qtyInput.min) || 1;

  if (isNaN(value) || value < min) {
    qtyInput.value = min;
  } else if (value > maxStock) {
    qtyInput.value = maxStock;
    // Use Bootstrap toast instead of alert
    showToast('warning', `Maximum available quantity is ${maxStock}`);
  }
}

// Enhanced Add to Cart functionality
function addToCart(productId, productName, finalPrice, maxStock, basePrice, gstRate) {
  const qtyInput = document.getElementById(`qty-${productId}`);
  const quantity = parseInt(qtyInput.value);
  const button = document.querySelector(`button[onclick*="addToCart(${productId}"]`);

  if (quantity <= 0) {
    showToast('warning', 'Please enter a valid quantity');
    return;
  }

  if (quantity > maxStock) {
    showToast('warning', `Only ${maxStock} items available in stock`);
    return;
  }

  // Button loading state
  const originalContent = button.innerHTML;
  button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Adding...';
  button.disabled = true;

  // Simulate API call delay for better UX
  setTimeout(() => {
    // Check if product already exists in cart
    const existingIndex = cart.findIndex(item => item.id == productId);

    if (existingIndex > -1) {
      // Update quantity
      cart[existingIndex].quantity += quantity;
      if (cart[existingIndex].quantity > maxStock) {
        cart[existingIndex].quantity = maxStock;
        showToast('info', `Quantity adjusted to maximum available stock: ${maxStock}`);
      }
    } else {
      // Add new item
      cart.push({
        id: productId,
        name: productName,
        price: finalPrice,
        basePrice: basePrice,
        gstRate: gstRate,
        quantity: quantity,
        maxStock: maxStock
      });
    }

    // Save to localStorage
    localStorage.setItem('customerCart', JSON.stringify(cart));

    // Update UI
    updateCartBadge();
    showToast('success', `${productName} added to cart successfully!`);

    // Reset button and quantity
    button.innerHTML = originalContent;
    button.disabled = false;
    qtyInput.value = 1;
  }, 500);
}

// Modern toast notifications
function showToast(type, message) {
  // Remove existing toasts
  const existingToasts = document.querySelectorAll('.toast');
  existingToasts.forEach(toast => toast.remove());

  // Create toast
  const toastContainer = document.createElement('div');
  toastContainer.className = 'position-fixed top-0 end-0 p-3';
  toastContainer.style.zIndex = '1055';

  const bgClass = type === 'success' ? 'bg-success' : type === 'warning' ? 'bg-warning' : type === 'info' ? 'bg-info' : 'bg-primary';

  toastContainer.innerHTML = `
    <div class="toast show align-items-center text-white ${bgClass} border-0" role="alert">
      <div class="d-flex">
        <div class="toast-body">
          <i class="bi bi-${type === 'success' ? 'check-circle' : type === 'warning' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>
          ${message}
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button>
      </div>
    </div>
  `;

  document.body.appendChild(toastContainer);

  // Auto remove after 3 seconds
  setTimeout(() => {
    toastContainer.remove();
  }, 3000);
}

function updateCartBadge() {
  const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
  const cartBadge = document.getElementById('cart-count');

  if (cartBadge) {
    if (totalItems > 0) {
      cartBadge.textContent = Math.round(totalItems);
      cartBadge.style.display = 'inline-block';
    } else {
      cartBadge.style.display = 'none';
    }
  }

  // Also update header cart badge
  const headerCartBadge = document.getElementById('cart-badge');
  if (headerCartBadge) {
    if (totalItems > 0) {
      headerCartBadge.textContent = totalItems > 99 ? '99+' : Math.round(totalItems);
      headerCartBadge.style.display = 'block';
    } else {
      headerCartBadge.style.display = 'none';
    }
  }

  // Dispatch custom event for other pages
  window.dispatchEvent(new CustomEvent('cartUpdated', {
    detail: { totalItems: totalItems }
  }));
}

// Enhanced Filter functionality
function toggleFilter(type) {
  const products = document.querySelectorAll('.product-grid-item');
  const buttons = document.querySelectorAll('#allProductsBtn, #inStockBtn');

  // Update button states
  buttons.forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');

  if (type === 'all') {
    products.forEach(product => {
      product.style.display = 'block';
    });
  } else if (type === 'instock') {
    products.forEach(product => {
      const stock = parseInt(product.dataset.stock);
      product.style.display = stock > 0 ? 'block' : 'none';
    });
  }
}

function filterProductsByCategory(categoryId) {
  const products = document.querySelectorAll('.product-grid-item');

  products.forEach(product => {
    const productCategory = product.dataset.category;
    product.style.display = productCategory == categoryId ? 'block' : 'none';
  });
}

function showAllProducts() {
  const products = document.querySelectorAll('.product-grid-item');
  products.forEach(product => {
    product.style.display = 'block';
  });
}
</script>