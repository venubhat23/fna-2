<% content_for :title, "Referral Details" %>

<style>
/* Referral Details Page Styles */
.referral-detail-card {
  background: white;
  border-radius: 20px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  max-width: 800px;
  margin: 0 auto;
}

.referral-detail-header {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: white;
  padding: 2rem;
  text-align: center;
}

.referral-detail-body {
  padding: 2.5rem 2rem;
}

.referral-status-large {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  border-radius: 20px;
  font-size: 1rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2rem;
}

.status-pending {
  background: rgba(251, 191, 36, 0.15);
  color: #d97706;
  border: 2px solid rgba(251, 191, 36, 0.3);
}

.status-registered {
  background: rgba(59, 130, 246, 0.15);
  color: #2563eb;
  border: 2px solid rgba(59, 130, 246, 0.3);
}

.status-converted {
  background: rgba(16, 185, 129, 0.15);
  color: #059669;
  border: 2px solid rgba(16, 185, 129, 0.3);
}

.detail-section {
  margin-bottom: 2.5rem;
}

.detail-section-title {
  color: #1f2937;
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.detail-section-icon {
  background: #f3f4f6;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
}

.detail-item {
  background: #f8fafc;
  border-radius: 12px;
  padding: 1.25rem;
  border: 1px solid #e2e8f0;
}

.detail-item-label {
  color: #6b7280;
  font-size: 0.85rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.5rem;
}

.detail-item-value {
  color: #1f2937;
  font-size: 1rem;
  font-weight: 600;
}

.timeline {
  position: relative;
  padding-left: 2rem;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0.75rem;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #e2e8f0;
}

.timeline-item {
  position: relative;
  padding-bottom: 2rem;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -0.5rem;
  top: 0.25rem;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #10b981;
  border: 3px solid white;
  box-shadow: 0 0 0 2px #10b981;
}

.timeline-content {
  padding-left: 1rem;
}

.timeline-date {
  color: #6b7280;
  font-size: 0.85rem;
  font-weight: 500;
}

.timeline-title {
  color: #1f2937;
  font-weight: 600;
  margin: 0.25rem 0;
}

.timeline-description {
  color: #6b7280;
  font-size: 0.9rem;
}

.back-btn {
  color: #64748b;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 2rem;
  font-weight: 500;
  transition: color 0.3s ease;
}

.back-btn:hover {
  color: #10b981;
  text-decoration: none;
}

.action-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid #e2e8f0;
}

.btn-modern {
  padding: 0.75rem 1.5rem;
  border-radius: 12px;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s ease;
  border: none;
}

.btn-primary-modern {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: white;
}

.btn-primary-modern:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
  color: white;
  text-decoration: none;
}

.btn-outline-modern {
  background: white;
  color: #6b7280;
  border: 2px solid #e5e7eb;
}

.btn-outline-modern:hover {
  border-color: #10b981;
  color: #10b981;
  text-decoration: none;
}

.btn-danger-modern {
  background: #ef4444;
  color: white;
}

.btn-danger-modern:hover {
  background: #dc2626;
  color: white;
  text-decoration: none;
}

.notes-section {
  background: #fef3c7;
  border: 1px solid #fde68a;
  border-radius: 12px;
  padding: 1.5rem;
  margin-top: 1.5rem;
}

.notes-title {
  color: #92400e;
  font-weight: 600;
  margin-bottom: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.notes-content {
  color: #78350f;
  font-style: italic;
  line-height: 1.5;
}
</style>

<div class="container-fluid">
  <div class="row">
    <div class="col-12">

      <%= link_to customer_referrals_path, class: "back-btn" do %>
        <i class="bi bi-arrow-left"></i>
        Back to Referrals
      <% end %>

      <div class="referral-detail-card">
        <div class="referral-detail-header">
          <h2 class="mb-2">Referral Details</h2>
          <p class="mb-0">Track your friend's referral journey</p>
        </div>

        <div class="referral-detail-body">
          <!-- Status Badge -->
          <div class="text-center">
            <span class="referral-status-large status-<%= @referral.status %>">
              <%= @referral.status.humanize %>
            </span>
          </div>

          <!-- Contact Information -->
          <div class="detail-section">
            <div class="detail-section-title">
              <div class="detail-section-icon">
                <i class="bi bi-person-fill"></i>
              </div>
              Contact Information
            </div>
            <div class="detail-grid">
              <div class="detail-item">
                <div class="detail-item-label">Full Name</div>
                <div class="detail-item-value"><%= @referral.referred_name %></div>
              </div>
              <div class="detail-item">
                <div class="detail-item-label">Email Address</div>
                <div class="detail-item-value"><%= @referral.referred_email %></div>
              </div>
              <div class="detail-item">
                <div class="detail-item-label">Mobile Number</div>
                <div class="detail-item-value"><%= @referral.referred_mobile %></div>
              </div>
              <div class="detail-item">
                <div class="detail-item-label">Referral Date</div>
                <div class="detail-item-value"><%= @referral.referral_date.strftime("%B %d, %Y") %></div>
              </div>
            </div>
          </div>

          <!-- Referral Timeline -->
          <div class="detail-section">
            <div class="detail-section-title">
              <div class="detail-section-icon">
                <i class="bi bi-clock-fill"></i>
              </div>
              Referral Timeline
            </div>
            <div class="timeline">
              <div class="timeline-item">
                <div class="timeline-content">
                  <div class="timeline-date"><%= @referral.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
                  <div class="timeline-title">Referral Created</div>
                  <div class="timeline-description">You submitted this referral</div>
                </div>
              </div>

              <% if @referral.status == 'registered' || @referral.status == 'converted' %>
                <div class="timeline-item">
                  <div class="timeline-content">
                    <div class="timeline-date">
                      <%= @referral.customer&.created_at&.strftime("%B %d, %Y at %I:%M %p") || "Date not available" %>
                    </div>
                    <div class="timeline-title">Friend Registered</div>
                    <div class="timeline-description">Your friend created an account</div>
                  </div>
                </div>
              <% end %>

              <% if @referral.status == 'converted' %>
                <div class="timeline-item">
                  <div class="timeline-content">
                    <div class="timeline-date">
                      <%= @referral.converted_at&.strftime("%B %d, %Y at %I:%M %p") || "Date not available" %>
                    </div>
                    <div class="timeline-title">First Purchase Made</div>
                    <div class="timeline-description">Your friend made their first purchase - rewards earned!</div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Statistics -->
          <div class="detail-section">
            <div class="detail-section-title">
              <div class="detail-section-icon">
                <i class="bi bi-graph-up"></i>
              </div>
              Progress Stats
            </div>
            <div class="detail-grid">
              <div class="detail-item">
                <div class="detail-item-label">Days Since Referral</div>
                <div class="detail-item-value"><%= @referral.days_since_referral %> days</div>
              </div>
              <div class="detail-item">
                <div class="detail-item-label">Current Status</div>
                <div class="detail-item-value"><%= @referral.status.humanize %></div>
              </div>
              <% if @referral.customer %>
                <div class="detail-item">
                  <div class="detail-item-label">Customer ID</div>
                  <div class="detail-item-value">#<%= @referral.customer.id %></div>
                </div>
              <% end %>
              <div class="detail-item">
                <div class="detail-item-label">Referral ID</div>
                <div class="detail-item-value">#<%= @referral.id %></div>
              </div>
            </div>
          </div>

          <!-- Personal Notes -->
          <% if @referral.notes.present? %>
            <div class="notes-section">
              <div class="notes-title">
                <i class="bi bi-chat-quote-fill"></i>
                Your Personal Message
              </div>
              <div class="notes-content">
                "<%= @referral.notes %>"
              </div>
            </div>
          <% end %>

          <!-- Action Buttons -->
          <div class="action-buttons">
            <%= link_to new_customer_referral_path, class: "btn-modern btn-primary-modern" do %>
              <i class="bi bi-plus-circle-fill"></i>
              Refer Another Friend
            <% end %>
            <%= link_to customer_referrals_path, class: "btn-modern btn-outline-modern" do %>
              <i class="bi bi-list-ul"></i>
              View All Referrals
            <% end %>
            <% if @referral.status == 'pending' %>
              <%= link_to customer_referral_path(@referral), method: :delete,
                  confirm: "Are you sure you want to delete this referral?",
                  class: "btn-modern btn-danger-modern" do %>
                <i class="bi bi-trash"></i>
                Delete Referral
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>