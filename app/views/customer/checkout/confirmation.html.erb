<% content_for :title, 'Order Confirmation' %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <!-- Success Message -->
      <div class="text-center mb-5">
        <div class="success-icon mb-4">
          <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
        </div>
        <h1 class="text-success mb-3">Order Placed Successfully!</h1>
        <p class="text-muted">Thank you for your order. We'll process it shortly and keep you updated.</p>
      </div>

      <!-- Order Details Card -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0">
            <i class="bi bi-receipt me-2"></i>Order Details
          </h5>
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Booking Number:</strong><br>
              <span class="text-primary fs-5"><%= @booking.booking_number %></span>
            </div>
            <div class="col-md-6">
              <strong>Order Date:</strong><br>
              <%= @booking.booking_date.strftime('%d %B %Y at %I:%M %p') %>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Payment Method:</strong><br>
              <span class="badge bg-info"><%= @booking.payment_method.humanize %></span>
            </div>
            <div class="col-md-6">
              <strong>Status:</strong><br>
              <span class="badge bg-success"><%= @booking.status.humanize %></span>
            </div>
          </div>

          <div class="mb-3">
            <strong>Delivery Address:</strong><br>
            <div class="bg-light p-3 rounded">
              <%= simple_format(@booking.delivery_address) %>
            </div>
          </div>
        </div>
      </div>

      <!-- Order Items -->
      <div class="card shadow-sm mb-4">
        <div class="card-header">
          <h5 class="mb-0">
            <i class="bi bi-bag-check me-2"></i>Items Ordered
          </h5>
        </div>
        <div class="card-body">
          <% @booking_items.each do |item| %>
            <div class="row align-items-center py-3 border-bottom">
              <div class="col-md-6">
                <h6 class="mb-1"><%= item.product&.name || 'Product' %></h6>
                <small class="text-muted">Quantity: <%= item.quantity %></small>
              </div>
              <div class="col-md-3">
                <span>₹<%= item.price %></span>
              </div>
              <div class="col-md-3 text-end">
                <strong>₹<%= (item.price * item.quantity).round(2) %></strong>
              </div>
            </div>
          <% end %>

          <!-- Order Total -->
          <div class="row mt-4">
            <div class="col-md-8"></div>
            <div class="col-md-4">
              <div class="border rounded p-3 bg-light">
                <div class="d-flex justify-content-between mb-2">
                  <span>Subtotal:</span>
                  <span>₹<%= @booking.subtotal %></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span>Delivery:</span>
                  <span class="text-success">Free</span>
                </div>
                <hr class="my-2">
                <div class="d-flex justify-content-between fw-bold">
                  <span>Total:</span>
                  <span class="text-success">₹<%= @booking.total_amount %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Next Steps -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0">
            <i class="bi bi-info-circle me-2"></i>What's Next?
          </h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-start">
                <i class="bi bi-1-circle-fill text-primary me-3 mt-1"></i>
                <div>
                  <h6>Order Processing</h6>
                  <p class="text-muted mb-0">We'll prepare your items for delivery within 24 hours.</p>
                </div>
              </div>
            </div>
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-start">
                <i class="bi bi-2-circle-fill text-primary me-3 mt-1"></i>
                <div>
                  <h6>Quality Check</h6>
                  <p class="text-muted mb-0">Our team ensures all items meet our quality standards.</p>
                </div>
              </div>
            </div>
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-start">
                <i class="bi bi-3-circle-fill text-primary me-3 mt-1"></i>
                <div>
                  <h6>Delivery</h6>
                  <p class="text-muted mb-0">Your order will be delivered to the specified address.</p>
                </div>
              </div>
            </div>
            <div class="col-md-6 mb-3">
              <div class="d-flex align-items-start">
                <i class="bi bi-4-circle-fill text-primary me-3 mt-1"></i>
                <div>
                  <h6>Payment</h6>
                  <p class="text-muted mb-0">
                    <% if @booking.payment_method == 'cod' %>
                      Pay cash on delivery when your order arrives.
                    <% else %>
                      Your payment will be processed securely.
                    <% end %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="text-center">
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= link_to customer_orders_path, class: "btn btn-outline-primary btn-lg w-100" do %>
              <i class="bi bi-list-ul me-2"></i>View All Orders
            <% end %>
          </div>
          <div class="col-md-6 mb-3">
            <%= link_to customer_shop_path, class: "btn btn-success btn-lg w-100" do %>
              <i class="bi bi-arrow-left me-2"></i>Continue Shopping
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.success-icon {
  animation: bounceIn 0.6s ease-in-out;
}

@keyframes bounceIn {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.05); }
  70% { transform: scale(0.9); }
  100% { transform: scale(1); opacity: 1; }
}

.card {
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1) !important;
}
</style>