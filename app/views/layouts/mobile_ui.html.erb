<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Atma Nirbhar Farm</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <%= csrf_meta_tags %>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body {
      background: #f0f2f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      overscroll-behavior: none;
      min-height: 100vh;
    }
    .mobile-header {
      background: linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%);
      color: white;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .mobile-header .brand { font-size: 1.05rem; font-weight: 700; letter-spacing: 0.3px; }
    .mobile-header .sub-brand { font-size: 0.7rem; opacity: 0.8; }
    .mobile-content { padding-bottom: 80px; }
    .tab-nav {
      display: flex;
      background: white;
      border-bottom: 2px solid #e9ecef;
      position: sticky;
      top: 56px;
      z-index: 95;
    }
    .tab-nav a {
      flex: 1;
      text-align: center;
      padding: 10px 4px;
      font-size: 0.8rem;
      font-weight: 600;
      color: #6c757d;
      text-decoration: none;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      transition: all 0.15s;
    }
    .tab-nav a.active {
      color: #2e7d32;
      border-bottom-color: #2e7d32;
    }
    .tab-nav a i { display: block; font-size: 1.1rem; margin-bottom: 2px; }
    .fab {
      position: fixed;
      bottom: 24px;
      right: 20px;
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%);
      color: white;
      border: none;
      font-size: 1.6rem;
      box-shadow: 0 4px 18px rgba(46,125,50,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      z-index: 200;
      transition: transform 0.15s;
    }
    .fab:hover, .fab:active { transform: scale(0.93); color: white; }
    .flash-msg {
      position: fixed;
      top: 65px;
      left: 10px;
      right: 10px;
      z-index: 999;
      border-radius: 10px;
      font-size: 0.9rem;
      animation: fadeInDown 0.3s ease;
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Global page loader ── */
    #globalLoader {
      display: none;
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,0.45);
      align-items: center; justify-content: center;
    }
    #globalLoader.active { display: flex; }
    .gl-box {
      background: white; border-radius: 20px;
      padding: 28px 36px; text-align: center;
      box-shadow: 0 10px 40px rgba(0,0,0,0.25);
      min-width: 200px;
      animation: glPop 0.2s ease;
    }
    @keyframes glPop {
      from { transform: scale(0.85); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }
    .gl-ring {
      width: 50px; height: 50px;
      border: 5px solid #e6f4ea;
      border-top-color: #2e7d32;
      border-radius: 50%;
      animation: glSpin 0.7s linear infinite;
      margin: 0 auto 14px;
    }
    @keyframes glSpin { to { transform: rotate(360deg); } }
    .gl-text { font-size: 0.95rem; font-weight: 700; color: #1b5e20; }
    .gl-sub  { font-size: 0.75rem; color: #999; margin-top: 4px; }
  </style>
</head>
<body>
  <%# Header — only shown when logged in %>
  <% if session[:mobile_ui_auth] %>
    <div class="mobile-header px-3 py-2">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
               style="width:36px;height:36px;">
            <i class="bi bi-flower1 text-white fs-5"></i>
          </div>
          <div>
            <div class="brand">Atma Nirbhar Farm</div>
            <div class="sub-brand">Admin Mobile</div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <%= link_to admin_mobile_ui_bookings_path, class: "btn btn-sm btn-outline-light border-white border-opacity-50 text-white py-1 px-2" do %>
            <i class="bi bi-list-ul"></i>
          <% end %>
          <%= link_to admin_mobile_ui_logout_path,
              class: "btn btn-sm btn-outline-light border-white border-opacity-50 text-white py-1 px-2" do %>
            <i class="bi bi-box-arrow-right"></i>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Flash messages %>
  <% if flash[:error].present? %>
    <div class="flash-msg alert alert-danger alert-dismissible mb-0" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= flash[:error] %>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
  <% end %>
  <% if flash[:notice].present? %>
    <div class="flash-msg alert alert-success alert-dismissible mb-0" role="alert">
      <i class="bi bi-check-circle me-2"></i><%= flash[:notice] %>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <% if session[:mobile_ui_auth] %>
    <% current_path = request.path %>
    <nav class="tab-nav">
      <%= link_to admin_mobile_ui_bookings_path,
            class: "#{current_path == admin_mobile_ui_bookings_path ? 'active' : ''}" do %>
        <i class="bi bi-receipt"></i>Bookings
      <% end %>
      <%= link_to admin_mobile_ui_price_list_path,
            class: "#{current_path == admin_mobile_ui_price_list_path ? 'active' : ''}" do %>
        <i class="bi bi-tags"></i>Price List
      <% end %>
      <%= link_to admin_mobile_ui_vendors_path,
            class: "#{current_path == admin_mobile_ui_vendors_path ? 'active' : ''}" do %>
        <i class="bi bi-people"></i>Vendors
      <% end %>
    </nav>
  <% end %>

  <div class="mobile-content">
    <%= yield %>
  </div>

  <% if session[:mobile_ui_auth] %>
    <%# FAB speed-dial %>
    <div id="fabWrap" style="position:fixed;bottom:24px;right:20px;z-index:200;">
      <%# Sub-buttons (hidden by default) %>
      <div id="fabMenu" style="display:none;flex-direction:column;align-items:flex-end;gap:10px;margin-bottom:12px;">
        <%= link_to admin_mobile_ui_new_customer_path, style: "display:flex;align-items:center;gap:8px;text-decoration:none;" do %>
          <span style="background:white;color:#1b5e20;font-size:0.8rem;font-weight:600;padding:5px 12px;border-radius:20px;box-shadow:0 2px 8px rgba(0,0,0,0.15);white-space:nowrap;">New Customer + Booking</span>
          <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#2e7d32,#1b5e20);color:white;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(46,125,50,0.4);">
            <i class="bi bi-person-plus-fill" style="font-size:1.1rem;"></i>
          </div>
        <% end %>
        <%= link_to admin_mobile_ui_new_booking_path, style: "display:flex;align-items:center;gap:8px;text-decoration:none;" do %>
          <span style="background:white;color:#1b5e20;font-size:0.8rem;font-weight:600;padding:5px 12px;border-radius:20px;box-shadow:0 2px 8px rgba(0,0,0,0.15);white-space:nowrap;">New Booking</span>
          <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#2e7d32,#1b5e20);color:white;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(46,125,50,0.4);">
            <i class="bi bi-cart-plus-fill" style="font-size:1.1rem;"></i>
          </div>
        <% end %>
        <%= link_to admin_mobile_ui_new_vendor_purchase_path, style: "display:flex;align-items:center;gap:8px;text-decoration:none;" do %>
          <span style="background:white;color:#1b5e20;font-size:0.8rem;font-weight:600;padding:5px 12px;border-radius:20px;box-shadow:0 2px 8px rgba(0,0,0,0.15);white-space:nowrap;">New Vendor Purchase</span>
          <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#2e7d32,#1b5e20);color:white;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(46,125,50,0.4);">
            <i class="bi bi-truck" style="font-size:1.1rem;"></i>
          </div>
        <% end %>
      </div>
      <%# Main FAB %>
      <button id="fabMain" onclick="toggleFab()" style="width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,#2e7d32,#1b5e20);color:white;border:none;font-size:1.6rem;box-shadow:0 4px 18px rgba(46,125,50,0.5);display:flex;align-items:center;justify-content:center;transition:transform 0.2s;">
        <i class="bi bi-plus-lg" id="fabIcon"></i>
      </button>
    </div>
    <script>
      function toggleFab() {
        const menu = document.getElementById('fabMenu');
        const icon = document.getElementById('fabIcon');
        const btn  = document.getElementById('fabMain');
        const open = menu.style.display === 'flex';
        menu.style.display = open ? 'none' : 'flex';
        icon.className = open ? 'bi bi-plus-lg' : 'bi bi-x-lg';
        btn.style.transform = open ? '' : 'rotate(45deg)';
      }
      // Close fab when clicking outside
      document.addEventListener('click', function(e) {
        if (!document.getElementById('fabWrap').contains(e.target)) {
          document.getElementById('fabMenu').style.display = 'none';
          document.getElementById('fabIcon').className = 'bi bi-plus-lg';
          document.getElementById('fabMain').style.transform = '';
        }
      });
    </script>
  <% end %>

  <!-- Global page loader overlay -->
  <div id="globalLoader">
    <div class="gl-box">
      <div class="gl-ring"></div>
      <div class="gl-text" id="glText">Please wait…</div>
      <div class="gl-sub"  id="glSub"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Auto-dismiss flash after 3s
    setTimeout(() => {
      document.querySelectorAll('.flash-msg').forEach(el => {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.4s';
        setTimeout(() => el.remove(), 400);
      });
    }, 3000);

    /* ── Global Loader API ── */
    function showLoader(text, sub) {
      document.getElementById('glText').textContent = text || 'Please wait…';
      document.getElementById('glSub').textContent  = sub  || '';
      document.getElementById('globalLoader').classList.add('active');
    }
    function hideLoader() {
      document.getElementById('globalLoader').classList.remove('active');
    }

    /* Hide loader on browser back (page restored from bfcache) */
    window.addEventListener('pageshow', function(e) {
      if (e.persisted) hideLoader();
    });

    /* ── Auto-wire: show loader on all form submits ──
       Skip forms marked data-no-loader or method=GET search forms            */
    document.addEventListener('submit', function(e) {
      const form = e.target;
      if (form.dataset.noLoader !== undefined) return;
      if (form.method === 'get' && form.dataset.loaderOnGet === undefined) return;
      showLoader();
    }, true);

    /* ── Auto-wire: show loader on internal link clicks ──
       Skip: target=_blank, href=#, wa.me, data-no-loader                      */
    document.addEventListener('click', function(e) {
      const a = e.target.closest('a[href]');
      if (!a) return;
      if (a.dataset.noLoader !== undefined) return;
      if (a.target === '_blank') return;
      const href = a.getAttribute('href') || '';
      if (href === '#' || href.startsWith('#')) return;
      if (href.includes('wa.me') || href.includes('whatsapp')) return;
      if (a.hasAttribute('data-bs-dismiss') || a.hasAttribute('data-bs-toggle')) return;
      showLoader();
    }, true);
  </script>
</body>
</html>
